{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "StrategyHouse.Web.Services.SmtpEmailSender": "Information"
    }
  },
  "AllowedHosts": "*",

  "_SMTP_NOTES": [
    "After deploying to the IIS server, edit this file and set:",
    "  Smtp.Enabled = true",
    "  Smtp.Host    = 'smtp.office365.com'  (Office365)  OR  'mail.gac.gov.sa'  (internal Exchange)",
    "  Smtp.Username = '<service account mailbox>'",
    "  Smtp.Password = '<service account password / app password>'",
    "  Smtp.FromAddress = '<sender mailbox>'",
    "Restart the application pool after editing."
  ],
  "Smtp": {
    "Enabled": false,
    "Host": "smtp.office365.com",
    "Port": 587,
    "UseStartTls": true,
    "Username": "",
    "Password": "",
    "FromAddress": "no-reply@gac.gov.sa",
    "FromName": "منصة الاستراتيجية - GAC"
  }
}
