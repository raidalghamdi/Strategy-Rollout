@{
    ViewData["Title"] = "تحليلات القيادة";
    int deptCount = ViewBag.DeptCount;
    int completedDepts = ViewBag.CompletedDepts;
    int signedMaps = ViewBag.SignedMaps;
    int approvedMaps = ViewBag.ApprovedMaps;
    int totalPledges = ViewBag.TotalPledges;
    int quizAttempts = ViewBag.QuizAttempts;
    int surveyResponses = ViewBag.SurveyResponses;
    var rate = ViewBag.SignatureRate as System.Collections.IEnumerable;
    var timeline = ViewBag.Timeline as System.Collections.IEnumerable;
    string Pct(int a, int b) => b == 0 ? "0%" : Math.Round(100.0 * a / b) + "%";
}

@section Styles {
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
    <style>
        .ins-card { background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(40,51,74,.08);padding:18px;text-align:center; }
        .ins-card .num { font-size:2.2rem;font-weight:800;color:#28334A; }
        .ins-card .lbl { color:#5a6b80;font-size:.9rem; }
        .ins-nav a { margin-inline-start:8px; }
    </style>
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#28334A;">تحليلات القيادة</h1>
        <div class="ins-nav">
            <a class="btn btn-outline-primary btn-sm" href="/Admin/Insights/Coverage">خريطة التغطية</a>
            <a class="btn btn-outline-primary btn-sm" href="/Admin/Insights/Pledges">تحليل التعهدات</a>
            <a class="btn btn-outline-primary btn-sm" href="/Admin/Insights/Survey">تحليل الاستبيان</a>
            <a class="btn btn-outline-success btn-sm" href="/Admin/Insights/Poster">بوستر A2</a>
            <a class="btn btn-outline-secondary btn-sm" href="/Admin">رجوع</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@Pct(completedDepts, deptCount)</div><div class="lbl">إدارات أكملت الرحلة</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@signedMaps</div><div class="lbl">خرائط موقّعة</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@approvedMaps</div><div class="lbl">خرائط معتمدة</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@totalPledges</div><div class="lbl">إجمالي التعهدات</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@quizAttempts</div><div class="lbl">محاولات الاختبار</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@surveyResponses</div><div class="lbl">ردود الاستبيان</div></div></div>
        <div class="col-6 col-md-3"><div class="ins-card"><div class="num">@deptCount</div><div class="lbl">إجمالي الإدارات</div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6"><div class="ins-card"><h5>الخط الزمني للإتمام</h5><div class="chart-box"><canvas id="timelineChart"></canvas></div></div></div>
        <div class="col-12 col-md-6"><div class="ins-card"><h5>معدل التوقيع لكل إدارة</h5><div class="chart-box"><canvas id="rateChart"></canvas></div></div></div>
    </div>
</div>

@section Scripts {
    @* Phase 20.34 (Comment C) — Chart.js with robust loader *@
    <script src="/lib/chartjs/chart.umd.min.js" onload="if(typeof window._initInsightsCharts==='function')window._initInsightsCharts();"></script>
    <script>
        window._initInsightsCharts = function () {
            if (typeof Chart === 'undefined') return;
            Chart.defaults.font.family = "'Cairo','Noto Naskh Arabic',sans-serif";
            var tlEl = document.getElementById('timelineChart');
            if (tlEl && !tlEl.dataset.chartDone) {
                tlEl.dataset.chartDone = '1';
                var tl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(timeline));
                new Chart(tlEl, {
                    type: 'line',
                    data: { labels: tl.map(function(x){return x.date;}), datasets: [{ label: 'جلسات مكتملة', data: tl.map(function(x){return x.count;}), borderColor: '#28334A', backgroundColor: 'rgba(70,188,205,.3)', fill: true, tension: .3 }] },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { font: { family: "'Noto Naskh Arabic'" } } } } }
                });
            }
            var rtEl = document.getElementById('rateChart');
            if (rtEl && !rtEl.dataset.chartDone) {
                rtEl.dataset.chartDone = '1';
                var rt = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(rate));
                new Chart(rtEl, {
                    type: 'bar',
                    data: { labels: rt.map(function(x){return x.dept;}), datasets: [
                        { label: 'بدأت', data: rt.map(function(x){return x.started;}), backgroundColor: '#5F9600' },
                        { label: 'موقّعة', data: rt.map(function(x){return x.signed;}), backgroundColor: '#28334A' }
                    ] },
                    options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', scales: { x: { beginAtZero: true } } }
                });
            }
        };
        (function () {
            function tryInit() {
                if (typeof Chart !== 'undefined' && typeof window._initInsightsCharts === 'function') {
                    window._initInsightsCharts();
                    return true;
                }
                return false;
            }
            if (!tryInit()) {
                if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', tryInit);
                setTimeout(tryInit, 500);
            }
        })();
    </script>
}
