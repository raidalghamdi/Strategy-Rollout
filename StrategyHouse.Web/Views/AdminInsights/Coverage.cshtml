@model StrategyHouse.Web.Services.CoverageMatrix
@{
    ViewData["Title"] = "خريطة التغطية";
    var dim = ViewBag.Dim as string ?? "Pillar";
    string CellColor(int total) => total switch
    {
        0 => "#EEF2F7",
        <= 2 => "#CFE3F4",
        <= 5 => "#28334A",
        _ => "#0E2E55",
    };
    string TextColor(int total) => total >= 3 ? "#fff" : "#1d2733";
}

@section Styles {
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
    <style>
        .heat-wrap { overflow-x:auto; }
        table.heat { border-collapse:collapse; font-size:.78rem; }
        table.heat th, table.heat td { border:1px solid #dde5ef; padding:4px; text-align:center; min-width:42px; }
        table.heat th.rowhdr { text-align:right; min-width:220px; position:sticky; right:0; background:#fff; z-index:1; }
        table.heat thead th { background:#28334A; color:#fff; font-weight:600; writing-mode:vertical-rl; height:120px; }
        table.heat td.cell { cursor:default; position:relative; font-weight:700; }
        .legend span { display:inline-block;width:18px;height:18px;border-radius:3px;vertical-align:middle;margin-inline-start:4px; }
    </style>
}

<div class="container-fluid py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#28334A;">خريطة التغطية الاستراتيجية</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/Admin/Insights">رجوع للوحة</a>
    </div>

    <div class="mb-3">
        <div class="btn-group" role="group">
            <a class="btn btn-sm @(dim == "Pillar" ? "btn-primary" : "btn-outline-primary")" href="?dim=Pillar">حسب الركائز</a>
            <a class="btn btn-sm @(dim == "Objective" ? "btn-primary" : "btn-outline-primary")" href="?dim=Objective">حسب الأهداف</a>
            <a class="btn btn-sm @(dim == "Initiative" ? "btn-primary" : "btn-outline-primary")" href="?dim=Initiative">حسب المبادرات</a>
        </div>
        <span class="legend ms-3 small text-muted">
            القيمة = مؤشرات + مشاريع + تعهدات الإدارة على هذا العنصر.
            <span style="background:#EEF2F7;border:1px solid #ccc;"></span>0
            <span style="background:#CFE3F4;"></span>1-2
            <span style="background:#28334A;"></span>3-5
            <span style="background:#0E2E55;"></span>6+
        </span>
    </div>

    <div class="heat-wrap">
        <div class="scroll-x-sm">
<table class="heat">
            <thead>
                <tr>
                    <th class="rowhdr">العنصر \ الإدارة</th>
                    @foreach (var d in Model.Departments)
                    {
                        <th title="@d.DeptCode">@(d.NameAr ?? d.DeptCode)</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int r = 0; r < Model.Rows.Count; r++)
                {
                    <tr>
                        <th class="rowhdr">@Model.Rows[r].Label <span class="text-muted small">(@Model.Rows[r].Code)</span></th>
                        @for (int c = 0; c < Model.Departments.Count; c++)
                        {
                            var cell = Model.Cells[r, c];
                            var tip = cell.Total == 0 ? "لا توجد عناصر" :
                                $"مؤشرات: {cell.KpiCount} | مشاريع: {cell.ProjectCount} | تعهدات: {cell.PledgeCount}\n" + string.Join("\n", cell.Details);
                            <td class="cell" style="background:@CellColor(cell.Total);color:@TextColor(cell.Total);" title="@tip">
                                @(cell.Total == 0 ? "" : cell.Total.ToString())
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
</div>
    </div>
</div>
