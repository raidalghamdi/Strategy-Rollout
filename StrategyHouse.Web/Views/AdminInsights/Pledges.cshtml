@model StrategyHouse.Web.Services.PledgeAggregate
@{
    ViewData["Title"] = "تحليل التعهدات";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#194F90;">تحليل التعهدات</h1>
        <div>
            <a class="btn btn-success btn-sm" href="/Admin/Insights/Pledges/Csv">تصدير CSV</a>
            <a class="btn btn-outline-secondary btn-sm" href="/Admin/Insights">رجوع</a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card"><div class="card-body text-center">
                <div style="font-size:2rem;font-weight:800;color:#194F90;">@Model.Total</div>
                <div class="text-muted">إجمالي التعهدات</div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card"><div class="card-body"><h6>حسب نوع العنصر</h6>
                @foreach (var kv in Model.ByType)
                {
                    <div class="d-flex justify-content-between"><span>@kv.Key</span><strong>@kv.Value</strong></div>
                }
            </div></div>
        </div>
        <div class="col-md-5">
            <div class="card"><div class="card-body"><h6>حسب نوع المساهمة</h6>
                @foreach (var kv in Model.ByKind)
                {
                    <div class="d-flex justify-content-between"><span>@kv.Key</span><strong>@kv.Value</strong></div>
                }
            </div></div>
        </div>
    </div>

    <div class="card mb-3"><div class="card-body">
        <h5>أكثر 10 عناصر تعهداً</h5>
        <div class="chart-box"><canvas id="topChart"></canvas></div>
    </div></div>

    <div class="card"><div class="card-body">
        <h5>كل التعهدات</h5>
        <input id="filter" class="form-control mb-2" placeholder="بحث (إدارة / عنصر / نوع)..." />
        <div class="table-responsive">
            <table class="table table-sm table-hover" id="ptable">
                <thead><tr><th>الإدارة</th><th>النوع</th><th>العنصر</th><th>المساهمة</th><th>ملاحظات</th><th>التاريخ</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td>@r.DeptName</td>
                            <td>@r.ElementType</td>
                            <td>@r.ElementLabel <span class="text-muted small">@r.ElementCode</span></td>
                            <td>@r.Kind</td>
                            <td>@r.Notes</td>
                            <td class="small">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        Chart.defaults.font.family = "'Noto Naskh Arabic','Tajawal',sans-serif";
        const top = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopElements));
        new Chart(document.getElementById('topChart'), {
            type: 'bar',
            data: { labels: top.map(x => x.Label), datasets: [{ label: 'عدد التعهدات', data: top.map(x => x.Count), backgroundColor: '#46BCCD' }] },
            options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', scales: { x: { beginAtZero: true, ticks: { precision: 0 } } } }
        });
        document.getElementById('filter').addEventListener('input', function () {
            const q = this.value.trim();
            document.querySelectorAll('#ptable tbody tr').forEach(tr => {
                tr.style.display = tr.textContent.includes(q) ? '' : 'none';
            });
        });
    </script>
}
