@using StrategyHouse.Web.Controllers
@{
    ViewData["Title"] = "تحليل الاستبيان";
    var summary = ViewBag.Summary as AdminInsightsController.SurveySummary;
    var surveyUrl = ViewBag.SurveyUrl as string;
    string FmtSize(long b)
    {
        if (b < 1024) return b + " B";
        if (b < 1024 * 1024) return Math.Round(b / 1024.0, 1) + " KB";
        return Math.Round(b / (1024.0 * 1024.0), 2) + " MB";
    }
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <style>
        .ins-card { background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(40,51,74,.08);padding:18px; }
        .ins-card.center { text-align:center; }
        .ins-card .num { font-size:2.2rem;font-weight:800;color:#00192B; }
        .ins-card .lbl { color:#5a6b80;font-size:.9rem; }
        .sec-title { color:#00192B;font-weight:800;border-inline-start:5px solid #FAC126;padding-inline-start:12px;margin-bottom:14px; }
        .ins-nav a { margin-inline-start:8px; }
        .bar-row { display:flex;align-items:center;gap:10px;margin-bottom:8px; }
        .bar-row .bar-lbl { flex:0 0 40%;font-size:.9rem;color:#28334A;overflow:hidden;text-overflow:ellipsis;white-space:nowrap; }
        .bar-row .bar-track { flex:1;background:#eef1f5;border-radius:6px;height:18px;overflow:hidden; }
        .bar-row .bar-fill { height:100%;background:#FAC126; }
        .bar-row .bar-num { flex:0 0 40px;text-align:start;font-weight:700;color:#00192B; }
        .danger-zone { border:1px solid #f3c2c2;border-radius:14px;background:#fff6f6;padding:18px; }
        .url-box { background:#f6f8fa;border:1px solid #e2e8f0;border-radius:8px;padding:10px 14px;word-break:break-all; }
    </style>
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#00192B;">تحليل الاستبيان</h1>
        <div class="ins-nav">
            <a class="btn btn-outline-secondary btn-sm" href="/Admin/Insights">رجوع</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert" style="background:#067647;color:#fff;border:none;">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- Section 1 — current survey link -->
    <div class="ins-card mb-4">
        <h4 class="sec-title">رابط الاستبيان الحالي</h4>
        @if (!string.IsNullOrEmpty(surveyUrl))
        {
            <div class="url-box mb-2"><a href="@surveyUrl" target="_blank" rel="noopener">@surveyUrl</a></div>
        }
        else
        {
            <p class="text-muted">لا يوجد رابط محدد.</p>
        }
        <p class="text-muted mb-0" style="font-size:.9rem;">يمكن للمدير تعديل هذا الرابط من <a href="/Admin/Content">إدارة المحتوى</a> (المفتاح <code>quiz.survey.url</code>).</p>
    </div>

    <!-- Section 2 — upload xlsx -->
    <div class="ins-card mb-4">
        <h4 class="sec-title">رفع ملف نتائج الاستبيان (.xlsx)</h4>
        <p class="text-muted" style="font-size:.9rem;">ارفع ملف Excel المُصدّر من Microsoft Forms لتحليل الردود.</p>
        <form method="post" enctype="multipart/form-data" action="/Admin/Insights/Survey/Upload" class="row g-2 align-items-center">
            @Html.AntiForgeryToken()
            <div class="col-12 col-md-8">
                <input type="file" name="file" accept=".xlsx" class="form-control" required />
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="btn btn-primary w-100" style="background:#00192B;border-color:#00192B;">رفع وتحليل</button>
            </div>
        </form>
    </div>

    <!-- Section 3 — analysis summary -->
    @if (summary != null)
    {
        <div class="ins-card mb-4">
            <h4 class="sec-title">ملخص التحليل</h4>
            <div class="row g-3 mb-3">
                <div class="col-6 col-md-3"><div class="ins-card center"><div class="num">@summary.RowCount</div><div class="lbl">عدد الردود</div></div></div>
                <div class="col-6 col-md-3"><div class="ins-card center"><div class="num">@summary.Columns.Count</div><div class="lbl">عدد الحقول</div></div></div>
                <div class="col-6 col-md-3"><div class="ins-card center"><div class="num">@FmtSize(summary.FileSizeBytes)</div><div class="lbl">حجم الملف</div></div></div>
                <div class="col-6 col-md-3"><div class="ins-card center"><div class="num" style="font-size:1.2rem;">@summary.UploadedAt.ToString("yyyy-MM-dd HH:mm")</div><div class="lbl">آخر تحديث</div></div></div>
            </div>
            <a class="btn btn-outline-success btn-sm mb-3" href="/Admin/Insights/Survey/Download">تنزيل الملف الأصلي</a>

            @if (summary.Averages.Count > 0)
            {
                <h5 style="color:#00192B;">المتوسطات (حقول رقمية)</h5>
                <div class="row g-3 mb-3">
                    @foreach (var kv in summary.Averages)
                    {
                        <div class="col-12 col-md-4">
                            <div class="ins-card center">
                                <div class="num">@kv.Value.ToString("0.00")</div>
                                <div class="lbl">@kv.Key</div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (summary.ValueCounts.Count > 0)
            {
                <h5 style="color:#00192B;">تكرار الإجابات (حقول نصية)</h5>
                <div class="row g-3">
                    @foreach (var entry in summary.ValueCounts)
                    {
                        var maxCount = entry.Value.Count > 0 ? entry.Value.Max(v => v.Value) : 1;
                        <div class="col-12 col-md-6">
                            <div class="ins-card">
                                <h6 style="color:#00192B;font-weight:700;">@entry.Key</h6>
                                @foreach (var v in entry.Value)
                                {
                                    var pct = maxCount == 0 ? 0 : (int)Math.Round(100.0 * v.Value / maxCount);
                                    <div class="bar-row">
                                        <span class="bar-lbl" title="@v.Key">@v.Key</span>
                                        <span class="bar-track"><span class="bar-fill" style="width:@(pct)%;"></span></span>
                                        <span class="bar-num">@v.Value</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Section 4 — reset (password-gated) -->
    <div class="danger-zone mb-4">
        <h4 class="sec-title" style="border-inline-start-color:#dc3545;">إعادة تهيئة الاستبيان</h4>
        <p class="text-muted" style="font-size:.9rem;">سيتم حذف بيانات الاستبيان المرفوعة وإرجاع رابط الاستبيان إلى الإعداد الافتراضي. تتطلب هذه العملية كلمة مرور المدير.</p>
        <form method="post" action="/Admin/Insights/Survey/Reset" class="row g-2 align-items-center"
              onsubmit="return confirm('سيتم حذف بيانات الاستبيان وإرجاع الرابط إلى الافتراضي. هل أنت متأكد؟');">
            @Html.AntiForgeryToken()
            <div class="col-12 col-md-8">
                <input type="password" name="password" class="form-control" placeholder="كلمة مرور المدير" required />
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="btn btn-danger w-100">إعادة التهيئة</button>
            </div>
        </form>
    </div>
</div>
