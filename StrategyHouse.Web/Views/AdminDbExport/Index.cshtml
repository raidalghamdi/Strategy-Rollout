@model List<StrategyHouse.Web.Controllers.AdminDbExportController.TableSummary>
@{
    ViewData["Title"] = "تصدير قاعدة البيانات";
    var totalRows = Model.Sum(t => t.RowCount < 0 ? 0 : t.RowCount);
}

@section Styles {
    <style>
        .dbx-card { background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(40,51,74,.08);padding:18px;margin-bottom:20px; }
        .sec-title { color:#00192B;font-weight:800;border-inline-start:5px solid #FAC126;padding-inline-start:12px;margin-bottom:14px; }
        .dbx-stat { display:inline-block;background:#f1f5f9;border-radius:10px;padding:10px 16px;margin-inline-end:12px;margin-bottom:6px; }
        .dbx-stat strong { display:block;font-size:1.5rem;color:#00192B; }
        .dbx-stat span { font-size:.85rem;color:#64748b; }
        .dbx-table th { color:#00192B;background:#f8fafc; }
        .dbx-table code { background:#f1f5f9;padding:2px 6px;border-radius:4px;font-size:.85rem; }
        .dbx-download { background:#067647;color:#fff;border:none;padding:14px 28px;border-radius:12px;font-weight:700;font-size:1.05rem; }
        .dbx-download:hover { background:#055e39;color:#fff; }
    </style>
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#00192B;">تصدير قاعدة البيانات</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/Admin">رجوع</a>
    </div>

    <div class="dbx-card">
        <h4 class="sec-title">نظرة عامة</h4>
        <div class="dbx-stat">
            <strong>@Model.Count</strong>
            <span>عدد الجداول</span>
        </div>
        <div class="dbx-stat">
            <strong>@totalRows.ToString("N0")</strong>
            <span>إجمالي الصفوف</span>
        </div>
        <div class="dbx-stat">
            <strong>SQLite</strong>
            <span>نوع قاعدة البيانات</span>
        </div>
    </div>

    <div class="dbx-card">
        <h4 class="sec-title">تنزيل ملف Excel كامل</h4>
        <p class="text-muted" style="font-size:.95rem;">
            سيتم إنشاء ملف Excel يحتوي على ورقة لكل جدول من جداول قاعدة البيانات، بالإضافة إلى
            ورقة "نظرة عامة" بأسماء الجداول وأعداد الصفوف. الملف يُولّد لحظياً من القاعدة الحية.
        </p>
        <a class="dbx-download" href="/Admin/DbExport/Download">
            ⬇ تنزيل ملف Excel كامل (.xlsx)
        </a>
    </div>

    <div class="dbx-card">
        <h4 class="sec-title">قائمة الجداول</h4>
        <div class="table-responsive">
            <table class="table dbx-table align-middle">
                <thead>
                    <tr>
                        <th style="width:5%">#</th>
                        <th>اسم الجدول</th>
                        <th style="width:20%">عدد الصفوف</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td><code>@t.Name</code></td>
                            <td>@(t.RowCount < 0 ? "—" : t.RowCount.ToString("N0"))</td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
