@model List<StrategyHouse.Web.Controllers.ContentItem>
@{
    ViewData["Title"] = "تحرير نصوص الصفحات";
    var labels = new Dictionary<string, string>
    {
        ["home.hero.title"] = "العنوان الرئيسي للصفحة الرئيسية",
        ["home.hero.subtitle"] = "العنوان الفرعي للصفحة الرئيسية",
        ["home.hero.cta"] = "زر الدعوة في الواجهة",
        ["home.about.title"] = "عنوان قسم: عن المنصة",
        ["home.about.body"] = "نص قسم: عن المنصة",
        ["home.objectives.title"] = "عنوان قسم: أهداف الرحلة",
        ["home.objectives.body"] = "نص قسم: أهداف الرحلة",
        ["home.cta.title"] = "عنوان قسم الدعوة للإجراء",
        ["home.cta.button"] = "زر قسم الدعوة للإجراء",
        ["home.contact.title"] = "عنوان قسم التواصل",
        ["home.contact.phone"] = "هاتف التواصل",
        ["home.contact.email"] = "بريد التواصل",
        ["home.footer.note"] = "ملاحظة التذييل في الصفحة الرئيسية",
        ["home.session.title"] = "عنوان: كيف تعمل الجلسة",
        ["home.session.item1.title"] = "الحركة الأولى — العنوان",
        ["home.session.item1.body"] = "الحركة الأولى — النص",
        ["home.session.item2.title"] = "الحركة الثانية — العنوان",
        ["home.session.item2.body"] = "الحركة الثانية — النص",
        ["home.session.item3.title"] = "الحركة الثالثة — العنوان",
        ["home.session.item3.body"] = "الحركة الثالثة — النص",
        ["home.session.item4.title"] = "الإغلاق — العنوان",
        ["home.session.item4.body"] = "الإغلاق — النص",
        ["home.principles.title"] = "عنوان: المبادئ التشغيلية",
        ["home.principles.item1"] = "المبدأ الأول",
        ["home.principles.item2"] = "المبدأ الثاني",
        ["home.principles.item3"] = "المبدأ الثالث",
        ["home.principles.item4"] = "المبدأ الرابع",
        ["home.principles.item5"] = "المبدأ الخامس",
        ["journey.landing.intro"] = "مقدمة صفحة الدخول للرحلة",
        ["journey.stage1.intro"] = "مقدمة المرحلة 1 — الفريق",
        ["journey.stage2.intro"] = "مقدمة المرحلة 2 — الصورة الكبرى",
        ["journey.stage3.intro"] = "مقدمة المرحلة 3 — بيت الاستراتيجية",
        ["journey.stage4.intro"] = "مقدمة المرحلة 4 — المساهمة",
        ["journey.stage5.intro"] = "مقدمة المرحلة 5 — الخريطة والتوقيع",
        ["journey.stage6.intro"] = "مقدمة المرحلة 6 — الإتمام",
        ["quiz.intro"] = "مقدمة الاختبار",
        ["survey.thank_you"] = "رسالة الشكر بعد الاستبيان",
        ["footer.copyright"] = "نص حقوق النشر في التذييل",
    };

    var sectionTitles = new Dictionary<string, string>
    {
        ["home"] = "الصفحة الرئيسية",
        ["journey"] = "رحلة الاستراتيجية",
        ["quiz"] = "الاختبار",
        ["survey"] = "الاستبيان",
        ["footer"] = "التذييل العام",
    };
    string SectionOf(string key)
    {
        var dot = key.IndexOf('.');
        return dot > 0 ? key.Substring(0, dot) : key;
    }
    string SectionTitle(string sec) => sectionTitles.TryGetValue(sec, out var t) ? t : sec;

    var groups = Model
        .GroupBy(m => SectionOf(m.Key))
        .OrderBy(g => g.Key == "home" ? 0 : 1)
        .ThenBy(g => g.Key);
}
<h1>تحرير نصوص الصفحات</h1>
<p class="muted">عدّل النصوص الظاهرة للمستخدمين. التغييرات تُحفظ فوراً وتظهر مباشرة على الصفحات.</p>

@if (TempData["Saved"] != null)
{
    <div class="alert alert--success">@TempData["Saved"]</div>
}

<form method="post" action="/Admin/Content/Save">
    @Html.AntiForgeryToken()
    @foreach (var group in groups)
    {
        <h2 class="h5 mt-4" style="color:#00192B;border-bottom:2px solid #FAC126;padding-bottom:6px;">@SectionTitle(group.Key)</h2>
        @foreach (var item in group)
        {
            var rows = (item.Value != null && item.Value.Length > 90) ? 4 : 2;
            <div class="card" style="margin-bottom:14px;">
                <label class="form-row" style="margin-bottom:0;">
                    <strong>@(labels.TryGetValue(item.Key, out var l) ? l : item.Key)</strong>
                    <span class="hint">@item.Key</span>
                    <input type="hidden" name="keys" value="@item.Key" />
                    <textarea name="values" class="textarea" rows="@rows">@item.Value</textarea>
                </label>
            </div>
        }
    }
    <div class="sticky-bottom-cta btn-stack-mobile">
        <button type="submit" class="btn btn--primary">حفظ جميع التغييرات</button>
    </div>
</form>
