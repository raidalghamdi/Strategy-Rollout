@using StrategyHouse.Domain.Entities
@model List<StrategyMap>
@{
    ViewData["Title"] = "جدار الالتزامات الرقمي";
    var totalDepts = (int)ViewBag.TotalDepts;
    var isComplete = (bool)ViewBag.IsComplete;
}

<div class="hero">
    <h1>جدار الالتزامات الرقمي</h1>
    <p>هنا تُعرض الالتزامات الجماعية لكل إدارة بعد تثبيت خريطتها الاستراتيجية. كل التزام مرتبط بعنصر من بيت الاستراتيجية.</p>
</div>

@if (isComplete)
{
    <div class="alert alert--success">
        <strong>تم! جميع الإدارات الـ @totalDepts أنهت خرائطها.</strong> الجدار مفتوح الآن للجميع كرسالة جماعية للهيئة.
    </div>
}
else
{
    <div class="alert alert--info">
        أُكمل حتى الآن: <strong>@Model.Count</strong> من <strong>@totalDepts</strong> إدارة. الجدار سيُعمَّم عند اكتمال الجميع.
    </div>
}

@if (!Model.Any())
{
    <div class="card center">
        <p class="muted">لم تُثبَّت أي خريطة بعد. ستظهر الالتزامات هنا بعد إنهاء كل جلسة.</p>
    </div>
}
else
{
    <div class="wall">
        @foreach (var m in Model)
        {
            <div class="wall-card">
                <div class="wall-card__dept">@m.Department!.NameAr</div>
                <ul class="wall-card__commitments">
                    @foreach (var c in m.Commitments)
                    {
                        <li>
                            <strong>@c.TextAr</strong>
                            @if (c.LinkedElement != null)
                            {
                                <div class="muted" style="font-size:12px; margin-top:2px;">↳ @c.LinkedElement.NameAr</div>
                            }
                        </li>
                    }
                </ul>
                <div class="wall-card__sig-count">
                    🖋 @m.Signatures.Count توقيع تطوعي · ثُبِّت @(m.FinalizedAt?.ToString("yyyy-MM-dd") ?? "")
                </div>
            </div>
        }
    </div>
}
