@model StrategyHouse.Web.Controllers.ResetPasswordModel
@{ ViewData["Title"] = "إعادة تعيين كلمة المرور"; }
<h1>إعادة تعيين كلمة المرور: @ViewBag.UserName</h1>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">@Html.Raw(string.Join("<br>", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage)))</div>
}
<form method="post" action="/Admin/Users/ResetPassword/@Model.Id" class="card" style="max-width:480px;">
    @Html.AntiForgeryToken()
    <label class="form-label">كلمة المرور الجديدة</label>
    <input name="NewPassword" type="password" class="form-control mb-3" required />

    <label class="form-label">تأكيد كلمة المرور</label>
    <input name="ConfirmPassword" type="password" class="form-control mb-3" required />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn--primary">تعيين</button>
        <a href="/Admin/Users" class="btn btn--secondary">إلغاء</a>
    </div>
</form>
