@model List<StrategyHouse.Web.Controllers.UserRow>
@{ ViewData["Title"] = "إدارة المستخدمين"; }

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1 class="mb-0">إدارة المستخدمين (@Model.Count)</h1>
    <a href="/Admin/Users/Create" class="btn btn--primary">+ مستخدم جديد</a>
</div>
<p class="muted">المستخدمون لا يُحذفون نهائياً — التعطيل يحافظ على سجل التدقيق. حسابات الأدمن المحمية لا يمكن تعديلها أو إعادة تسميتها من هذه الواجهة.</p>

@* Phase 20.33 (Comment 6) — Mobile responsive: hide low-priority columns on small screens *@
<div class="table-responsive">
    <table class="table table-hover align-middle" style="background:#fff;">
        <thead>
            <tr>
                <th>اسم المستخدم</th>
                <th class="d-none d-md-table-cell">الاسم</th>
                <th>الدور</th>
                <th class="d-none d-lg-table-cell">نطاق الرحلة</th>
                <th>الحالة</th>
                <th class="d-none d-md-table-cell">آخر دخول</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>
                    <div>@u.UserName</div>
                    @* On mobile, show name under username *@
                    <div class="d-md-none small text-muted">@u.FullNameAr</div>
                    @if (u.IsProtected)
                    {
                        <span class="badge bg-warning text-dark ms-1" title="حساب أدمن محمي — لا يمكن تعديله أو حذفه">محمي</span>
                    }
                </td>
                <td class="d-none d-md-table-cell">@u.FullNameAr</td>
                <td>@u.AppRole</td>
                <td class="d-none d-lg-table-cell"><span class="small">@(u.JourneyScopeKey ?? "—")</span></td>
                <td>@(u.IsActive ? Html.Raw("<span class='badge bg-success'>نشط</span>") : Html.Raw("<span class='badge bg-secondary'>معطّل</span>"))</td>
                <td class="d-none d-md-table-cell"><span class="small">@(u.LastLoginAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</span></td>
                <td class="text-nowrap">
                    @if (u.IsProtected)
                    {
                        <span class="small muted">—</span>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-1">
                            <a href="/Admin/Users/Edit/@u.Id" class="btn btn-sm btn--secondary">تعديل</a>
                            <a href="/Admin/Users/Rename/@u.Id" class="btn btn-sm btn--secondary d-none d-md-inline-flex">إعادة تسمية</a>
                            <a href="/Admin/Users/ResetPassword/@u.Id" class="btn btn-sm btn--secondary">كلمة المرور</a>
                            @if (u.IsActive)
                            {
                                <form method="post" action="/Admin/Users/Delete/@u.Id" style="display:inline;" onsubmit="return confirm('تعطيل هذا المستخدم؟');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn--danger">تعطيل</button>
                                </form>
                            }
                        </div>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
