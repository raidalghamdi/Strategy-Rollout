@using StrategyHouse.Web.Services
@model DailySummary
@{ ViewData["Title"] = "لوحة المؤشرات اليومية"; }

<h1>لوحة المؤشرات اليومية</h1>
<p class="muted">اليوم: <strong>@Model.Day.ToString("yyyy-MM-dd")</strong> · يجيب على الأسئلة التشغيلية الخمسة لمكتب الاستراتيجية.</p>

<form method="get" action="/Dashboard" class="row mb-3">
    <input type="date" name="day" value="@Model.Day.ToString("yyyy-MM-dd")" class="input" style="max-width:220px;" />
    <button type="submit" class="btn btn--secondary">تحديث</button>
</form>

<div class="card">
    <h2>١. من حضر اليوم؟</h2>
    @if (Model.Attendance.Any())
    {
        <table class="table">
            <thead><tr><th>الجلسة</th><th>الإدارات</th><th>المخطط</th><th>الحاضرون</th><th>النسبة</th></tr></thead>
            <tbody>
                @foreach (var r in Model.Attendance)
                {
                    var pct = r.Planned > 0 ? (int)Math.Round(r.Attended * 100.0 / r.Planned) : 0;
                    <tr>
                        <td>@r.Title</td>
                        <td>@r.Departments</td>
                        <td>@r.Planned</td>
                        <td>@r.Attended</td>
                        <td><span class="badge @(pct >= 80 ? "badge--green" : pct >= 50 ? "badge--orange" : "badge--gray")">@pct%</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else { <p class="muted">لا توجد جلسات في هذا اليوم.</p> }
</div>

<div class="card">
    <h2>٢. كيف وجدوا الجلسة؟ (متوسطات الاستبيان)</h2>
    @if (Model.SurveyAverages.Any())
    {
        <table class="table">
            <thead><tr><th>السؤال</th><th>المتوسط</th><th>عدد الإجابات</th></tr></thead>
            <tbody>
                @foreach (var r in Model.SurveyAverages)
                {
                    <tr><td>@r.Question</td><td><strong>@r.Average.ToString("F1")</strong> / 5</td><td>@r.Responses</td></tr>
                }
            </tbody>
        </table>
    }
    else { <p class="muted">لا توجد ردود استبيان لهذا اليوم.</p> }
</div>

<div class="card">
    <h2>٣. ما الالتزامات الأكثر تكراراً؟</h2>
    @if (Model.TopCommitments.Any())
    {
        <table class="table">
            <thead><tr><th>الالتزام</th><th>التكرار</th><th>الربط</th></tr></thead>
            <tbody>
                @foreach (var r in Model.TopCommitments)
                {
                    <tr><td>@r.Text</td><td><span class="badge badge--primary">@r.Count</span></td><td>@r.LinkedTo</td></tr>
                }
            </tbody>
        </table>
    }
    else { <p class="muted">لا توجد التزامات بعد.</p> }
</div>

<div class="card">
    <h2>٤. هل بقيت المفاهيم في الذاكرة؟ (اختبار اليوم)</h2>
    @if (Model.QuizRetention.Any())
    {
        <table class="table">
            <thead><tr><th>السؤال</th><th>إجابات</th><th>صحيحة</th><th>نسبة الصحة</th></tr></thead>
            <tbody>
                @foreach (var r in Model.QuizRetention)
                {
                    var pct = r.Answers > 0 ? (int)Math.Round(r.Correct * 100.0 / r.Answers) : 0;
                    <tr><td>@r.Question</td><td>@r.Answers</td><td>@r.Correct</td><td><span class="badge @(pct >= 70 ? "badge--green" : pct >= 50 ? "badge--orange" : "badge--gray")">@pct%</span></td></tr>
                }
            </tbody>
        </table>
    }
    else { <p class="muted">لم تتوفر بيانات اختبار بعد.</p> }
</div>

<div class="card">
    <h2>٥. ماذا كتبوا بأقلامهم؟ (نص مفتوح)</h2>
    @if (Model.OpenText.Any())
    {
        <ul style="list-style:none; padding:0;">
            @foreach (var r in Model.OpenText)
            {
                <li style="border-bottom:1px solid var(--border-soft); padding:8px 0;">
                    <div class="muted" style="font-size:12px;">@r.Question</div>
                    <div>@r.Text</div>
                </li>
            }
        </ul>
    }
    else { <p class="muted">لا توجد ردود نصية مفتوحة لهذا اليوم.</p> }
</div>
