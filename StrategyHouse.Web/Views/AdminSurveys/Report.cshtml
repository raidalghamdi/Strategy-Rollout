@model StrategyHouse.Web.Services.SurveyReportPdfService.ReportModel
@{
    ViewData["Title"] = "تقرير الاستبيان";
    var id = Context.Request.RouteValues["id"];
    string TypeAr(string t) => t switch
    {
        "Likert5" => "مقياس (1-5)", "MCQ" => "اختيار من متعدد", "Text" => "نص حر", "YesNo" => "نعم/لا", _ => t
    };
}

@section Styles {
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 style="color:#28334A;">تقرير الاستبيان</h1>
            <h5 style="color:#FAC126;">@Model.SurveyTitle</h5>
        </div>
        <div>
            <a class="btn btn-outline-success btn-sm" asp-action="ReportPdf" asp-route-id="@id">تصدير PDF</a>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">رجوع</a>
        </div>
    </div>

    <div class="alert alert-info">إجمالي الردود: <strong>@Model.TotalResponses</strong></div>

    @if (Model.ByDept.Any())
    {
        <h4 style="color:#28334A;">التوزيع حسب الإدارة</h4>
        <div class="table-responsive">
<table class="table table-sm w-auto">
            <thead><tr><th>الإدارة</th><th>عدد الردود</th></tr></thead>
            <tbody>
                @foreach (var (dept, cnt) in Model.ByDept)
                {
                    <tr><td>@dept</td><td>@cnt</td></tr>
                }
            </tbody>
        </table>
</div>
    }

    @foreach (var q in Model.Questions)
    {
        <div class="card mb-3"><div class="card-body">
            <h6 style="color:#28334A;">@q.QuestionAr</h6>
            <div class="small text-muted">@TypeAr(q.Type) · عدد الإجابات: @q.Answered</div>
            @if (q.Average != null)
            {
                <div class="fw-bold text-success">المتوسط: @q.Average?.ToString("0.00") / 5</div>
            }
            @if (q.Distribution.Any())
            {
                var maxC = Math.Max(1, q.Distribution.Max(d => d.Count));
                <div class="mt-2">
                    @foreach (var (label, cnt) in q.Distribution)
                    {
                        var pct = (int)(100.0 * cnt / maxC);
                        <div class="d-flex align-items-center mb-1">
                            <div style="width:140px;">@label</div>
                            <div class="flex-grow-1 bg-light rounded" style="height:18px;">
                                <div style="width:@pct%;height:18px;background:#299ECE;border-radius:4px;"></div>
                            </div>
                            <div style="width:40px;" class="text-start fw-bold">@cnt</div>
                        </div>
                    }
                </div>
            }
            @if (q.Verbatim.Any())
            {
                <div class="mt-2">
                    <div class="fw-bold" style="color:#FAC126;">عينة من الإجابات:</div>
                    <ul class="small text-muted mb-0">
                        @foreach (var v in q.Verbatim) { <li>@v</li> }
                    </ul>
                </div>
            }
        </div></div>
    }
</div>
