@model StrategyHouse.Domain.Entities.Survey
@{
    ViewData["Title"] = "تحرير الاستبيان";
    string TypeAr(string t) => t switch
    {
        "Likert5" => "مقياس (1-5)", "MCQ" => "اختيار من متعدد", "Text" => "نص حر", "YesNo" => "نعم/لا", _ => t
    };
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center">
        <h1 style="color:#28334A;">تحرير الاستبيان</h1>
        <div>
            <a class="btn btn-outline-info btn-sm" asp-action="Qr" asp-route-id="@Model.Id">رمز QR</a>
            <a class="btn btn-outline-success btn-sm" asp-action="Report" asp-route-id="@Model.Id">التقرير</a>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">رجوع</a>
        </div>
    </div>

    <form method="post" asp-action="Update" asp-route-id="@Model.Id" class="card card-body my-3">
        @Html.AntiForgeryToken()
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">العنوان</label>
                <input name="titleAr" class="form-control" value="@Model.TitleAr" />
            </div>
            <div class="col-md-4">
                <label class="form-label">الوصف</label>
                <input name="descriptionAr" class="form-control" value="@Model.DescriptionAr" />
            </div>
            <div class="col-md-2 form-check mt-4">
                <input class="form-check-input" type="checkbox" name="isActive" value="true" id="active" @(Model.IsActive ? "checked" : "") />
                <label class="form-check-label" for="active">نشط</label>
            </div>
            <div class="col-md-1"><button class="btn btn-primary w-100" style="background:#28334A;border:none;">حفظ</button></div>
        </div>
        <div class="mt-2 small text-muted">الرابط العام: <code>/s/@Model.PublicToken</code></div>
    </form>

    <form method="post" asp-action="RegenerateToken" asp-route-id="@Model.Id" class="mb-3">
        @Html.AntiForgeryToken()
        <button class="btn btn-sm btn-outline-warning">توليد رابط جديد</button>
    </form>

    <h4 style="color:#28334A;">الأسئلة (@Model.Questions.Count)</h4>
    <ol class="list-group list-group-numbered mb-3">
        @foreach (var q in Model.Questions)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="flex-grow-1">
                        <span class="badge bg-info text-dark">@TypeAr(q.Type)</span>
                        <form method="post" asp-action="EditQuestion" asp-route-id="@Model.Id" asp-route-qid="@q.Id" class="d-flex gap-2 mt-2">
                            @Html.AntiForgeryToken()
                            <input name="questionAr" class="form-control form-control-sm" value="@q.QuestionAr" required />
                            <button class="btn btn-sm btn-outline-primary" type="submit">حفظ النص</button>
                        </form>
                        @if (!string.IsNullOrEmpty(q.OptionsJson))
                        {
                            var opts = System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new();
                            <div class="small text-muted mt-1">@string.Join(" · ", opts)</div>
                        }
                    </div>
                    <form method="post" asp-action="DeleteQuestion" asp-route-id="@Model.Id" asp-route-qid="@q.Id">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">حذف</button>
                    </form>
                </div>
            </li>
        }
    </ol>

    <form method="post" asp-action="AddQuestion" asp-route-id="@Model.Id" class="card card-body">
        @Html.AntiForgeryToken()
        <h5>إضافة سؤال</h5>
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">النوع</label>
                <select name="type" class="form-select" id="qtype">
                    <option value="Likert5">مقياس (1-5)</option>
                    <option value="MCQ">اختيار من متعدد</option>
                    <option value="Text">نص حر</option>
                    <option value="YesNo">نعم/لا</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">نص السؤال</label>
                <input name="questionAr" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">خيارات (مفصولة بـ |)</label>
                <input name="optionsCsv" class="form-control" placeholder="للاختيار من متعدد فقط" />
            </div>
            <div class="col-md-1"><button class="btn btn-success w-100">إضافة</button></div>
        </div>
    </form>
</div>
