@{
    ViewData["Title"] = "رفع نتائج الاستبيان";
}

@section Styles {
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center">
        <h1 style="color:#28334A;">📥 رفع نتائج وتحليل</h1>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">رجوع للاستبيانات</a>
    </div>

    @if (TempData["Error"] is string errMsg && !string.IsNullOrEmpty(errMsg))
    {
        <div class="alert alert-danger mt-3">@errMsg</div>
    }
    @if (TempData["Success"] is string okMsg && !string.IsNullOrEmpty(okMsg))
    {
        <div class="alert alert-success mt-3">@okMsg</div>
    }

    <div class="card my-3">
        <div class="card-body">
            <h5 class="card-title" style="color:#28334A;">رفع ملف Excel للنتائج الخام</h5>
            <p class="text-muted small mb-3">
                ارفع ملف <code>.xlsx</code> يحتوي على الأعمدة:
                <strong>Survey</strong> · <strong>Email</strong> · <strong>Name</strong> (نص السؤال) ·
                <strong>Answer</strong> · <strong>Notes</strong> · <strong>Suggestions</strong> ·
                <strong>SubmittionDateTime</strong>.
                سيقوم النظام تلقائياً بمطابقة الأسئلة مع الاستبيان النشط وإضافة جميع الاستجابات
                (مع <strong>إضافة الكل دائماً</strong> بدون فحص تكرار)، ثم سيوجّهك إلى صفحة التحليلات.
            </p>

            <form method="post" asp-action="ImportPreview" enctype="multipart/form-data" class="d-flex gap-2 align-items-end flex-wrap">
                @Html.AntiForgeryToken()
                <div class="flex-grow-1">
                    <label class="form-label">ملف Excel (xlsx)</label>
                    <input type="file" name="file" accept=".xlsx" class="form-control" required />
                </div>
                <div>
                    <button type="submit" class="btn btn-lg"
                            style="background:#1f8a4c;color:#fff;font-weight:700;border:none;">
                        🔍 تحليل ومعاينة
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0" style="background:#f8f9fb;">
        <div class="card-body small text-muted">
            <strong style="color:#28334A;">ملاحظات:</strong>
            <ul class="mb-0">
                <li>الحد الأقصى لحجم الملف: ~20 ميغابايت.</li>
                <li>يتم تجميع الصفوف حسب البريد الإلكتروني + وقت التسليم (دقيقة)
                    إلى استجابة واحدة لكل مشارك.</li>
                <li>يمكنك رفع نفس الملف عدة مرات؛ سيقوم النظام بإضافة جميع الاستجابات في كل مرة.</li>
                <li>إذا كان لديك أكثر من استبيان نشط، ستحتاج لتعطيل البقية مؤقتاً لاختيار الهدف تلقائياً.</li>
            </ul>
        </div>
    </div>
</div>
