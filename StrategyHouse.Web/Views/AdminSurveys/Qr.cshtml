@model StrategyHouse.Domain.Entities.Survey
@{
    ViewData["Title"] = "رمز QR";
    var url = ViewBag.Url as string;
    var qr = ViewBag.QrPng as string;
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-4 text-center" dir="rtl">
    <h1 style="color:#28334A;">@Model.TitleAr</h1>
    <p class="text-muted">امسح الرمز للمشاركة في الاستبيان</p>
    <img src="@qr" alt="QR" class="my-3" style="max-width:320px;" />
    <div><a href="@url" class="d-block">@url</a></div>
    <div class="mt-4">
        <button class="btn btn-outline-primary" onclick="window.print()">طباعة</button>
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">رجوع</a>
    </div>
</div>
