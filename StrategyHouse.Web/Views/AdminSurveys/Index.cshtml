@model List<StrategyHouse.Web.Controllers.SurveyListItem>
@{
    ViewData["Title"] = "الاستبيانات";
    var surveys = Model;
}

@section Styles {
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center">
        <h1 style="color:#28334A;">الاستبيانات</h1>
        <div>
            <a class="btn btn-sm" style="background:#1f8a4c;color:#fff;font-weight:700;border:none;" asp-action="Import">📥 رفع نتائج وتحليل</a>
            <a class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border:none;" asp-action="Link">رابط وصورة QR</a>
            <a class="btn btn-outline-secondary btn-sm" href="/Admin">رجوع</a>
        </div>
    </div>
    @if (TempData["Success"] is string okMsg && !string.IsNullOrEmpty(okMsg))
    {
        <div class="alert alert-success mt-3 mb-0">@okMsg</div>
    }
    @if (TempData["Error"] is string errMsg && !string.IsNullOrEmpty(errMsg))
    {
        <div class="alert alert-danger mt-3 mb-0">@errMsg</div>
    }
    <div class="alert alert-info mt-3 mb-0" style="background:#fff8e1;border:1px solid #FAC126;color:#00192B;">
        <strong>جديد — إدارة رابط الاستبيان:</strong>
        يمكنك الآن تغيير رابط الاستبيان المعروض على شاشة شكر الاختبار وصفحة تحليل الاستبيان، أو رفع صورة QR مخصّصة بديلاً عن التوليد التلقائي —
        <a asp-action="Link" class="alert-link">افتح الصفحة</a>.
    </div>

    <form method="post" asp-action="Create" class="card card-body my-3">
        @Html.AntiForgeryToken()
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">عنوان الاستبيان</label>
                <input name="titleAr" class="form-control" required />
            </div>
            <div class="col-md-5">
                <label class="form-label">وصف (اختياري)</label>
                <input name="descriptionAr" class="form-control" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" style="background:#28334A;border:none;">إنشاء</button>
            </div>
        </div>
    </form>

    <div class="table-responsive">
<table class="table table-hover align-middle">
        <thead><tr><th>العنوان</th><th>الحالة</th><th>الأسئلة</th><th>الردود</th><th>الرابط</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in surveys)
            {
                <tr>
                    <td>@s.TitleAr</td>
                    <td>@(s.IsActive ? Html.Raw("<span class='badge bg-success'>نشط</span>") : Html.Raw("<span class='badge bg-secondary'>متوقف</span>"))</td>
                    <td>@s.Questions</td>
                    <td>@s.Responses</td>
                    <td><code>/s/@s.PublicToken</code></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@s.Id">تحرير</a>
                        <a class="btn btn-sm btn-outline-info" asp-action="Qr" asp-route-id="@s.Id">QR</a>
                        <a class="btn btn-sm btn-outline-success" asp-action="Report" asp-route-id="@s.Id">التقرير</a>
                        <a class="btn btn-sm btn-outline-dark" asp-action="Analytics" asp-route-id="@s.Id">التحليلات</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>
