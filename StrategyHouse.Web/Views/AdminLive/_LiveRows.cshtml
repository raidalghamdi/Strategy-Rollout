@model List<StrategyHouse.Web.Controllers.LiveSessionRow>
@{
    var stageNames = new[] { "", "الصورة", "البيت", "المساهمة", "الخريطة", "الإتمام" };
    string StageName(int s) => s >= 1 && s < stageNames.Length ? stageNames[s] : "";
}
@if (!Model.Any())
{
    <p class="muted">لا توجد جلسات مطابقة.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle table-responsive-stack" style="background:#fff;">
            <thead>
                <tr>
                    <th>الإدارة</th>
                    <th>الرمز</th>
                    <th style="min-width:170px;">المرحلة</th>
                    <th>الأعضاء</th>
                    <th>الخريطة</th>
                    <th>الاختبار</th>
                    <th>الاستبيان</th>
                    <th>آخر نشاط</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    var pct = (int)Math.Round(Math.Clamp(r.CurrentStage, 1, 5) / 5.0 * 100);
                    <tr style="cursor:pointer;" onclick="location.href='/Admin/SessionDetail/@r.Id'">
                        <td data-label="الإدارة"><strong>@r.DeptName</strong></td>
                        <td data-label="الرمز"><span class="muted small">@r.AccessCode</span></td>
                        <td data-label="المرحلة">
                            <div class="d-flex align-items-center gap-2">
                                <div style="flex:1;background:#e7edf5;border-radius:6px;height:10px;overflow:hidden;min-width:80px;">
                                    <div style="width:@pct%;background:#299ECE;height:100%;"></div>
                                </div>
                                <span class="small">@Math.Clamp(r.CurrentStage, 1, 5)/5 — @StageName(Math.Clamp(r.CurrentStage, 1, 5))</span>
                            </div>
                        </td>
                        <td data-label="الأعضاء">@r.Members</td>
                        <td data-label="الخريطة">@(r.MapSigned ? Html.Raw("<span class='badge bg-success'>معتمدة</span>") : Html.Raw("<span class='badge bg-secondary'>—</span>"))</td>
                        <td data-label="الاختبار">@r.QuizAttempts</td>
                        <td data-label="الاستبيان">@r.SurveyResponses</td>
                        <td data-label="آخر نشاط"><span class="small">@((r.LastActivityAt ?? r.StartedAt).ToLocalTime().ToString("MM-dd HH:mm"))</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
