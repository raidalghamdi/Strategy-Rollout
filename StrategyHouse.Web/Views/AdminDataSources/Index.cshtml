@model StrategyHouse.Web.Models.DataSources.DataSourcesViewModel
@{
    ViewData["Title"] = "مصادر البيانات";

    string SrcLabel(string s) => s switch
    {
        "Mirror" => "نسخة MSSQL",
        "Sqlite" => "SQLite",
        "Live" => "MSSQL مباشر",
        "Empty" => "لا توجد بيانات",
        _ => s,
    };
    string SrcColor(string s) => s switch
    {
        "Mirror" => "#067647",
        "Sqlite" => "#00192B",
        "Live" => "#067647",
        _ => "#b42318",
    };
}

@section Styles {
    <style>
        .ds-card { background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(40,51,74,.08);padding:18px;margin-bottom:20px; }
        .sec-title { color:#00192B;font-weight:800;border-inline-start:5px solid #FAC126;padding-inline-start:12px;margin-bottom:14px; }
        .ds-table th { color:#00192B; }
        .ds-badge { display:inline-block;padding:2px 10px;border-radius:999px;color:#fff;font-weight:700;font-size:.8rem; }
    </style>
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 style="color:#00192B;">مصادر البيانات</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/Admin">رجوع</a>
    </div>

    @if (TempData["Saved"] != null) { <div class="alert" style="background:#067647;color:#fff;border:none;">@TempData["Saved"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="ds-card">
        <h4 class="sec-title">المصدر الحالي لكل كيان</h4>
        <p class="text-muted" style="font-size:.9rem;">
            ترتيب القراءة لكل كيان: نسخة MSSQL ← SQLite ← لا توجد بيانات. لا تُستخدم بيانات تجريبية إطلاقًا.
        </p>
        <div class="table-responsive">
            <table class="table ds-table align-middle">
                <thead>
                    <tr><th>الكيان</th><th>المصدر</th><th>عدد الصفوف</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>الركائز</strong></td>
                        <td><span class="ds-badge" style="background:@SrcColor(Model.Trace.Pillars)">@SrcLabel(Model.Trace.Pillars)</span></td>
                        <td>@Model.Counts.Pillars</td>
                    </tr>
                    <tr>
                        <td><strong>الأهداف</strong></td>
                        <td><span class="ds-badge" style="background:@SrcColor(Model.Trace.Objectives)">@SrcLabel(Model.Trace.Objectives)</span></td>
                        <td>@Model.Counts.Objectives</td>
                    </tr>
                    <tr>
                        <td><strong>المبادرات</strong></td>
                        <td><span class="ds-badge" style="background:@SrcColor(Model.Trace.Initiatives)">@SrcLabel(Model.Trace.Initiatives)</span></td>
                        <td>@Model.Counts.Initiatives</td>
                    </tr>
                    <tr>
                        <td><strong>المشاريع</strong></td>
                        <td><span class="ds-badge" style="background:@SrcColor(Model.Trace.Projects)">@SrcLabel(Model.Trace.Projects)</span></td>
                        <td>@Model.Counts.Projects</td>
                    </tr>
                    <tr>
                        <td><strong>مؤشرات الأداء</strong></td>
                        <td><span class="ds-badge" style="background:@SrcColor(Model.Trace.Kpis)">@SrcLabel(Model.Trace.Kpis)</span></td>
                        <td>@Model.Counts.Kpis</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

