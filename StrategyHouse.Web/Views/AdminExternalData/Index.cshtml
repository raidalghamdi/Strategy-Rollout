@model StrategyHouse.Web.Controllers.ExternalDataViewModel
@{
    ViewData["Title"] = "بيانات قاعدة البيانات الخارجية";
    string YesNo(bool v) => v ? "نعم" : "لا";
    var samples = new (string Title, string[] Headers, List<string[]> Rows)[]
    {
        ("الركائز Pillars", new[] { "PLR_Code", "PILLAR_Name", "PLR_Periods" }, Model.SamplePillars),
        ("الأهداف Objectives", new[] { "Objective_Code", "Objective_Name", "PLR_Code" }, Model.SampleObjectives),
        ("المؤشرات KPIs", new[] { "KPI_Code", "KPI_Name", "Division" }, Model.SampleKpis),
        ("المبادرات Initiatives", new[] { "Initiative_Code", "Initiative_Name", "Objective_Code" }, Model.SampleInitiatives),
        ("المشاريع Projects", new[] { "Project_Code", "Project_Name", "Division" }, Model.SampleProjects),
    };
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <h1 class="h3 mb-0">بيانات قاعدة البيانات الخارجية (Option A)</h1>
    <a href="/Admin/ExternalData" class="btn btn-outline-secondary">تحديث</a>
</div>

@if (User.IsInRole("Admin"))
{
    @Html.AntiForgeryToken()

    <div class="card border-0 shadow-sm mb-4" style="border-top:4px solid #00192B !important;">
        <div class="card-body">
            <h2 class="h5 mb-2">تفعيل قاعدة البيانات الخارجية | UseExternalDb</h2>
            <p class="text-muted small mb-3">
                يتحكم هذا المفتاح في استخدام قاعدة بيانات Microsoft SQL الخارجية كمصدر مباشر للبيانات.
                عند التفعيل يُستخدم الاتصال المباشر (ثم النسخة المحلية كاحتياطي)، وعند التعطيل يعمل الموقع
                على النسخة المحلية (SQLite) فقط. يُحفظ الإعداد فوراً دون الحاجة لإعادة تشغيل الخادم.
            </p>
            <div class="form-check form-switch" style="min-height:auto;">
                <input class="form-check-input" type="checkbox" role="switch" id="useExternalToggle"
                       style="width:3rem;height:1.5rem;cursor:pointer;"
                       @(Model.FlagEnabled ? "checked" : "") />
                <label class="form-check-label ms-2" for="useExternalToggle" id="useExternalLabel">
                    @(Model.FlagEnabled ? "مفعّل" : "معطّل")
                </label>
            </div>
            <div id="toggleAlert" class="mt-3 d-none" role="alert"></div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-top:4px solid #FAC126 !important;">
        <div class="card-body">
            <h2 class="h5 mb-2">مزامنة البيانات | Microsoft SQL → SQLite</h2>
            <p class="text-muted small mb-3">
                ينسخ هذا الإجراء جميع جداول الاستراتيجية (الركائز، الأهداف، المؤشرات، المبادرات، المشاريع)
                من Microsoft SQL إلى نسخة محلية في SQLite تُستخدم كاحتياطي عند تعذّر الاتصال المباشر.
            </p>
            <button id="pushBtn" type="button" class="btn btn-lg w-100 w-md-auto"
                    style="background-color:#FAC126;border-color:#FAC126;color:#00192B;font-weight:700;">
                <span id="pushSpinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
                <span id="pushLabel">دفع البيانات من Microsoft SQL إلى SQLite</span>
            </button>
            <div id="pushAlert" class="mt-3 d-none" role="alert"></div>

            <div class="mt-4">
                <h3 class="h6">حالة آخر دفع</h3>
                <table class="table table-sm" style="max-width:560px;">
                    <tbody>
                        <tr>
                            <th style="width:40%;">آخر دفع</th>
                            <td id="metaLastPush">
                                @(Model.Mirror?.LastPushAt is { } lp
                                    ? lp.AddHours(3).ToString("dd/MM/yyyy HH:mm") + " (توقيت الرياض)"
                                    : "لم يتم الدفع بعد")
                            </td>
                        </tr>
                        <tr>
                            <th>عدد السجلات</th>
                            <td id="metaCount">@(Model.Mirror?.RecordCount ?? 0)</td>
                        </tr>
                        <tr>
                            <th>الحالة</th>
                            <td id="metaStatus">
                                @{
                                    var st = Model.Mirror?.Status ?? "";
                                    var badge = st == "Success" ? "bg-success"
                                        : st == "Failed" ? "bg-danger"
                                        : st == "Aborted_Empty" ? "bg-warning text-dark"
                                        : st == "InProgress" ? "bg-warning text-dark"
                                        : "bg-secondary";
                                    var stText = st == "Success" ? "ناجح"
                                        : st == "Failed" ? "فشل"
                                        : st == "Aborted_Empty" ? "أُلغي — المصدر فارغ"
                                        : st == "InProgress" ? "قيد التنفيذ"
                                        : "—";
                                }
                                <span class="badge @badge">@stText</span>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Mirror?.ErrorMessage))
                        {
                            <tr>
                                <th>رسالة الخطأ</th>
                                <td id="metaError" class="text-danger small">@Model.Mirror!.ErrorMessage</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="my-4" />

            <h2 class="h5 mb-2">تشخيص الاتصال | Microsoft SQL</h2>
            <p class="text-muted small mb-3">
                يفحص هذا الإجراء الاتصال المباشر بقاعدة بيانات Microsoft SQL ويعرض سبب الفشل (إن وجد)
                مع شرح بالعربي. آمن للقراءة فقط — لا يعدّل أي بيانات.
            </p>

            @if (!Model.FlagEnabled)
            {
                <div class="alert alert-warning" role="alert">
                    العلم UseExternalDb معطل في الإعدادات. لتفعيل MSSQL، عدّل <code>appsettings.json</code> وأعد تشغيل التطبيق.
                </div>
            }

            <button id="testBtn" type="button" class="btn btn-lg btn-outline-primary w-100 w-md-auto"
                    style="border-color:#00192B;color:#00192B;font-weight:700;">
                <span id="testSpinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
                <span id="testLabel">اختبر الاتصال بـ Microsoft SQL</span>
            </button>

            <div id="testPanel" class="mt-3 d-none">
                <table class="table table-sm" style="max-width:720px;">
                    <tbody>
                        <tr>
                            <th style="width:38%;">حالة العلم UseExternalDb</th>
                            <td id="resFlag">—</td>
                        </tr>
                        <tr>
                            <th>سلسلة الاتصال (مخفية)</th>
                            <td><code id="resConn">—</code></td>
                        </tr>
                        <tr>
                            <th>إمكانية الاتصال</th>
                            <td id="resCanConnect">—</td>
                        </tr>
                        <tr>
                            <th>التصنيف</th>
                            <td><span id="resCategory" class="badge bg-secondary">—</span></td>
                        </tr>
                        <tr id="resErrorRow" class="d-none">
                            <th>رسالة الخطأ</th>
                            <td><pre id="resError" class="small mb-0" style="white-space:pre-wrap;word-break:break-word;"></pre></td>
                        </tr>
                        <tr>
                            <th>شرح بالعربي</th>
                            <td id="resHint">—</td>
                        </tr>
                        <tr>
                            <th>زمن الاستجابة</th>
                            <td id="resLatency">—</td>
                        </tr>
                        <tr id="resVersionRow" class="d-none">
                            <th>إصدار الخادم</th>
                            <td><code id="resVersion" class="small"></code></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <button type="button" class="btn btn-sm btn-link p-0" data-bs-toggle="collapse" data-bs-target="#connHelp"
                        aria-expanded="false" aria-controls="connHelp">
                    عرض صيغة سلسلة الاتصال المتوقعة ▾
                </button>
                <div class="collapse mt-2" id="connHelp">
                    <div class="card card-body bg-light">
                        <pre class="small mb-2" style="white-space:pre-wrap;word-break:break-word;">Server=hostname,1433;Database=DatabaseName;User Id=username;Password=password;TrustServerCertificate=True;Encrypt=False;Connection Timeout=10;</pre>
                        <ul class="small mb-0">
                            <li><strong>Server</strong>: اسم الخادم أو عنوان IP متبوعاً بالمنفذ (1433 افتراضياً) — مثال <code>db.example.com,1433</code></li>
                            <li><strong>Database</strong>: اسم قاعدة البيانات على الخادم</li>
                            <li><strong>User Id</strong> و<strong>Password</strong>: بيانات اعتماد مستخدم له صلاحية القراءة</li>
                            <li><strong>TrustServerCertificate=True</strong>: يتجاوز التحقق من شهادة SSL (مطلوب عادةً للخوادم بدون شهادة موثوقة)</li>
                            <li><strong>Encrypt=False</strong>: يعطّل التشفير عند عدم توفّر شهادة صالحة</li>
                            <li><strong>Connection Timeout=10</strong>: مهلة الاتصال بالثواني</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<table class="table" style="max-width:640px;">
    <tbody>
        <tr><th>العلم (UseExternalDb)</th><td>@YesNo(Model.FlagEnabled)</td></tr>
        <tr><th>سلسلة الاتصال مُعرَّفة</th><td>@YesNo(Model.ConnectionConfigured)</td></tr>
        <tr><th>السياق مُسجَّل (ExternalDbContext)</th><td>@YesNo(Model.ContextRegistered)</td></tr>
        <tr><th>الاتصال (ping)</th><td>@YesNo(Model.CanConnect)</td></tr>
        <tr><th>الإدارات (KPIs.Division المميزة)</th><td>@Model.DistinctDivisions</td></tr>
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="card card-body" style="margin-bottom:1rem;">@Model.StatusMessage</div>
}

@if (Model.CanConnect && Model.Counts.Count > 0)
{
    <h2>عدد السجلات</h2>
    <table class="table" style="max-width:480px;">
        <thead><tr><th>الجدول</th><th>العدد</th></tr></thead>
        <tbody>
            @foreach (var kv in Model.Counts)
            {
                <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
            }
        </tbody>
    </table>

    @foreach (var s in samples)
    {
        <h3 style="margin-top:1.5rem;">@s.Title (أول 5)</h3>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>@foreach (var h in s.Headers) { <th>@h</th> }</tr>
                </thead>
                <tbody>
                    @foreach (var r in s.Rows)
                    {
                        <tr>@foreach (var c in r) { <td>@c</td> }</tr>
                    }
                    @if (s.Rows.Count == 0)
                    {
                        <tr><td colspan="@s.Headers.Length">لا توجد بيانات</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (User.IsInRole("Admin"))
{
    @section Scripts {
        <script>
        // Phase 19.5 — push MSSQL → SQLite. iOS Safari-safe: ES5, IIFE, string
        // concat, var, no template literals, no block scope, try/catch fallback.
        (function () {
            function byId(id) { return document.getElementById(id); }

            function setBusy(busy) {
                var btn = byId('pushBtn');
                var sp = byId('pushSpinner');
                var lbl = byId('pushLabel');
                if (!btn) return;
                btn.disabled = busy;
                if (sp) { if (busy) { sp.classList.remove('d-none'); } else { sp.classList.add('d-none'); } }
                if (lbl) { lbl.textContent = busy ? 'جارٍ الدفع…' : 'دفع البيانات من Microsoft SQL إلى SQLite'; }
            }

            function showAlert(kind, html) {
                var box = byId('pushAlert');
                if (!box) return;
                box.className = 'mt-3 alert alert-' + kind;
                box.innerHTML = html;
            }

            function pad(n) { return (n < 10 ? '0' : '') + n; }

            function riyadhNow() {
                // Approximate Riyadh time (UTC+3) for the optimistic status update.
                var d = new Date(Date.now() + 3 * 3600 * 1000);
                return pad(d.getUTCDate()) + '/' + pad(d.getUTCMonth() + 1) + '/' + d.getUTCFullYear()
                    + ' ' + pad(d.getUTCHours()) + ':' + pad(d.getUTCMinutes()) + ' (توقيت الرياض)';
            }

            function updateStatus(success, count) {
                var lp = byId('metaLastPush'); if (lp) { lp.textContent = riyadhNow(); }
                var c = byId('metaCount'); if (c) { c.textContent = count; }
                var s = byId('metaStatus');
                if (s) {
                    s.innerHTML = success
                        ? '<span class="badge bg-success">ناجح</span>'
                        : '<span class="badge bg-danger">فشل</span>';
                }
            }

            function onClick() {
                if (!window.confirm('هل أنت متأكد؟ سيتم استبدال البيانات الحالية في SQLite بالكامل.')) return;
                var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                var token = tokenEl ? tokenEl.value : '';
                setBusy(true);
                showAlert('info', 'جارٍ دفع البيانات…');
                try {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Admin/ExternalData/PushToSqlite', true);
                    xhr.setRequestHeader('RequestVerificationToken', token);
                    xhr.setRequestHeader('Accept', 'application/json');
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        setBusy(false);
                        try {
                            var res = JSON.parse(xhr.responseText);
                            if (xhr.status >= 200 && xhr.status < 300 && res.success) {
                                showAlert('success', 'تم دفع ' + res.recordCount + ' سجلاً بنجاح خلال '
                                    + res.durationSeconds + ' ثانية.');
                                updateStatus(true, res.recordCount);
                            } else {
                                var err = (res && res.errorMessage) ? res.errorMessage : 'حدث خطأ غير متوقع.';
                                showAlert('danger', 'فشل الدفع: ' + err);
                                updateStatus(false, 0);
                            }
                        } catch (e) {
                            showAlert('danger', 'تعذّر قراءة استجابة الخادم.');
                        }
                    };
                    xhr.onerror = function () {
                        setBusy(false);
                        showAlert('danger', 'تعذّر الاتصال بالخادم.');
                    };
                    xhr.send();
                } catch (e) {
                    setBusy(false);
                    showAlert('danger', 'تعذّر بدء عملية الدفع.');
                }
            }

            function init() {
                var btn = byId('pushBtn');
                if (btn) { btn.addEventListener('click', onClick); }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();

        // Phase 19.7 — test the MSSQL connection. iOS Safari-safe: ES5, IIFE,
        // string concat, var, no template literals, no block scope, try/catch.
        (function () {
            function byId(id) { return document.getElementById(id); }

            function setBusy(busy) {
                var btn = byId('testBtn');
                var sp = byId('testSpinner');
                var lbl = byId('testLabel');
                if (!btn) return;
                btn.disabled = busy;
                if (sp) { if (busy) { sp.classList.remove('d-none'); } else { sp.classList.add('d-none'); } }
                if (lbl) { lbl.textContent = busy ? 'جارٍ الفحص…' : 'اختبر الاتصال بـ Microsoft SQL'; }
            }

            function categoryBadge(cat) {
                var map = {
                    network: 'bg-danger', auth: 'bg-danger', ssl: 'bg-warning text-dark',
                    database: 'bg-danger', timeout: 'bg-warning text-dark',
                    config: 'bg-secondary', unknown: 'bg-secondary'
                };
                return map[cat] || 'bg-secondary';
            }

            function render(res) {
                var panel = byId('testPanel');
                if (panel) { panel.classList.remove('d-none'); }

                var flag = byId('resFlag');
                if (flag) { flag.innerHTML = res.useExternalDb ? '✅ مفعل' : '⚠️ معطل'; }

                var conn = byId('resConn');
                if (conn) { conn.textContent = res.connectionStringMasked || '—'; }

                var cc = byId('resCanConnect');
                if (cc) { cc.innerHTML = res.canConnect ? '✅ ناجح' : '❌ فاشل'; }

                var cat = byId('resCategory');
                if (cat) {
                    cat.className = 'badge ' + categoryBadge(res.errorCategory);
                    cat.textContent = res.errorCategory || 'unknown';
                }

                var errRow = byId('resErrorRow');
                var err = byId('resError');
                if (res.errorMessage) {
                    if (err) { err.textContent = res.errorMessage; }
                    if (errRow) { errRow.classList.remove('d-none'); }
                } else {
                    if (errRow) { errRow.classList.add('d-none'); }
                }

                var hint = byId('resHint');
                if (hint) { hint.textContent = res.arabicHint || '—'; }

                var lat = byId('resLatency');
                if (lat) { lat.textContent = res.latencyMs + 'ms'; }

                var verRow = byId('resVersionRow');
                var ver = byId('resVersion');
                if (res.serverVersion) {
                    if (ver) { ver.textContent = res.serverVersion; }
                    if (verRow) { verRow.classList.remove('d-none'); }
                } else {
                    if (verRow) { verRow.classList.add('d-none'); }
                }
            }

            function renderError(msg) {
                var panel = byId('testPanel');
                if (panel) { panel.classList.remove('d-none'); }
                var hint = byId('resHint');
                if (hint) { hint.textContent = msg; }
                var cc = byId('resCanConnect');
                if (cc) { cc.innerHTML = '❌ فاشل'; }
            }

            function onClick() {
                setBusy(true);
                try {
                    var xhr = new XMLHttpRequest();
                    xhr.open('GET', '/Admin/ExternalData/TestConnection', true);
                    xhr.setRequestHeader('Accept', 'application/json');
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        setBusy(false);
                        try {
                            var res = JSON.parse(xhr.responseText);
                            render(res);
                        } catch (e) {
                            renderError('تعذّر قراءة استجابة الخادم. حاول مرة أخرى.');
                        }
                    };
                    xhr.onerror = function () {
                        setBusy(false);
                        renderError('تعذّر الاتصال بالخادم. حاول مرة أخرى.');
                    };
                    xhr.send();
                } catch (e) {
                    setBusy(false);
                    renderError('تعذّر بدء عملية الفحص.');
                }
            }

            function init() {
                var btn = byId('testBtn');
                if (btn) { btn.addEventListener('click', onClick); }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();

        // Phase 19.8 — toggle UseExternalDb at runtime. iOS Safari-safe: ES5, IIFE,
        // string concat, var, no template literals, no block scope, try/catch fallback.
        (function () {
            function byId(id) { return document.getElementById(id); }

            function showAlert(kind, text) {
                var box = byId('toggleAlert');
                if (!box) return;
                box.className = 'mt-3 alert alert-' + kind;
                box.textContent = text;
            }

            function setLabel(enabled) {
                var lbl = byId('useExternalLabel');
                if (lbl) { lbl.textContent = enabled ? 'مفعّل' : 'معطّل'; }
            }

            function onChange() {
                var cb = byId('useExternalToggle');
                if (!cb) return;
                var desired = cb.checked;
                var confirmMsg = desired
                    ? 'هل تريد تفعيل قاعدة البيانات الخارجية (UseExternalDb)؟ سيُستخدم الاتصال المباشر بـ Microsoft SQL.'
                    : 'هل تريد تعطيل قاعدة البيانات الخارجية؟ سيعمل الموقع على النسخة المحلية (SQLite) فقط.';
                if (!window.confirm(confirmMsg)) {
                    cb.checked = !desired; // revert the visual toggle
                    return;
                }

                var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                var token = tokenEl ? tokenEl.value : '';
                cb.disabled = true;
                showAlert('info', 'جارٍ حفظ الإعداد…');
                try {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Admin/ExternalData/SetUseExternalDb', true);
                    xhr.setRequestHeader('RequestVerificationToken', token);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                    xhr.setRequestHeader('Accept', 'application/json');
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        cb.disabled = false;
                        try {
                            var res = JSON.parse(xhr.responseText);
                            if (xhr.status >= 200 && xhr.status < 300 && res.success) {
                                cb.checked = res.enabled;
                                setLabel(res.enabled);
                                showAlert('success', res.message);
                            } else {
                                cb.checked = res && typeof res.enabled === 'boolean' ? res.enabled : !desired;
                                setLabel(cb.checked);
                                showAlert('danger', (res && res.message) ? res.message : 'تعذّر حفظ الإعداد.');
                            }
                        } catch (e) {
                            cb.checked = !desired;
                            setLabel(cb.checked);
                            showAlert('danger', 'تعذّر قراءة استجابة الخادم.');
                        }
                    };
                    xhr.onerror = function () {
                        cb.disabled = false;
                        cb.checked = !desired;
                        setLabel(cb.checked);
                        showAlert('danger', 'تعذّر الاتصال بالخادم.');
                    };
                    xhr.send('enabled=' + (desired ? 'true' : 'false'));
                } catch (e) {
                    cb.disabled = false;
                    cb.checked = !desired;
                    setLabel(cb.checked);
                    showAlert('danger', 'تعذّر بدء عملية الحفظ.');
                }
            }

            function init() {
                var cb = byId('useExternalToggle');
                if (cb) { cb.addEventListener('change', onChange); }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();
        </script>
    }
}
