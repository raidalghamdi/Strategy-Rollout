@inject Microsoft.AspNetCore.Identity.UserManager<StrategyHouse.Domain.Entities.AppUser> UserManagerForLayout
@{
    var title = (ViewData["Title"] as string) ?? "منصة استراتيجية الهيئة العامة للمنافسة";
    var authed = User.Identity?.IsAuthenticated == true;
    var cur = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string activeIf(params string[] cs) => cs.Any(c => string.Equals(cur, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    var name = User.Identity?.Name ?? "";
    string initials(string n)
    {
        if (string.IsNullOrWhiteSpace(n)) return "هم";
        var at = n.IndexOf('@');
        var core = at > 0 ? n[..at] : n;
        return core.Length >= 2 ? core[..2].ToUpperInvariant() : core.ToUpperInvariant();
    }
    // Phase 20.7 — journey-only accounts see a stripped-down sidebar that only links to
    // their landing dashboard. Platform admins (JourneyScopeKey == null) keep full nav.
    var isJourneyOnly = false;
    StrategyHouse.Domain.Entities.AppUser? _layoutUser = null;
    if (authed)
    {
        _layoutUser = await UserManagerForLayout.GetUserAsync(User);
        isJourneyOnly = _layoutUser != null && !string.IsNullOrEmpty(_layoutUser.JourneyScopeKey);
    }
    var _isVpSector = _layoutUser != null
        && !string.IsNullOrEmpty(_layoutUser.JourneyScopeKey)
        && _layoutUser.JourneyScopeKey.StartsWith("SECTOR:", StringComparison.Ordinal);
    // Phase 20.15 — JourneySuper / GLOBAL scope (e.g. gac.admin) should also
    // see the journey launcher, mirroring VP behavior across all sectors.
    var _isJourneySuper = _layoutUser != null
        && !string.IsNullOrEmpty(_layoutUser.JourneyScopeKey)
        && (_layoutUser.JourneyScopeKey.Equals("GLOBAL", StringComparison.OrdinalIgnoreCase)
            || _layoutUser.JourneyScopeKey.Equals("TEST", StringComparison.OrdinalIgnoreCase));
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title</title>
    <link href="/lib/bootstrap/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dga.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase15-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase19_5-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dga-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase20.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase20_8-responsive.css" asp-append-version="true" />
    @* Phase 20.12 — Tom Select for searchable dropdowns (self-hosted, offline). *@
    <link rel="stylesheet" href="~/lib/tomselect/tom-select.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase20_12-pplx-select.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (authed)
{
    <div class="app-shell">
        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>
        <aside class="app-sidebar" aria-label="Primary" id="appSidebar">
            <div class="brand">
                <img src="~/images/gac-logo-white.png" alt="الهيئة العامة للمنافسة" style="height:48px;width:auto;" />
                <div>
                    <div class="name">استراتيجية المنافسة</div>
                    <div class="tag">منصة الإطلاق</div>
                </div>
            </div>
            <nav>
                @if (isJourneyOnly)
                {
                    <div class="group-title">الرحلة التنفيذية</div>
                    <a class="@activeIf("AdminLive")" href="/Admin/LiveDashboard">اللوحة الحية</a>
                    @* Phase 20.9 — VPs (any user whose JourneyScopeKey starts with
                       SECTOR:) get a one-click launcher for the unified sector
                       journey that aggregates all of their sector's departments. *@
                    @if (_isVpSector)
                    {
                        <a class="@activeIf("Journey")" href="/Journey/Sector">رحلة القطاع</a>
                    }
                    @* Phase 20.17 — JourneySuper / GLOBAL accounts (gac.admin)
                       launch the unified agency-wide journey. *@
                    else if (_isJourneySuper)
                    {
                        <a class="@activeIf("Journey")" href="/Journey/Sector">رحلة الهيئة الشاملة</a>
                    }
                }
                else
                {
                    @* Phase 20.33 (Comment 8) — CX role has limited nav *@
                    var _isCX = User.IsInRole("CX");

                    @if (!_isCX)
                    {
                        <a class="@activeIf("Home")" href="/">الرئيسية</a>

                        <div class="group-title">المراقبة</div>
                        <a class="@activeIf("Admin")" href="/Admin/LiveDashboard">اللوحة الحية</a>
                        <a class="@activeIf("Admin")" href="/Admin">لوحة المعلومات</a>

                        <div class="group-title">الرحلة الاستراتيجية</div>
                        <a class="@activeIf("Journey")" href="/Journey">الرحلة</a>

                        <div class="group-title">الاختبار</div>
                        <a class="@activeIf("AdminQuiz")" href="/Admin/Quiz">إدارة الاختبار</a>
                    }

                    <div class="group-title">الاستبيان</div>
                    <a class="@activeIf("AdminSurveys")" href="/Admin/Surveys">رفع نتائج الاستبيان</a>
                    <a class="@activeIf("AdminSurvey")" href="/Admin/Survey/Analytics">تحليلات الاستبيان الرسمي</a>
                    <a class="@activeIf("AdminSurvey")" href="/Admin/Survey/FinalReport">التقرير النهائي للاستبيان</a>

                    <div class="group-title">التقارير</div>
                    <a class="@activeIf("AdminExecutiveReport")" href="/Admin/ExecutiveReport">التقرير التنفيذي</a>

                    @if (!_isCX)
                    {
                        <div class="group-title">الإعدادات</div>
                        <a class="@activeIf("AdminCodes")" href="/Admin/Codes">رموز الدخول</a>
                        <a class="@activeIf("Admin")" href="/Admin/Content">تحرير النصوص</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="group-title">الإدارة المتقدمة</div>
                            <a class="@activeIf("AdminUsers")" href="/Admin/Users">إدارة المستخدمين</a>
                            <a class="@activeIf("AdminJourneyReset")" href="/Admin/JourneyReset">إعادة تشغيل رحلة إدارة</a>
                            <a class="@activeIf("AdminTestResults")" href="/Admin/TestResults">حذف نتائج الاختبار</a>
                            <a class="@activeIf("AdminAuditLog")" href="/Admin/AuditLog">سجل التدقيق</a>
                        }
                    }
                }
            </nav>
        </aside>

        <div class="app-main">
            <header class="app-header">
                <div style="display:flex; align-items:center; gap:12px;">
                    <button class="sidebar-toggle" data-sidebar-toggle aria-label="القائمة">☰</button>
                    <strong style="color:var(--color-gray-800);">@title</strong>
                </div>
                <div class="actions">
                    <a class="user-badge" href="/Account/Profile" title="@name" style="text-decoration:none;color:inherit;">
                        <span class="avatar">@initials(name)</span>
                        <span class="user-meta">
                            <span class="user-name">@name</span>
                            <span class="user-role">الملف الشخصي</span>
                        </span>
                    </a>
                    <form method="post" action="/Account/Logout" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-ghost btn-sm" type="submit">خروج</button>
                    </form>
                </div>
            </header>

            <main class="app-content">
                @RenderBody()
            </main>

            <footer class="app-footer">© @DateTime.Now.Year — @Html.Content("footer.copyright", "الهيئة العامة للمنافسة · منصة إطلاق استراتيجية الهيئة")</footer>
        </div>
    </div>
    <script>
        (function () {
            var t = document.querySelector('[data-sidebar-toggle]');
            var sb = document.getElementById('appSidebar');
            var bd = document.getElementById('sidebarBackdrop');
            var DRAWER = '(max-width: 1024px)';
            function isDrawer() { return window.matchMedia(DRAWER).matches; }
            function setOpen(open) {
                if (!sb) return;
                sb.classList.toggle('open', open);
                if (bd) bd.classList.toggle('open', open);
            }
            function toggle() {
                if (isDrawer()) {
                    setOpen(!sb.classList.contains('open'));
                } else {
                    // Desktop: collapse the rail to give content more room.
                    document.body.classList.toggle('sidebar-collapsed');
                }
            }
            if (t) t.addEventListener('click', toggle);
            if (bd) bd.addEventListener('click', function () { setOpen(false); });
            // close drawer when a nav link is tapped on mobile/tablet
            if (sb) sb.querySelectorAll('nav a').forEach(function (a) {
                a.addEventListener('click', function () { if (isDrawer()) setOpen(false); });
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') setOpen(false); });
        })();
    </script>
}
else
{
    <header class="cx-public-header">
        <a href="/" class="cx-public-brand" style="text-decoration:none;">
            <img src="~/images/gac-logo-white.png" alt="الهيئة العامة للمنافسة" class="brand-logo" />
            <span>
                <span class="cx-name d-block">منصة استراتيجية الهيئة العامة للمنافسة</span>
                <span class="cx-tag">رحلة إطلاق الاستراتيجية المؤسسية</span>
            </span>
        </a>
        <nav class="cx-public-actions">
            <a href="/">الرئيسية</a>
            <a href="/Journey">الرحلة</a>
            <a href="/Account/Login" class="btn btn-secondary btn-sm">دخول</a>
        </nav>
    </header>
    <main class="cx-public-main">
        @RenderBody()
    </main>
    <footer class="cx-public-footer">
        © @DateTime.Now.Year — @Html.Content("footer.copyright", "الهيئة العامة للمنافسة · منصة إطلاق استراتيجية الهيئة")
    </footer>
}

@if (User?.Identity?.IsAuthenticated == true)
{
    @await Html.PartialAsync("_Chatbot")
}

<script src="/lib/bootstrap/bootstrap.bundle.min.js"></script>
@* Phase 20.12 — Tom Select + enhancer. Any <select> with data-pplx-search="1"
   (or more than 10 options) becomes a searchable, RTL-aware combobox. *@
<script src="~/lib/tomselect/tom-select.complete.min.js" asp-append-version="true"></script>
<script src="~/js/pplx-select.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
