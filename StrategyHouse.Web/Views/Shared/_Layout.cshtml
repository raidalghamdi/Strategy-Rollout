@{
    var title = (ViewData["Title"] as string) ?? "منصة استراتيجية الهيئة العامة للمنافسة";
    var authed = User.Identity?.IsAuthenticated == true;
    var cur = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string activeIf(params string[] cs) => cs.Any(c => string.Equals(cur, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    var name = User.Identity?.Name ?? "";
    string initials(string n)
    {
        if (string.IsNullOrWhiteSpace(n)) return "GA";
        var at = n.IndexOf('@');
        var core = at > 0 ? n[..at] : n;
        return core.Length >= 2 ? core[..2].ToUpperInvariant() : core.ToUpperInvariant();
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Exo+2:wght@400;600;700&family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dga.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (authed)
{
    <div class="app-shell">
        <aside class="app-sidebar" aria-label="Primary" id="appSidebar">
            <div class="brand">
                <img src="~/images/gac-logo-white.png" alt="الهيئة العامة للمنافسة" style="height:48px;width:auto;" />
                <div>
                    <div class="name">استراتيجية المنافسة</div>
                    <div class="tag">منصة الإطلاق</div>
                </div>
            </div>
            <nav>
                <a class="@activeIf("Home")" href="/">الرئيسية</a>
                <a class="@activeIf("Journey")" href="/Journey">الرحلة</a>

                <div class="group-title">الإدارة</div>
                <a class="@activeIf("Admin")" href="/Admin">لوحة المعلومات</a>
                <a class="@activeIf("AdminInsights")" href="/AdminInsights">المساهمات</a>
                <a class="@activeIf("AdminModeration")" href="/AdminModeration">الخريطة والاعتماد</a>
                <a class="@activeIf("Admin", "Roster")" href="/Admin/Roster">منسوبو الإدارات</a>
                <a class="@activeIf("AdminQuiz")" href="/AdminQuiz">الاختبار</a>
                <a class="@activeIf("AdminSurveys")" href="/AdminSurveys">الاستبيان</a>
                <a class="@activeIf("AdminCodes")" href="/AdminCodes">رموز الدخول</a>
                <a class="@activeIf("AdminWall")" href="/AdminWall">جدار المشاركات</a>
            </nav>
        </aside>

        <div class="app-main">
            <header class="app-header">
                <div style="display:flex; align-items:center; gap:12px;">
                    <button class="sidebar-toggle" data-sidebar-toggle aria-label="القائمة">☰</button>
                    <strong style="color:var(--color-gray-800);">@title</strong>
                </div>
                <div class="actions">
                    <div class="user-badge" title="@name">
                        <span class="avatar">@initials(name)</span>
                        <span class="user-meta">
                            <span class="user-name">@name</span>
                            <span class="user-role">مسؤول</span>
                        </span>
                    </div>
                    <form method="post" action="/Account/Logout" style="margin:0;">
                        <button class="btn btn-ghost btn-sm" type="submit">خروج</button>
                    </form>
                </div>
            </header>

            <main class="app-content">
                @RenderBody()
            </main>

            <footer class="app-footer">© @DateTime.Now.Year — الهيئة العامة للمنافسة · منصة إطلاق الاستراتيجية</footer>
        </div>
    </div>
    <script>
        (function () {
            var t = document.querySelector('[data-sidebar-toggle]');
            var sb = document.getElementById('appSidebar');
            if (t && sb) t.addEventListener('click', function () { sb.classList.toggle('open'); });
        })();
    </script>
}
else
{
    <header class="cx-public-header">
        <a href="/" class="cx-public-brand" style="text-decoration:none;">
            <img src="~/images/gac-logo-white.png" alt="الهيئة العامة للمنافسة" class="brand-logo" />
            <span>
                <span class="cx-name d-block">منصة استراتيجية الهيئة العامة للمنافسة</span>
                <span class="cx-tag">رحلة إطلاق الاستراتيجية المؤسسية</span>
            </span>
        </a>
        <nav class="cx-public-actions">
            <a href="/">الرئيسية</a>
            <a href="/Journey">الرحلة</a>
            <a href="/Account/Login" class="btn btn-secondary btn-sm">دخول</a>
        </nav>
    </header>
    <main class="cx-public-main">
        @RenderBody()
    </main>
    <footer class="cx-public-footer">
        © @DateTime.Now.Year — الهيئة العامة للمنافسة · منصة إطلاق الاستراتيجية
    </footer>
}

@if (User?.Identity?.IsAuthenticated == true)
{
    @await Html.PartialAsync("_Chatbot")
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
