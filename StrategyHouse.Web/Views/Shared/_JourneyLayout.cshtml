@{
    var title = (ViewData["Title"] as string) ?? "رحلة الاستراتيجية الإدارية";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title — الهيئة العامة للمنافسة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=Cairo:wght@400;600;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --gac-primary: #194F90;
            --gac-cyan: #46BCCD;
            --gac-green: #009845;
            --gac-gold: #D79A2B;
            --gac-lime: #9DC41A;
            --gac-bg: #FAFBFC;
        }
        body { font-family: 'Tajawal','Cairo',sans-serif; background: var(--gac-bg); color: #1d2733; }
        .gac-topbar { background: var(--gac-primary); color: #fff; padding: 12px 20px; display:flex; align-items:center; gap:14px; }
        .gac-topbar .mark { font-weight: 900; font-size: 1.4rem; letter-spacing: 1px; }
        .gac-btn-primary { background: var(--gac-primary); border-color: var(--gac-primary); }
        .gac-btn-primary:hover { background:#143f73; border-color:#143f73; }
        .gac-step { display:flex; gap:6px; margin: 18px 0; flex-wrap:wrap; }
        .gac-step .pip { flex:1; min-width:80px; text-align:center; padding:6px 4px; border-radius:8px; background:#e7edf5; font-size:.8rem; color:#5a6b80; }
        .gac-step .pip.active { background: var(--gac-cyan); color:#04303a; font-weight:700; }
        .gac-step .pip.done { background: var(--gac-green); color:#fff; }
        .gac-card { background:#fff; border-radius:14px; box-shadow: 0 4px 20px rgba(25,79,144,.07); padding:24px; }
        h1,h2,h3 { color: var(--gac-primary); }
        .gac-vision { background: var(--gac-primary); color:#fff; border-radius:14px; padding:18px 22px; }
        .gac-vision .label { color: var(--gac-cyan); font-weight:700; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="gac-topbar">
        <span class="mark">GAC</span>
        <span>رحلة الاستراتيجية الإدارية — الهيئة العامة للمنافسة</span>
    </div>
    <main class="container py-4">
        @RenderBody()
    </main>
    <footer class="text-center text-muted py-4" style="font-size:.85rem;">
        © @DateTime.Now.Year — الهيئة العامة للمنافسة · منصة إطلاق الاستراتيجية
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/konva@9.3.6/konva.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
