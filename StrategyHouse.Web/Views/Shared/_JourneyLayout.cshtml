@{
    var title = (ViewData["Title"] as string) ?? "رحلة استراتيجية الهيئة";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title — الهيئة العامة للمنافسة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dga.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase15-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase19_5-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dga-theme.css" asp-append-version="true" />
    @* Phase 20.13 — self-host Tom Select on journey pages too so searchable
       dropdowns (data-pplx-search="1") work on every journey type, not only
       on platform pages that use _Layout. *@
    <link rel="stylesheet" href="~/lib/tomselect/tom-select.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phase20_12-pplx-select.css" asp-append-version="true" />
    <style>
        /* Journey palette mapped to GAC brand tokens (Phase 7) */
        :root {
            --gac-primary: var(--gac-navy);
            --gac-cyan: var(--gac-blue-accent);
            --gac-green: var(--gac-service-green);
            --gac-lime: #5F9600;
            --gac-bg: var(--bg-page);
        }
        body { font-family: var(--font-ar); background: var(--gac-bg); color: var(--color-gray-900); }
        .gac-topbar { background: var(--gac-navy-dark); color: #fff; padding: 12px 20px; display:flex; align-items:center; gap:14px; box-shadow: var(--shadow-sm); border-bottom: 4px solid var(--gac-gold); }
        .gac-topbar .brand-logo { height: 48px; width: auto; display:block; }
        .gac-topbar .topbar-title { font-size: clamp(0.9rem, 3vw, 1.1rem); }
        @@media (max-width: 575.98px) {
            .gac-topbar { padding: 8px 12px; gap: 8px; }
            .gac-topbar .brand-logo { height: 32px; }
        }
        /* Phase 16 — align journey primary buttons (incl. Next) with the DGA green
           theme: green background, white text. Previously this inline rule shadowed
           dga-theme.css and forced gold/black, leaving "التالي" with dark text. */
        .gac-btn-primary { background: var(--dga-primary, #067647); border-color: var(--dga-primary, #067647); color: #FFFFFF !important; border-radius: var(--radius-pill); font-weight:700; }
        .gac-btn-primary:hover { background: var(--dga-primary-hover, #085D3A); border-color: var(--dga-primary-hover, #085D3A); color: #FFFFFF !important; }
        .gac-card { background:#fff; border:1px solid var(--border-soft); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); padding:24px; }
        .gac-card + .gac-card { margin-top: 16px; }
        h1,h2,h3 { color: var(--gac-navy); }
        .gac-vision { background: var(--gac-navy); color:#fff; border-radius: var(--radius-card); padding:18px 22px; }
        .gac-vision .label { color: var(--gac-gold); font-weight:700; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="gac-topbar">
        <img src="~/images/gac-logo-white.png" alt="الهيئة العامة للمنافسة" class="brand-logo" />
        <span class="topbar-title">رحلة استراتيجية الهيئة — الهيئة العامة للمنافسة</span>
    </div>
    <main class="container py-4">
        @RenderBody()
    </main>
    <footer class="text-center text-muted py-4" style="font-size:.85rem;">
        © @DateTime.Now.Year — الهيئة العامة للمنافسة · منصة إطلاق استراتيجية الهيئة
    </footer>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        @await Html.PartialAsync("_Chatbot")
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/konva@9.3.6/konva.min.js"></script>
    @* Phase 20.13 — wire Tom Select into journey layout as well, so dropdowns
       on stages 4/5 become searchable for every journey type. *@
    <script src="~/lib/tomselect/tom-select.complete.min.js" asp-append-version="true"></script>
    <script src="~/js/pplx-select.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
