@{
    var title = (ViewData["Title"] as string) ?? "رحلة الاستراتيجية الإدارية";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title — الهيئة العامة للمنافسة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=Cairo:wght@400;600;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dga.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/compat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <style>
        :root {
            --gac-primary: #194F90;
            --gac-cyan: #46BCCD;
            --gac-green: #009845;
            --gac-gold: #D79A2B;
            --gac-lime: #9DC41A;
            --gac-bg: #F5F5F6;
        }
        body { font-family: 'Cairo','Tajawal',sans-serif; background: var(--gac-bg); color: var(--color-gray-900); }
        .gac-topbar { background: var(--gac-primary); color: #fff; padding: 14px 20px; display:flex; align-items:center; gap:14px; box-shadow: var(--shadow-sm); }
        .gac-topbar .mark { font-weight: 900; font-size: 1.3rem; letter-spacing: 1px; background:#fff; color:var(--gac-primary); border-radius:8px; padding:4px 10px; }
        .gac-btn-primary { background: var(--gac-primary); border-color: var(--gac-primary); color:#fff; }
        .gac-btn-primary:hover { background:#103768; border-color:#103768; color:#fff; }
        .gac-card { background:#fff; border:1px solid var(--color-gray-200); border-radius:16px; box-shadow: var(--shadow-sm); padding:24px; }
        .gac-card + .gac-card { margin-top: 16px; }
        h1,h2,h3 { color: var(--gac-primary); }
        .gac-vision { background: var(--gac-primary); color:#fff; border-radius:16px; padding:18px 22px; }
        .gac-vision .label { color: var(--gac-cyan); font-weight:700; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="gac-topbar">
        <span class="mark">GAC</span>
        <span>رحلة الاستراتيجية الإدارية — الهيئة العامة للمنافسة</span>
    </div>
    <main class="container py-4">
        @RenderBody()
    </main>
    <footer class="text-center text-muted py-4" style="font-size:.85rem;">
        © @DateTime.Now.Year — الهيئة العامة للمنافسة · منصة إطلاق الاستراتيجية
    </footer>

    @await Html.PartialAsync("_Chatbot")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/konva@9.3.6/konva.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
