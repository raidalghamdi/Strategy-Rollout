@model List<BookingSlot>
@{
    ViewData["Title"] = "حجز موعد للجلسة";
    var departments = ViewBag.Departments as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<section class="hero">
    <h1>حجز موعد جلسة إطلاق الاستراتيجية</h1>
    <p class="muted">اختر إدارتك ثم اختر الموعد المناسب. تُحدَّث المواعيد لحظياً، وعند اكتمال الموعد لن يكون متاحاً لإدارات أخرى.</p>
</section>

@if (TempData["BookingSuccess"] != null)
{
    <div class="card card--accent" style="border-right-color: var(--accent-green); background:#eafaf1;">
        <strong>تم الحجز بنجاح:</strong> @TempData["BookingSuccess"]
    </div>
}
@if (TempData["BookingError"] != null)
{
    <div class="card card--accent" style="border-right-color: #c0392b; background:#fdecea;">
        <strong>تعذر إتمام الحجز:</strong> @TempData["BookingError"]
    </div>
}

<div class="card" style="margin-bottom:1.5rem;">
    <label for="departmentSelect" style="display:block; font-weight:700; margin-bottom:.5rem;">اختر الإدارة:</label>
    <select id="departmentSelect" class="form-control" style="width:100%; max-width:520px; padding:.6rem; border:1px solid #d0d8de; border-radius:6px; font-family:inherit; font-size:1rem;">
        <option value="">— اختر إدارتك من القائمة —</option>
        @foreach (var d in departments)
        {
            <option value="@d.Id">@d.NameAr</option>
        }
    </select>
    <p class="muted" style="margin-top:.5rem;">سعة كل موعد: إدارتان كحد أقصى.</p>
</div>

<h2 style="margin-top:1rem;">المواعيد المتاحة</h2>

<div id="slotsGrid" class="grid-2">
    @foreach (var s in Model)
    {
        var booked = s.Bookings.Count;
        var isFull = booked >= s.Capacity;
        <div class="card card--accent slot-card" data-slot-id="@s.Id" data-is-full="@(isFull ? "true" : "false")">
            <h3 style="margin-bottom:.3rem;">@(s.TitleAr ?? "جلسة إطلاق")</h3>
            <p class="muted" style="margin:.2rem 0;">
                <strong>التاريخ:</strong> @s.SlotDate.ToString("yyyy-MM-dd")
                · <strong>الوقت:</strong> @s.StartTime.ToString(@"hh\:mm")
                · <strong>المدة:</strong> @s.DurationMinutes د
            </p>
            @if (!string.IsNullOrWhiteSpace(s.VenueAr))
            {
                <p class="muted" style="margin:.2rem 0;"><strong>المكان:</strong> @s.VenueAr</p>
            }
            @if (!string.IsNullOrWhiteSpace(s.FacilitatorAr))
            {
                <p class="muted" style="margin:.2rem 0;"><strong>الميسّر:</strong> @s.FacilitatorAr</p>
            }
            @if (!string.IsNullOrWhiteSpace(s.NotesAr))
            {
                <p class="muted" style="margin:.2rem 0;">@s.NotesAr</p>
            }

            <div style="margin:.6rem 0;">
                <span class="chip" style="@(isFull ? "background:#fdecea; color:#c0392b;" : "background:#eafaf1; color:#1e7e3e;")">
                    @booked / @s.Capacity محجوز
                </span>
                @if (isFull)
                {
                    <span class="chip" style="background:#fdecea; color:#c0392b;">مكتمل</span>
                }
            </div>

            @if (s.Bookings.Any())
            {
                <p class="muted" style="margin:.4rem 0;">
                    <strong>محجوز لـ:</strong>
                    @string.Join("، ", s.Bookings.Select(b => b.Department?.NameAr ?? "—"))
                </p>
            }

            <form method="post" action="/Booking/Book" class="book-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="slotId" value="@s.Id" />
                <input type="hidden" name="departmentId" class="dept-input" value="" />
                <div class="grid-2" style="gap:.5rem; margin-bottom:.5rem;">
                    <input type="text" name="bookedByName" placeholder="اسم الحاجز (اختياري)" style="padding:.5rem; border:1px solid #d0d8de; border-radius:6px; font-family:inherit;" />
                    <input type="text" name="bookedByContact" placeholder="رقم التواصل أو البريد (اختياري)" style="padding:.5rem; border:1px solid #d0d8de; border-radius:6px; font-family:inherit;" />
                </div>
                <button type="submit" class="btn btn--primary book-btn" @(isFull ? "disabled" : "") style="width:100%;">
                    @(isFull ? "الموعد مكتمل" : "احجز هذا الموعد")
                </button>
            </form>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="card">
        <p class="muted">لا توجد مواعيد متاحة حالياً. يُرجى المراجعة لاحقاً.</p>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function() {
            const deptSelect = document.getElementById('departmentSelect');
            const grid = document.getElementById('slotsGrid');

            function syncDept() {
                const v = deptSelect.value || "";
                document.querySelectorAll('.dept-input').forEach(i => i.value = v);
                document.querySelectorAll('.book-btn').forEach(btn => {
                    const card = btn.closest('.slot-card');
                    const isFull = card && card.dataset.isFull === 'true';
                    if (isFull) { btn.disabled = true; btn.textContent = 'الموعد مكتمل'; return; }
                    if (!v) { btn.disabled = true; btn.textContent = 'اختر الإدارة أولاً'; }
                    else { btn.disabled = false; btn.textContent = 'احجز هذا الموعد'; }
                });
            }
            deptSelect.addEventListener('change', syncDept);
            syncDept();

            // Prevent submit if dept not chosen
            document.querySelectorAll('.book-form').forEach(f => {
                f.addEventListener('submit', e => {
                    if (!deptSelect.value) {
                        e.preventDefault();
                        alert('يرجى اختيار الإدارة من القائمة أولاً.');
                    }
                });
            });

            // SignalR live updates
            try {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/booking')
                    .withAutomaticReconnect()
                    .build();

                connection.on('SlotsChanged', refresh);
                connection.start().catch(err => console.warn('SignalR start failed', err));

                async function refresh() {
                    try {
                        const res = await fetch('/Booking/Status');
                        if (!res.ok) return;
                        const slots = await res.json();
                        renderSlots(slots);
                        syncDept();
                    } catch (e) { console.warn(e); }
                }

                function renderSlots(slots) {
                    if (!slots || slots.length === 0) {
                        grid.innerHTML = '<div class="card"><p class="muted">لا توجد مواعيد متاحة حالياً.</p></div>';
                        return;
                    }
                    grid.innerHTML = slots.map(s => `
                        <div class="card card--accent slot-card" data-slot-id="${s.id}" data-is-full="${s.isFull}">
                            <h3 style="margin-bottom:.3rem;">${escapeHtml(s.titleAr || 'جلسة إطلاق')}</h3>
                            <p class="muted" style="margin:.2rem 0;">
                                <strong>التاريخ:</strong> ${s.slotDate}
                                · <strong>الوقت:</strong> ${s.startTime}
                                · <strong>المدة:</strong> ${s.durationMinutes} د
                            </p>
                            ${s.venueAr ? `<p class="muted" style="margin:.2rem 0;"><strong>المكان:</strong> ${escapeHtml(s.venueAr)}</p>` : ''}
                            ${s.facilitatorAr ? `<p class="muted" style="margin:.2rem 0;"><strong>الميسّر:</strong> ${escapeHtml(s.facilitatorAr)}</p>` : ''}
                            <div style="margin:.6rem 0;">
                                <span class="chip" style="${s.isFull ? 'background:#fdecea; color:#c0392b;' : 'background:#eafaf1; color:#1e7e3e;'}">
                                    ${s.bookedCount} / ${s.capacity} محجوز
                                </span>
                                ${s.isFull ? '<span class="chip" style="background:#fdecea; color:#c0392b;">مكتمل</span>' : ''}
                            </div>
                            ${s.bookedDepartments && s.bookedDepartments.length > 0 ?
                                `<p class="muted" style="margin:.4rem 0;"><strong>محجوز لـ:</strong> ${s.bookedDepartments.map(escapeHtml).join('، ')}</p>` : ''}
                            <form method="post" action="/Booking/Book" class="book-form">
                                <input name="__RequestVerificationToken" type="hidden" value="${getToken()}" />
                                <input type="hidden" name="slotId" value="${s.id}" />
                                <input type="hidden" name="departmentId" class="dept-input" value="" />
                                <div class="grid-2" style="gap:.5rem; margin-bottom:.5rem;">
                                    <input type="text" name="bookedByName" placeholder="اسم الحاجز (اختياري)" style="padding:.5rem; border:1px solid #d0d8de; border-radius:6px; font-family:inherit;" />
                                    <input type="text" name="bookedByContact" placeholder="رقم التواصل أو البريد (اختياري)" style="padding:.5rem; border:1px solid #d0d8de; border-radius:6px; font-family:inherit;" />
                                </div>
                                <button type="submit" class="btn btn--primary book-btn" ${s.isFull ? 'disabled' : ''} style="width:100%;">
                                    ${s.isFull ? 'الموعد مكتمل' : 'احجز هذا الموعد'}
                                </button>
                            </form>
                        </div>
                    `).join('');
                    // re-attach submit guards
                    document.querySelectorAll('.book-form').forEach(f => {
                        f.addEventListener('submit', e => {
                            if (!deptSelect.value) { e.preventDefault(); alert('يرجى اختيار الإدارة من القائمة أولاً.'); }
                        });
                    });
                }

                function getToken() {
                    const t = document.querySelector('input[name="__RequestVerificationToken"]');
                    return t ? t.value : '';
                }
                function escapeHtml(s) {
                    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
                }
            } catch (e) { console.warn('SignalR unavailable', e); }
        })();
    </script>
}
