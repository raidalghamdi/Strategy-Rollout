@using StrategyHouse.Web.Controllers
@{
    ViewData["Title"] = "الرئيسية — منصة إطلاق الاستراتيجية";
    var stats = (HomeStats)ViewBag.Stats;
}

<div class="hero">
    <h1>@Html.Content("home.hero.title", "منصة إطلاق استراتيجية الهيئة العامة للمنافسة")</h1>
    <p>@Html.Content("home.hero.subtitle", "منصة رقمية تفاعلية لإطلاق الاستراتيجية على مستوى الإدارات الثمانية عشر — تُعرّف الموظفين بالرؤية والرسالة والقيم، تبني الخريطة الاستراتيجية لكل إدارة معاً، وتُسجّل الالتزامات الجماعية بتوقيع تطوعي على الجدار الرقمي للالتزامات.")</p>
    <div class="row mt-2 btn-stack-mobile">
        <a href="/Journey" class="btn btn--primary">@Html.Content("home.hero.cta", "ابدأ رحلة إدارتك")</a>
    </div>
</div>

<div class="card">
    <h2>@Html.Content("home.about.title", "عن المنصة")</h2>
    <p>@Html.Content("home.about.body", "منصة رقمية تفاعلية لإطلاق الاستراتيجية المؤسسية على مستوى الإدارات الثماني عشرة.")</p>
</div>

<div class="stats">
    <div class="stat">
        <div class="stat__num">@stats.Pillars</div>
        <div class="stat__label">ركيزة</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Objectives</div>
        <div class="stat__label">هدف</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Initiatives</div>
        <div class="stat__label">مبادرة</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Projects</div>
        <div class="stat__label">مشروع</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Kpis</div>
        <div class="stat__label">مؤشر أداء</div>
    </div>
</div>

<div class="grid-2">
    <div class="card card--accent">
        <h2>كيف تعمل الجلسة (٩٠ دقيقة)</h2>
        <ol>
            <li><strong>الحركة الأولى (٢٠ دقيقة) — التعريف:</strong> قياس مرجعي مجهول، ثم عرض بيت الاستراتيجية (الرؤية، الرسالة، القيم، الركائز، الأهداف).</li>
            <li><strong>الحركة الثانية (٤٠ دقيقة) — البناء الجماعي:</strong> كل إدارة تبني خريطتها الاستراتيجية على لوحة تفاعلية بالربط بين عناصرها (مشاريع، مؤشرات، أدوار) وبين الأهداف والركائز.</li>
            <li><strong>الحركة الثالثة (٣٠ دقيقة) — الالتزام:</strong> اختيار الالتزامات الجماعية، ربطها بعناصر الإطار، وتوقيع تطوعي على iPad.</li>
            <li><strong>إغلاق:</strong> استبيان قصير ثم رسالة شكر بريدية في اليوم نفسه مع رابط الاختبار الاختياري.</li>
        </ol>
    </div>

    <div class="card card--accent">
        <h2>المبادئ التشغيلية</h2>
        <ul>
            <li>الإدارات مكتملة، بدون تجميع مختلط بين إدارات.</li>
            <li>أيام التشغيل ٢ إلى ٥ فقط (لا أول ولا آخر يوم).</li>
            <li>مكتب الاستراتيجية فقط هو المُيسّر؛ رئيس الإدارة راعٍ نشط بدور محدد سلفاً عبر <strong>خريطة رحلة رئيس الإدارة</strong>.</li>
            <li>التوقيع تطوعي، يُضاف على خريطة الإدارة في منطقة A3.</li>
            <li>جدار الالتزامات الرقمي يبقى مفتوحاً للحضور خلال الأسبوع، ثم يُعمَّم عند الإكمال.</li>
            <li>التصميم عربي RTL، واضح ومؤسسي بهوية الهيئة العامة للمنافسة.</li>
        </ul>
    </div>
</div>

<div class="card card--accent">
    <h2>@Html.Content("home.objectives.title", "أهداف الرحلة")</h2>
    <p>@Html.Content("home.objectives.body", "ترسيخ فهم مشترك للاستراتيجية، وربط عمل كل إدارة بالركائز والأهداف المؤسسية.")</p>
</div>

<div class="card" style="text-align:center;">
    <h2>@Html.Content("home.cta.title", "هل أنت مستعد لبدء رحلة إدارتك الاستراتيجية؟")</h2>
    <div class="row mt-2 btn-stack-mobile" style="justify-content:center;">
        <a href="/Account/Login" class="btn btn--primary">@Html.Content("home.cta.button", "الدخول إلى المنصة")</a>
    </div>
</div>

<div class="card">
    <h2>@Html.Content("home.contact.title", "للتواصل مع مكتب الاستراتيجية")</h2>
    <p class="muted">
        <span>الهاتف: @Html.Content("home.contact.phone", "011 000 0000")</span><br />
        <span>البريد الإلكتروني: @Html.Content("home.contact.email", "strategy@gac.gov.sa")</span>
    </p>
</div>

<p class="muted" style="text-align:center;margin-top:8px;">@Html.Content("home.footer.note", "جميع الحقوق محفوظة — الهيئة العامة للمنافسة")</p>
