@using StrategyHouse.Web.Controllers
@{
    ViewData["Title"] = "الرئيسية — منصة إطلاق استراتيجية الهيئة";
    var stats = (HomeStats)ViewBag.Stats;
}

<div class="hero">
    <h1>@Html.Content("home.hero.title", "منصة إطلاق استراتيجية الهيئة العامة للمنافسة")</h1>
    <p>@Html.Content("home.hero.subtitle", "منصة رقمية تفاعلية لإطلاق الاستراتيجية على مستوى الإدارات الثمانية عشر — تُعرّف الموظفين بالرؤية والرسالة والقيم، تبني الخريطة الاستراتيجية لكل إدارة معاً، وتُسجّل الالتزامات الجماعية بتوقيع تطوعي على الجدار الرقمي للالتزامات.")</p>
    <div class="row mt-2 btn-stack-mobile">
        <a href="/Journey" class="btn btn--primary">@Html.Content("home.hero.cta", "ابدأ رحلة إدارتك")</a>
    </div>
</div>

<div class="card">
    <h2>@Html.Content("home.about.title", "عن المنصة")</h2>
    <p>@Html.Content("home.about.body", "منصة رقمية تفاعلية لإطلاق الاستراتيجية المؤسسية على مستوى الإدارات الثماني عشرة.")</p>
</div>

<div class="stats">
    <div class="stat">
        <div class="stat__num">@stats.Pillars</div>
        <div class="stat__label">ركيزة</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Objectives</div>
        <div class="stat__label">هدف</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Initiatives</div>
        <div class="stat__label">مبادرة</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Projects</div>
        <div class="stat__label">إجمالي المشاريع</div>
    </div>
    <div class="stat">
        <div class="stat__num">@stats.Kpis</div>
        <div class="stat__label">إجمالي المؤشرات</div>
    </div>
</div>

<div class="grid-2">
    <div class="card card--accent">
        <h2>@Html.Content("home.session.title")</h2>
        <ol>
            <li><strong>@Html.Content("home.session.item1.title"):</strong> @Html.Content("home.session.item1.body")</li>
            <li><strong>@Html.Content("home.session.item2.title"):</strong> @Html.Content("home.session.item2.body")</li>
            <li><strong>@Html.Content("home.session.item3.title"):</strong> @Html.Content("home.session.item3.body")</li>
            <li><strong>@Html.Content("home.session.item4.title"):</strong> @Html.Content("home.session.item4.body")</li>
        </ol>
    </div>

    <div class="card card--accent">
        <h2>@Html.Content("home.principles.title")</h2>
        <ul>
            <li>@Html.Content("home.principles.item1")</li>
            <li>@Html.Content("home.principles.item2")</li>
            <li>@Html.Content("home.principles.item3")</li>
            <li>@Html.Content("home.principles.item4")</li>
            <li>@Html.Content("home.principles.item5")</li>
        </ul>
    </div>
</div>

<div class="card card--accent">
    <h2>@Html.Content("home.objectives.title", "أهداف الرحلة")</h2>
    <p>@Html.Content("home.objectives.body", "ترسيخ فهم مشترك للاستراتيجية، وربط عمل كل إدارة بالركائز والأهداف المؤسسية.")</p>
</div>

<div class="card contact-card">
    <h2 class="contact-title">@Html.Content("home.contact.title", "للتواصل مع إدارة الاستراتيجية والأداء المؤسسي")</h2>
    <p class="muted">
        للتواصل: <a href="mailto:strategy@gac.gov.sa">strategy@gac.gov.sa</a>
    </p>
</div>

<p class="muted" style="text-align:center;margin-top:8px;">@Html.Content("home.footer.note", "جميع الحقوق محفوظة — الهيئة العامة للمنافسة")</p>
