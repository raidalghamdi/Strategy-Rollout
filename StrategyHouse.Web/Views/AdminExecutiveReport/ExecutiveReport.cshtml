@model StrategyHouse.Web.Models.ExecutiveReportViewModel
@using StrategyHouse.Web.Models
@{
    ViewData["Title"] = "التقرير التنفيذي";
    var sectionsQuery = Model.Sections.ToQueryValue();
    var qs = "?sections=" + Uri.EscapeDataString(sectionsQuery);
}

<div class="card mb-3" style="background:linear-gradient(135deg,#00192B 0%,#0E2A47 60%,#0069A7 100%);color:#fff;border:0;">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <h1 class="mb-1" style="color:#fff;">التقرير التنفيذي</h1>
            <p class="mb-0" style="color:#FAC126;">بناء البيت الاستراتيجي — رحلة الإدارات · الهيئة العامة للمنافسة</p>
            <p class="mb-0 small" style="color:#cfe2f0;">تم الإنشاء: @Model.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/Admin/ExecutiveReport.pdf@(qs)" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل PDF</a>
            <a href="/Admin/ExecutiveReport.pptx@(qs)" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل PowerPoint</a>
            <a href="/Admin/ExecutiveReport.xlsx@(qs)" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل Excel</a>
            <a href="/Admin/ExecutiveReport.csv@(qs)" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل CSV</a>
            <button type="button" id="btn-email-report" class="btn btn-sm" style="background:#fff;color:#00192B;font-weight:700;border-radius:999px;">إرسال بالبريد</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<div id="email-report-modal" style="display:none;position:fixed;inset:0;z-index:1080;background:rgba(0,25,43,0.55);">
    <div style="max-width:420px;margin:8% auto;background:#fff;border-radius:14px;padding:20px;direction:rtl;box-shadow:0 12px 40px rgba(0,0,0,0.3);">
        <h2 class="h5" style="color:#00192B;">إرسال التقرير بالبريد الإلكتروني</h2>
        <label class="form-label small" for="email-report-to">البريد الإلكتروني</label>
        <input type="email" id="email-report-to" class="form-control" placeholder="name@gac.gov.sa" />
        <label class="form-label small mt-2" for="email-report-format">صيغة الملف</label>
        <select id="email-report-format" class="form-select">
            <option value="pdf">PDF</option>
            <option value="pptx">PowerPoint</option>
            <option value="xlsx">Excel</option>
            <option value="csv">CSV</option>
        </select>
        <div id="email-report-msg" class="small mt-2" style="display:none;"></div>
        <div class="d-flex gap-2 mt-3 justify-content-end">
            <button type="button" id="email-report-cancel" class="btn btn--secondary btn-sm">إلغاء</button>
            <button type="button" id="email-report-submit" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;">إرسال</button>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="d-flex justify-content-between align-items-center" style="cursor:pointer;" id="customize-toggle">
        <h2 class="h5 mb-0">خصص التقرير</h2>
        <span class="badge bg-secondary" id="customize-caret">▼</span>
    </div>
    <div id="customize-body" style="display:none;margin-top:12px;">
        <p class="muted small">اختر الأقسام التي ترغب بعرضها وتصديرها. التحديد الافتراضي يشمل جميع الأقسام.</p>
        <div class="grid-3">
            @foreach (var sec in ExecReportSections.All)
            {
                <label class="d-flex align-items-center gap-2" style="padding:4px 0;">
                    <input type="checkbox" class="exec-section-cb" value="@sec.Key" @(Model.Sections.Has(sec.Key) ? "checked" : "") />
                    <span>@sec.Title</span>
                </label>
            }
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <button type="button" id="sections-apply" class="btn btn-sm" style="background:#0069A7;color:#fff;font-weight:700;border-radius:999px;">تطبيق على العرض</button>
            <button type="button" id="sections-save" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">حفظ كافتراضي</button>
            <span id="sections-msg" class="small align-self-center" style="display:none;"></span>
        </div>
    </div>
</div>

@if (Model.Sections.Has(ExecReportSections.Overview))
{
<div class="card mb-3">
    <h2 class="h5">الملخص التنفيذي</h2>
    <div class="grid-3 my-2">
        <div class="card"><h3>@Model.Overview.TotalSessions</h3><p class="muted small">إجمالي الجلسات</p></div>
        <div class="card"><h3>@Model.Overview.TotalCompletedSessions</h3><p class="muted small">الجلسات المكتملة</p></div>
        <div class="card"><h3>@Model.Overview.TotalDepartmentsEngaged/@Model.Overview.TotalDepartments</h3><p class="muted small">الإدارات المشاركة</p></div>
        <div class="card"><h3>@Model.Overview.TotalAttendees</h3><p class="muted small">إجمالي الحضور</p></div>
        <div class="card"><h3>@Model.Overview.CompletionPercentage.ToString("0.#")%</h3><p class="muted small">نسبة الإكمال</p></div>
        <div class="card"><h3>@Model.Overview.AvgQuizScore.ToString("0.##") / 5</h3><p class="muted small">متوسط الاختبار</p></div>
        <div class="card"><h3>@(Model.Overview.AvgSurveyClarity > 0 ? Model.Overview.AvgSurveyClarity.ToString("0.##") + " / 5" : "—")</h3><p class="muted small">وضوح الاستراتيجية</p></div>
        <div class="card"><h3>@(Model.Overview.AvgContributionCapability > 0 ? Model.Overview.AvgContributionCapability.ToString("0.##") + " / 5" : "—")</h3><p class="muted small">القدرة على المساهمة</p></div>
        <div class="card"><h3>@(Model.Overview.AvgCompletionMinutes > 0 ? Model.Overview.AvgCompletionMinutes.ToString("0.#") + " د" : "—")</h3><p class="muted small">متوسط وقت الإكمال</p></div>
    </div>
    @if (Model.Overview.NotEngagedDepartments.Any())
    {
        <p class="muted small mb-0">لم تشارك بعد: @string.Join("، ", Model.Overview.NotEngagedDepartments)</p>
    }
</div>
}

@if (Model.Sections.Has(ExecReportSections.Departments))
{
<div class="card mb-3">
    <h2 class="h5">الحضور حسب الإدارة</h2>
    @if (Model.DepartmentBreakdown.Any())
    {
        <div class="chart-wrap" style="height:280px;"><canvas id="chart-depts"></canvas></div>
        <div class="table-responsive mt-3">
            <table class="table table-hover align-middle" style="background:#fff;">
                <thead>
                    <tr><th>الترتيب</th><th>الإدارة</th><th>الجلسات</th><th>الحضور</th><th>نسبة الإكمال</th></tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.DepartmentBreakdown)
                    {
                        <tr>
                            <td>@d.Rank</td>
                            <td><strong>@d.DeptName</strong></td>
                            <td>@d.SessionsCount</td>
                            <td>@d.AttendeesCount</td>
                            <td>@d.CompletionRate.ToString("0.#")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <p class="muted">لا توجد بيانات إدارات بعد.</p> }
</div>
}

@* Phase 20.34 (Comment A) — Totals-first hierarchy: Overall → Sector → Department → Individual
   Individual names hidden by default behind a toggle. *@
@if (Model.Sections.Has(ExecReportSections.Departments))
{
<div class="card mb-3">
    <h2 class="h5 mb-1">الإجماليات حسب المستوى</h2>
    <p class="muted small mb-3">تعرض الأرقام الإجمالية على مستوى المنظمة، ثم القطاعات، ثم الإدارات. الأسماء الفردية مخفية افتراضياً ويمكن إظهارها بزر الإظهار في الأسفل.</p>

    @* Level 1 — Overall (organization-wide) *@
    <div class="mb-3">
        <h3 class="h6 mb-2">إجمالي المنظمة</h3>
        <div class="table-responsive">
            <table class="table table-sm align-middle" style="background:#fff;">
                <thead class="table-light">
                    <tr><th>الجلسات</th><th>الحضور</th><th>نسبة الإكمال</th><th>متوسط الوقت (د)</th></tr>
                </thead>
                <tbody>
                    @{
                        var totSessions = Model.SectorRows.Sum(s => s.SessionsCount);
                        var totAttendees = Model.SectorRows.Sum(s => s.AttendeesCount);
                        var totCompletion = Model.Overview.CompletionPercentage;
                        var totAvgMin = Model.Overview.AvgCompletionMinutes;
                    }
                    <tr class="fw-bold" style="background:#FFF8E1;">
                        <td>@totSessions</td>
                        <td>@totAttendees</td>
                        <td>@totCompletion.ToString("0.#")%</td>
                        <td>@(totAvgMin > 0 ? totAvgMin.ToString("0.#") : "—")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* Level 2 — Sectors (collapsible) *@
    <details class="mb-3" open>
        <summary class="h6 mb-2" style="cursor:pointer;">حسب القطاع (@Model.SectorRows.Count)</summary>
        @if (Model.SectorRows.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle table-sm" style="background:#fff;">
                    <thead class="table-dark">
                        <tr><th>القطاع</th><th>الجلسات</th><th>الحضور</th><th>نسبة الإكمال</th><th>متوسط الوقت (د)</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.SectorRows)
                        {
                            <tr>
                                <td><strong>@(string.IsNullOrEmpty(s.SectorName) ? "إدارات مستقلة" : s.SectorName)</strong></td>
                                <td>@s.SessionsCount</td>
                                <td>@s.AttendeesCount</td>
                                <td>@s.CompletionRate.ToString("0.#")%</td>
                                <td>@(s.AvgCompletionMinutes > 0 ? s.AvgCompletionMinutes.ToString("0.#") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p class="muted">لا توجد بيانات قطاعات.</p> }
    </details>

    @* Level 3 — Departments (collapsible) *@
    <details class="mb-3">
        <summary class="h6 mb-2" style="cursor:pointer;">حسب الإدارة (@Model.DepartmentRowsV2.Count)</summary>
        @if (Model.DepartmentRowsV2.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle table-sm" style="background:#fff;">
                    <thead>
                        <tr><th>الإدارة</th><th>القطاع</th><th>الجلسات</th><th>الحضور</th><th>نسبة الإكمال</th><th>متوسط الوقت (د)</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.DepartmentRowsV2)
                        {
                            <tr>
                                <td><strong>@d.DeptName</strong></td>
                                <td class="d-none d-md-table-cell">@(string.IsNullOrEmpty(d.SectorName) ? "—" : d.SectorName)</td>
                                <td>@d.SessionsCount</td>
                                <td>@d.AttendeesCount</td>
                                <td>@d.CompletionRate.ToString("0.#")%</td>
                                <td>@(d.AvgCompletionMinutes > 0 ? d.AvgCompletionMinutes.ToString("0.#") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p class="muted">لا توجد بيانات إدارات.</p> }
    </details>

    @* Level 4 — Individuals (HIDDEN BY DEFAULT — toggle button) *@
    @if (Model.IndividualRows.Any())
    {
        <div class="mt-3 mb-2">
            <button type="button" class="btn btn-outline-primary btn-sm" id="toggle-individuals"
                    data-show-label="إظهار أسماء الموظفين (@Model.IndividualRows.Count)"
                    data-hide-label="إخفاء أسماء الموظفين"
                    onclick="(function(){var el=document.getElementById('individuals-section');var btn=document.getElementById('toggle-individuals');if(el.style.display==='none'){el.style.display='block';btn.textContent=btn.getAttribute('data-hide-label');}else{el.style.display='none';btn.textContent=btn.getAttribute('data-show-label');}})();">
                إظهار أسماء الموظفين (@Model.IndividualRows.Count)
            </button>
            <span class="muted small ms-2">مخفية افتراضياً للحفاظ على الخصوصية والتركيز على الأرقام الإجمالية</span>
        </div>
        <div id="individuals-section" style="display:none;">
            <h3 class="h6 mb-2">مستوى الموظفين (من سجل الحضور)</h3>
            <div class="table-responsive">
                <table class="table table-sm align-middle" style="background:#fff;">
                    <thead class="table-light">
                        <tr>
                            <th>الاسم</th>
                            <th class="d-none d-md-table-cell">البريد الإلكتروني</th>
                            <th>الإدارة</th>
                            <th class="d-none d-md-table-cell">القطاع</th>
                            <th>مكتمل؟</th>
                            <th class="d-none d-md-table-cell">وقت الإكمال (د)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model.IndividualRows)
                        {
                            <tr>
                                <td>@emp.FullNameAr</td>
                                <td class="d-none d-md-table-cell"><span class="small">@(string.IsNullOrEmpty(emp.Email) ? "—" : emp.Email)</span></td>
                                <td><span class="small">@emp.DeptName</span></td>
                                <td class="d-none d-md-table-cell"><span class="small">@(string.IsNullOrEmpty(emp.SectorName) ? "—" : emp.SectorName)</span></td>
                                <td>@(emp.Completed ? Html.Raw("<span class='badge bg-success'>مكتمل</span>") : Html.Raw("<span class='badge bg-secondary'>لم يكتمل</span>"))</td>
                                <td class="d-none d-md-table-cell">@(emp.CompletionMinutes.HasValue ? emp.CompletionMinutes.Value.ToString("0.#") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else { <p class="muted small mt-2">لا يوجد أعضاء في سجل الحضور بعد.</p> }
</div>
}

@if (Model.Sections.Has(ExecReportSections.Quiz) || Model.Sections.Has(ExecReportSections.Survey))
{
<div class="grid-2 mb-3">
    @if (Model.Sections.Has(ExecReportSections.Quiz))
    {
    <div class="card">
        <h2 class="h5">توزيع نتائج الاختبار</h2>
        <p class="muted small">إجمالي المحاولات: @Model.QuizAnalytics.TotalAttempts · المتوسط: @Model.QuizAnalytics.AvgScore.ToString("0.##") / 5</p>
        @if (Model.QuizAnalytics.TotalAttempts > 0)
        {
            <div class="chart-wrap" style="height:240px;"><canvas id="chart-quiz"></canvas></div>
        }
        else { <p class="muted">لا توجد محاولات بعد.</p> }
        @if (Model.QuizAnalytics.Top3MostMissed.Any())
        {
            <h3 class="h6 text-warning mt-3">أكثر الأسئلة صعوبة</h3>
            <ul class="small">
                @foreach (var q in Model.QuizAnalytics.Top3MostMissed)
                {
                    <li>@q.QuestionAr — نسبة الخطأ @q.MissRate.ToString("0.#")% (@q.Attempts محاولة)</li>
                }
            </ul>
        }
        @if (Model.QuizAnalytics.Top3Strongest.Any())
        {
            <h3 class="h6 text-success mt-3">نقاط القوة المعرفية</h3>
            <ul class="small">
                @foreach (var q in Model.QuizAnalytics.Top3Strongest)
                {
                    <li>@q.QuestionAr — نسبة الصواب @((100 - q.MissRate).ToString("0.#"))%</li>
                }
            </ul>
        }
    </div>
    }
    @if (Model.Sections.Has(ExecReportSections.Survey))
    {
    <div class="card">
        <h2 class="h5">وضوح الاستراتيجية (السؤال 1)</h2>
        @{ var clarity = Model.SurveyMetrics.FirstOrDefault(x => x.Order == 1); }
        @if (clarity != null)
        {
            <p class="muted small">@clarity.QuestionAr</p>
            <div class="chart-wrap" style="height:200px;"><canvas id="chart-clarity"></canvas></div>
            <p class="small mt-2">@clarity.Headline</p>
        }
        else { <p class="muted">لا توجد بيانات استبيان بعد.</p> }
    </div>
    }
</div>
}

@if (Model.Sections.Has(ExecReportSections.Survey) && Model.SurveyMetrics.Any())
{
    <div class="card mb-3">
        <h2 class="h5">مؤشرات الاستبيان الرسمي</h2>
        <ul class="list-group list-group-flush">
            @foreach (var s in Model.SurveyMetrics.OrderBy(x => x.Order))
            {
                <li class="list-group-item">
                    <strong>السؤال @s.Order:</strong> @s.QuestionAr
                    <div class="muted small">@s.Type · @s.Headline</div>
                </li>
            }
        </ul>
    </div>
}

@if (Model.Sections.Has(ExecReportSections.Contributions))
{
<div class="grid-2 mb-3">
    <div class="card">
        <h2 class="h5">أبرز الأهداف</h2>
        @if (Model.Contributions.TopObjectives.Any())
        {
            <ul class="list-group list-group-flush">
                @foreach (var o in Model.Contributions.TopObjectives)
                {
                    <li class="list-group-item d-flex justify-content-between"><span>@o.Name</span><span class="badge bg-primary">@o.Count</span></li>
                }
            </ul>
        }
        else { <p class="muted">لا توجد مساهمات بعد.</p> }
    </div>
    <div class="card">
        <h2 class="h5">أبرز المبادرات</h2>
        @if (Model.Contributions.TopInitiatives.Any())
        {
            <ul class="list-group list-group-flush">
                @foreach (var i in Model.Contributions.TopInitiatives)
                {
                    <li class="list-group-item d-flex justify-content-between"><span>@i.Name</span><span class="badge bg-info">@i.Count</span></li>
                }
            </ul>
        }
        else { <p class="muted">لا توجد مساهمات بعد.</p> }
    </div>
</div>
<div class="card mb-3">
    <h2 class="h5">القيمة التي تعبّر عن الفرق</h2>
    <p class="muted small">إجمالي الاختيارات: @Model.TeamValues.TotalSelections</p>
    @if (Model.TeamValues.ByValue.Any())
    {
        <ul class="list-group list-group-flush">
            @foreach (var v in Model.TeamValues.ByValue)
            {
                <li class="list-group-item d-flex justify-content-between"><span>@v.Name</span><span class="badge bg-success">@v.Count</span></li>
            }
        </ul>
    }
    else { <p class="muted">لم تختر الفرق قيمة بعد.</p> }
</div>
}

@if (Model.Sections.Has(ExecReportSections.Signatures))
{
<div class="card mb-3">
    <h2 class="h5">تواقيع الفرق وتعليقاتها</h2>
    <p class="muted small">إجمالي التواقيع: @Model.GroupSignatures.TotalCount · الخرائط الاستراتيجية: @Model.MapsCount</p>
    @if (Model.GroupSignatures.TopKeywords.Any())
    {
        <p class="small">موضوعات شائعة: @string.Join("، ", Model.GroupSignatures.TopKeywords.Take(8).Select(k => $"{k.Name} ({k.Count})"))</p>
    }
    @if (Model.GroupSignatures.RecentComments.Any())
    {
        <ul class="list-group list-group-flush">
            @foreach (var c in Model.GroupSignatures.RecentComments)
            {
                <li class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <strong>@c.DeptName</strong>
                        <span class="muted small">@c.CapturedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div>@c.Text</div>
                </li>
            }
        </ul>
    }
    else { <p class="muted">لا توجد تعليقات بعد.</p> }
</div>
}

@if (Model.Sections.Has(ExecReportSections.LeadershipAlignment))
{
<div class="card mb-3">
    <h2 class="h5">الاتساق الاستراتيجي</h2>
    <p class="muted small">إجمالي المساهمات المرتبطة بالركائز: @Model.LeadershipAlignment.TotalContributions</p>
    @if (Model.LeadershipAlignment.PillarShares.Any())
    {
        <ul class="list-group list-group-flush">
            @foreach (var ps in Model.LeadershipAlignment.PillarShares)
            {
                <li class="list-group-item d-flex justify-content-between"><span>@ps.PillarName</span><span class="badge bg-primary">@ps.Count (@ps.Percent.ToString("0.#")%)</span></li>
            }
        </ul>
    }
    else { <p class="muted">لا توجد مساهمات مرتبطة بالركائز بعد.</p> }
    @if (Model.LeadershipAlignment.Gaps.Any())
    {
        <div class="alert alert-warning small mt-2 mb-0">
            @foreach (var g in Model.LeadershipAlignment.Gaps)
            {
                <div>⚠ @g</div>
            }
        </div>
    }
</div>
}

@if (Model.Sections.Has(ExecReportSections.LeadershipCulture))
{
<div class="card mb-3">
    <h2 class="h5">الثقافة والمشاركة</h2>
    <p class="small"><strong>مؤشر روح الفريق:</strong> @Model.LeadershipCulture.TeamSpiritScore.ToString("0.#")/100 (@Model.LeadershipCulture.TeamSpiritLabel)</p>
    <p class="muted small">التعليقات — إيجابية: @Model.LeadershipCulture.PositiveComments · محايدة: @Model.LeadershipCulture.NeutralComments · سلبية: @Model.LeadershipCulture.NegativeComments</p>
    @if (Model.LeadershipCulture.DepartmentParticipation.Any())
    {
        <ul class="list-group list-group-flush">
            @foreach (var d in Model.LeadershipCulture.DepartmentParticipation.Take(12))
            {
                <li class="list-group-item d-flex justify-content-between"><span>@d.DeptName</span><span class="badge bg-info">@d.Attendees</span></li>
            }
        </ul>
    }
</div>
}

