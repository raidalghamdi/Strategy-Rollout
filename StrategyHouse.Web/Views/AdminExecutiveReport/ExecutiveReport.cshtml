@section Scripts {
@* Phase 20.33 (Comment 7) — load Chart.js with fallback mirror CDN to fix blank chart areas *@
<script src="/lib/chartjs/chart.umd.min.js" onload="if(typeof window._initCharts==='function')window._initCharts();"></script>
<script>
// Phase 20.34 (Comment C) — robust chart init: run when Chart.js is ready.
// Chart.js is bundled locally (/lib/chartjs/) so this works offline / on intranet.
(function () {
    function tryInit() {
        if (typeof Chart !== 'undefined' && typeof window._initCharts === 'function') {
            window._initCharts();
            return true;
        }
        return false;
    }
    if (!tryInit()) {
        // Retry on DOMContentLoaded and once more 500ms later (covers script ordering edge cases)
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', tryInit);
        }
        setTimeout(tryInit, 500);
    }
})();
</script>
<script>
(function () {
    var openBtn = document.getElementById('btn-email-report');
    var modal = document.getElementById('email-report-modal');
    var cancelBtn = document.getElementById('email-report-cancel');
    var submitBtn = document.getElementById('email-report-submit');
    var msg = document.getElementById('email-report-msg');
    if (!openBtn || !modal) { return; }

    function showMsg(text, ok) {
        msg.style.display = 'block';
        msg.textContent = text;
        msg.style.color = ok ? '#009845' : '#C0392B';
    }
    function openModal() { modal.style.display = 'block'; msg.style.display = 'none'; }
    function closeModal() { modal.style.display = 'none'; }

    openBtn.onclick = openModal;
    cancelBtn.onclick = closeModal;
    modal.onclick = function (e) { if (e.target === modal) { closeModal(); } };

    submitBtn.onclick = function () {
        var email = document.getElementById('email-report-to').value;
        var format = document.getElementById('email-report-format').value;
        if (!email || email.indexOf('@@') === -1) {
            showMsg('يرجى إدخال بريد إلكتروني صحيح.', false);
            return;
        }
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenEl ? tokenEl.value : '';
        submitBtn.disabled = true;
        showMsg('جارٍ الإرسال...', true);
        var sections = (window.execReportSections && window.execReportSections.current) ? window.execReportSections.current() : '@Model.Sections.ToQueryValue()';
        var data = 'email=' + encodeURIComponent(email) + '&format=' + encodeURIComponent(format) + '&sections=' + encodeURIComponent(sections);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/Admin/ExecutiveReport/Email', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('RequestVerificationToken', token);
        xhr.onreadystatechange = function () {
            if (xhr.readyState !== 4) { return; }
            submitBtn.disabled = false;
            var ok = false, message = 'تعذّر الإرسال.';
            try {
                var res = JSON.parse(xhr.responseText);
                ok = !!res.success;
                message = res.message || message;
            } catch (err) { message = 'تعذّر الاتصال بالخادم.'; }
            showMsg(message, ok);
        };
        xhr.send(data);
    };
})();
</script>
<script>
// Phase 20.33 (Comment 7) — named init so fallback CDN can call it
window._initCharts = function() {
    if (typeof Chart === 'undefined') return;
    if (window._initChartsDone) return; // guard: prevent re-init double-draw
    window._initChartsDone = true;

    var deptLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentBreakdown.Select(d => d.DeptName)));
    var deptAttendees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentBreakdown.Select(d => d.AttendeesCount)));
    var deptSessions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentBreakdown.Select(d => d.SessionsCount)));
    var quizBuckets = [@Model.QuizAnalytics.Bucket0to2, @Model.QuizAnalytics.Bucket3to4, @Model.QuizAnalytics.Bucket5];
    var clarityDist = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Overview.SurveyClarityDistribution));

    var elDepts = document.getElementById('chart-depts');
    if (elDepts && deptLabels.length) {
        new Chart(elDepts, { type: 'bar', data: { labels: deptLabels, datasets: [{ label: 'الجلسات', data: deptSessions, backgroundColor: '#FAC126' }, { label: 'الحضور', data: deptAttendees, backgroundColor: '#0069A7' }] }, options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { x: { beginAtZero: true, ticks: { precision: 0 } } } } });
    }

    var elQuiz = document.getElementById('chart-quiz');
    if (elQuiz) {
        new Chart(elQuiz, { type: 'doughnut', data: { labels: ['منخفض (0-2)', 'متوسط (3-4)', 'ممتاز (5)'], datasets: [{ data: quizBuckets, backgroundColor: ['#E74C3C', '#FAC126', '#009845'] }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } } });
    }

    var elClarity = document.getElementById('chart-clarity');
    if (elClarity) {
        new Chart(elClarity, { type: 'bar', data: { labels: ['1', '2', '3', '4', '5'], datasets: [{ label: 'التكرار', data: clarityDist, backgroundColor: '#299ECE' }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } } });
    }
};
// Call immediately if Chart.js is already loaded
window._initCharts();
</script>
<script>
(function () {
    function ready(fn) {
        if (document.readyState !== 'loading') { fn(); }
        else { document.addEventListener('DOMContentLoaded', fn); }
    }
    ready(function () {
        try {
            var toggle = document.getElementById('customize-toggle');
            var body = document.getElementById('customize-body');
            var applyBtn = document.getElementById('sections-apply');
            var saveBtn = document.getElementById('sections-save');
            var msgEl = document.getElementById('sections-msg');

            function collect() {
                var boxes = document.querySelectorAll('.exec-section-cb');
                var keys = [];
                for (var i = 0; i < boxes.length; i++) {
                    if (boxes[i].checked) { keys.push(boxes[i].value); }
                }
                return keys.join(',');
            }

            // Expose the current selection so the email modal can read it.
            window.execReportSections = { current: collect };

            if (toggle && body) {
                toggle.onclick = function () {
                    body.style.display = (body.style.display === 'none' || body.style.display === '') ? 'block' : 'none';
                };
            }

            if (applyBtn) {
                applyBtn.onclick = function () {
                    var sel = collect();
                    if (!sel) {
                        if (msgEl) { msgEl.style.display = 'inline'; msgEl.style.color = '#C0392B'; msgEl.textContent = 'يرجى اختيار قسم واحد على الأقل.'; }
                        return;
                    }
                    window.location.href = '/Admin/ExecutiveReport?sections=' + encodeURIComponent(sel);
                };
            }

            if (saveBtn) {
                saveBtn.onclick = function () {
                    var sel = collect();
                    if (!sel) {
                        if (msgEl) { msgEl.style.display = 'inline'; msgEl.style.color = '#C0392B'; msgEl.textContent = 'يرجى اختيار قسم واحد على الأقل.'; }
                        return;
                    }
                    var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                    var token = tokenEl ? tokenEl.value : '';
                    saveBtn.disabled = true;
                    if (msgEl) { msgEl.style.display = 'inline'; msgEl.style.color = '#0069A7'; msgEl.textContent = 'جارٍ الحفظ...'; }
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Admin/ExecutiveReport/SaveDefault', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                    xhr.setRequestHeader('RequestVerificationToken', token);
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) { return; }
                        saveBtn.disabled = false;
                        var ok = false, message = 'تعذّر الحفظ.';
                        try {
                            var res = JSON.parse(xhr.responseText);
                            ok = !!res.success;
                            message = res.message || message;
                        } catch (err) { message = 'تعذّر الاتصال بالخادم.'; }
                        if (msgEl) { msgEl.style.display = 'inline'; msgEl.style.color = ok ? '#009845' : '#C0392B'; msgEl.textContent = message; }
                    };
                    xhr.send('sections=' + encodeURIComponent(sel));
                };
            }
        } catch (e) {
            var m = document.getElementById('sections-msg');
            if (m) { m.style.display = 'inline'; m.style.color = '#C0392B'; m.textContent = 'تعذّر تفعيل أدوات التخصيص.'; }
        }
    });
})();
</script>
}
