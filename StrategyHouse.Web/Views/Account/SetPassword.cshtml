@model StrategyHouse.Web.Controllers.SetPasswordViewModel
@{
    ViewData["Title"] = "إنشاء كلمة المرور";
}
<style>
    .login-stage {
        min-height: calc(100vh - 220px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 12px;
    }
    .login-stage > .card {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }
</style>
<div class="login-stage">
    <div class="card">
        <h2>إنشاء كلمة المرور</h2>
        <p class="muted">مرحباً بك في منصة الاستراتيجية. لكونها أول مرة تسجل دخولاً، الرجاء إنشاء كلمة المرور الخاصة بك.</p>

        <div class="alert alert--info" style="background:#eef6ff;border:1px solid #b6dcff;padding:10px;border-radius:6px;margin-bottom:12px;">
            <strong>المستخدم:</strong> @Model.UserName
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" action="/Account/SetPassword" autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserName" value="@Model.UserName" />
            <div class="form-row">
                <label for="NewPassword">كلمة المرور الجديدة</label>
                <input id="NewPassword" name="NewPassword" type="password" class="input" required minlength="12" />
                <small class="muted">12 حرفاً على الأقل، تتضمن حروفاً كبيرة وصغيرة وأرقاماً ورمزاً خاصاً.</small>
            </div>
            <div class="form-row">
                <label for="ConfirmPassword">تأكيد كلمة المرور</label>
                <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="input" required minlength="12" />
            </div>
            <button type="submit" class="btn btn--primary btn--block">حفظ وتسجيل الدخول</button>
        </form>

        <div style="margin-top:14px;text-align:center;">
            <a href="/Account/Login" class="muted small">العودة لصفحة تسجيل الدخول</a>
        </div>
    </div>
</div>
