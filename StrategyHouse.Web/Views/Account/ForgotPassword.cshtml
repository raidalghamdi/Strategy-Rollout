@{
    ViewData["Title"] = "نسيت كلمة المرور";
}
<style>
    .login-stage {
        min-height: calc(100vh - 220px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 12px;
    }
    .login-stage > .card {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }
</style>
<div class="login-stage">
    <div class="card">
        <h2>نسيت كلمة المرور</h2>
        <p class="muted">أدخل البريد الإلكتروني المسجّل في حسابك، وسنرسل لك رابطاً لإعادة تعيين كلمة المرور.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" action="/Account/ForgotPassword" autocomplete="off">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <label for="email">البريد الإلكتروني</label>
                <input id="email" name="email" type="email" class="input" required
                       placeholder="example@gac.gov.sa"
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </div>
            <button type="submit" class="btn btn--primary btn--block">إرسال الرابط</button>
        </form>

        <div style="margin-top:14px;text-align:center;">
            <a href="/Account/Login" class="muted small">العودة لصفحة تسجيل الدخول</a>
        </div>
    </div>
</div>
