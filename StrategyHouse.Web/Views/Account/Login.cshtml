@{
    ViewData["Title"] = "تسجيل الدخول";
}
<div class="container--narrow">
    <div class="card">
        <h2>تسجيل الدخول</h2>
        <p class="muted">للحضور: لا حاجة لتسجيل الدخول، استخدم رمز الجلسة من المُيسّر.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" action="/Account/Login" autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="form-row">
                <label for="email">اسم المستخدم أو البريد الإلكتروني</label>
                <input id="email" name="email" type="text" class="input" required
                       placeholder="gac.admin أو admin@gac.gov.sa"
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </div>
            <div class="form-row">
                <label for="password">كلمة المرور</label>
                <input id="password" name="password" type="password" class="input" required />
            </div>
            <button type="submit" class="btn btn--primary btn--block">دخول</button>
            <details class="mt-3" style="font-size:.85rem;color:#5a6b80;">
                <summary style="cursor:pointer;font-weight:700;">حسابات الرحلة المتاحة</summary>
                <ul style="margin:8px 0 0;padding-inline-start:18px;line-height:1.9;">
                    <li><code>gac.admin</code> — الحساب العام (يرى كل الإدارات)</li>
                    <li><code>vp.support</code> — قطاع الدعم المؤسسي</li>
                    <li><code>vp.economic</code> — قطاع الشؤون الاقتصادية</li>
                    <li><code>vp.legal</code> — قطاع الشؤون القانونية</li>
                    <li><code>testing</code> — اختبار</li>
                </ul>
            </details>
        </form>
    </div>
</div>
