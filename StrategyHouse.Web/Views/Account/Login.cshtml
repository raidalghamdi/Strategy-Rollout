@{
    ViewData["Title"] = "تسجيل الدخول";
}
<style>
    /* Phase 20.9 — fully center the login card on every viewport. */
    .login-stage {
        min-height: calc(100vh - 220px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 12px;
    }
    .login-stage > .card {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }
    @@media (max-height: 640px) {
        .login-stage { min-height: auto; padding: 18px 12px; }
    }
</style>
<div class="login-stage">
    <div class="card">
        <h2>تسجيل الدخول</h2>
        <p class="muted">للحضور: لا حاجة لتسجيل الدخول، استخدم رمز الجلسة من المُيسّر.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert" style="background:#eaf5d8;border:1px solid #5F9600;color:#3a5e00;padding:10px;border-radius:6px;margin-bottom:12px;">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert--error">@TempData["Error"]</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" action="/Account/Login" autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="form-row">
                <label for="email">اسم المستخدم أو البريد الإلكتروني</label>
                <input id="email" name="email" type="text" class="input" required
                       placeholder="gac.admin أو admin@gac.gov.sa"
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </div>
            <div class="form-row">
                <label for="password">كلمة المرور</label>
                <input id="password" name="password" type="password" class="input" required />
            </div>
            <button type="submit" class="btn btn--primary btn--block">دخول</button>
        </form>

        @* Phase 20.27 — self-service password recovery link. *@
        <div style="margin-top:14px;text-align:center;">
            <a href="/Account/ForgotPassword" class="muted small">نسيت كلمة المرور؟</a>
        </div>
    </div>
</div>
