@model StrategyHouse.Web.Controllers.BulkEmailsVm
@{ ViewData["Title"] = "إضافة وتحديث الأعضاء بالجملة"; }

@*
    Phase 20.31 — Bulk add roster members by email only.

    Paste lines like:
        email                    (creates an UNASSIGNED member; name = email local-part)
        email, namear            (creates an UNASSIGNED member with a custom display name)
    Admin links them to a department later from /Admin/Roster.
*@

<div class="d-flex justify-content-between align-items-center mb-3" style="flex-wrap:wrap;gap:.5rem;">
    <div>
        <h1 style="margin:0;">إضافة وتحديث الأعضاء بالجملة</h1>
        <p class="muted" style="margin:.25rem 0 0;">أضف عشرات الأعضاء بإيميلاتهم دفعة واحدة.</p>
    </div>
    <div>
        <a href="/Admin/Roster" class="btn btn-outline-secondary">← العودة للقائمة</a>
    </div>
</div>

@if (Model.DryRun)
{
    <div class="alert alert-warning">
        <strong>وضع المعاينة:</strong> لم يتم حفظ أي تغييرات.
        @Model.InsertedCount إضافة محتملة و @Model.UpdatedCount تحديث محتمل.
    </div>
}

@if (Model.Errors.Count > 0)
{
    <div class="alert alert-danger">
        <strong>أخطاء — لم يُحفظ شيء:</strong>
        <ul style="margin:.5rem 0 0;">
            @foreach (var e in Model.Errors) { <li>@e</li> }
        </ul>
    </div>
}

@if (Model.Warnings.Count > 0)
{
    <div class="alert alert-warning">
        <strong>تنبيهات:</strong>
        <ul style="margin:.5rem 0 0;">
            @foreach (var w in Model.Warnings) { <li>@w</li> }
        </ul>
    </div>
}

<div class="alert alert-info" style="font-size:.9rem;">
    <strong>صيغة المدخلات</strong> — سطر لكل عضو، إيميل فقط (أو إيميل + اسم). الأسطر التي تبدأ بـ <code>#</code> تُعد تعليقات:
    <pre style="background:#f8f9fa;border:1px solid #ddd;padding:.6rem;margin:.5rem 0 0;border-radius:4px;direction:ltr;text-align:left;">
# email فقط (يستخدم جزء البريد كاسم)
ahmad@@gac.gov.sa

# email, namear (مع تحديد اسم العرض)
sarah@@gac.gov.sa, سارة الأحمد
omar@@gac.gov.sa, عمر الفهد
</pre>
    الأعضاء الجدد يُضافون بحالة <strong>بدون إدارة</strong> — ربطهم بإدارة يتم لاحقاً من صفحة الأعضاء. البريد الإلكتروني فريد على مستوى المنصة كلها.
</div>

<form method="post" asp-action="BulkEmailsSubmit">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label fw-bold">المدخلات</label>
        <textarea name="payload"
                  class="form-control"
                  rows="14"
                  style="direction:ltr;text-align:left;font-family:monospace;font-size:.9rem;"
                  placeholder="ahmad@@gac.gov.sa
sarah@@gac.gov.sa, سارة الأحمد
omar@@gac.gov.sa, عمر الفهد">@Model.Payload</textarea>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" name="dryRun" value="true" class="btn btn-outline-primary">
            معاينة فقط (بدون حفظ)
        </button>
        <button type="submit" name="dryRun" value="false" class="btn gac-btn-primary text-white">
            تنفيذ وحفظ
        </button>
    </div>
</form>

<hr style="margin:2rem 0;" />

<h2 style="font-size:1.2rem;">طريقة بديلة: استيراد من Excel</h2>
<p class="muted">
    يمكنك أيضاً تنزيل قاعدة البيانات من
    <a href="/Admin/DbExport">/Admin/DbExport</a>،
    تعديل ورقة <code>DepartmentRoster</code> (مع تعبئة عمود <code>Email</code>)،
    ثم رفعها عبر <a href="/Admin/DbImport">/Admin/DbImport</a>.
    يتم تجاهل الأعمدة المساعدة <code>EmailNormalized</code> تلقائياً ويُعاد حسابها.
</p>
