@model List<StrategyHouse.Domain.Entities.QuizQuestion>
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "الاختبار";
    var sessionId = ViewBag.SessionId as Guid?;
    var scope = ViewBag.Scope as string ?? "General";
    var deptCode = ViewBag.DeptCode as string;
    var payload = Model.Select(q => new {
        id = q.Id,
        text = q.QuestionAr,
        options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new List<string>()
    });
}

@if (!Model.Any())
{
    <div class="gac-card text-center">
        <h2>لا توجد أسئلة معتمدة بعد</h2>
        <p class="text-muted">لم يعتمد المشرف أي أسئلة في هذا النطاق حتى الآن.</p>
        <a href="/" class="btn btn-outline-primary">العودة للرئيسية</a>
    </div>
}
else
{
    <div class="gac-card" style="max-width:720px;margin:0 auto;">
        <div class="progress mb-3" style="height:10px;">
            <div id="bar" class="progress-bar" role="progressbar" style="width:0%;background:#194F90;"></div>
        </div>
        <div id="quizArea"></div>
        <div id="resultArea" style="display:none;"></div>
    </div>
}

@section Scripts {
<script>
if (@(Model.Any() ? "true" : "false")) {
const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(payload));
const sessionId = @(sessionId != null ? $"\"{sessionId}\"" : "null");
const scope = "@scope";
const deptCode = @(deptCode != null ? $"\"{deptCode}\"" : "null");
const answers = new Array(questions.length).fill(-1);
let cur = 0;

const area = document.getElementById('quizArea');
const bar = document.getElementById('bar');

function render() {
    const q = questions[cur];
    bar.style.width = Math.round((cur) / questions.length * 100) + '%';
    let html = `<div class="small text-muted mb-2">سؤال ${cur + 1} من ${questions.length}</div>`;
    html += `<h4 class="mb-3">${q.text}</h4>`;
    q.options.forEach((opt, i) => {
        const checked = answers[cur] === i ? 'checked' : '';
        html += `<div class="form-check mb-2 p-2 border rounded">
            <input class="form-check-input" type="radio" name="opt" id="opt${i}" value="${i}" ${checked} onclick="pick(${i})">
            <label class="form-check-label w-100" for="opt${i}">${opt}</label></div>`;
    });
    html += `<div class="d-flex justify-content-between mt-3">`;
    html += cur > 0 ? `<button class="btn btn-outline-secondary" onclick="prev()">السابق</button>` : `<span></span>`;
    html += cur < questions.length - 1
        ? `<button class="btn gac-btn-primary text-white" onclick="next()">التالي</button>`
        : `<button class="btn btn-success" onclick="submit()">إنهاء وإظهار النتيجة</button>`;
    html += `</div>`;
    area.innerHTML = html;
}
function pick(i) { answers[cur] = i; }
function next() { if (cur < questions.length - 1) { cur++; render(); } }
function prev() { if (cur > 0) { cur--; render(); } }

async function submit() {
    const payload = {
        sessionId, scope, deptCode,
        answers: questions.map((q, i) => ({ qid: q.id, picked: answers[i] }))
    };
    const res = await fetch('/Quiz/Submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await res.json();
    bar.style.width = '100%';
    area.style.display = 'none';
    const r = document.getElementById('resultArea');
    r.style.display = 'block';
    let html = `<div class="text-center mb-4"><h2>نتيجتك</h2>
        <div style="font-size:3rem;font-weight:800;color:#194F90;">${data.score} / ${data.total}</div></div>`;
    data.detail.forEach((d, i) => {
        const q = questions.find(x => x.id === d.qid);
        const picked = d.picked >= 0 ? q.options[d.picked] : '— لم تتم الإجابة —';
        const correct = q.options[d.correctIndex];
        html += `<div class="mb-3 p-2 border rounded ${d.correct ? 'border-success' : 'border-danger'}">
            <div class="fw-bold">${q.text}</div>
            <div class="small">إجابتك: ${picked} ${d.correct ? '✓' : '✗'}</div>
            ${d.correct ? '' : `<div class="small text-success">الصحيح: ${correct}</div>`}
            ${d.explanation ? `<div class="small text-muted">${d.explanation}</div>` : ''}</div>`;
    });
    html += `<div class="text-center"><button class="btn btn-outline-primary" onclick="location.reload()">إعادة المحاولة</button></div>`;
    r.innerHTML = html;
}
render();
}
</script>
}
