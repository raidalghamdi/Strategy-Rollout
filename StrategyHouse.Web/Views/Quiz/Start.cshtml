@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "اختبار الاستراتيجية";
    var sessionId = ViewBag.SessionId as Guid?;
    var deptCode = ViewBag.DeptCode as string;
    bool hasDept = ViewBag.HasDeptQuestions ?? false;
}

<div class="gac-card" style="max-width:640px;margin:0 auto;text-align:center;">
    <h1>اختبار معرفة الاستراتيجية</h1>
    <p class="text-muted">10 أسئلة عشوائية. لا يوجد وقت محدد. ستظهر النتيجة والإجابات الصحيحة في النهاية.</p>

    <form method="get" asp-action="Play">
        @if (sessionId != null)
        {
            <input type="hidden" name="sessionId" value="@sessionId" />
            <div class="mb-3">
                <label class="form-label fw-bold">اختر النطاق</label>
                <select name="scope" class="form-select">
                    <option value="General">عام (الاستراتيجية المؤسسية)</option>
                    @if (hasDept)
                    {
                        <option value="Department">إدارتي (@deptCode)</option>
                    }
                </select>
            </div>
        }
        else
        {
            <input type="hidden" name="scope" value="General" />
            <p class="badge bg-info text-dark">النطاق: عام</p>
        }
        <button type="submit" class="btn gac-btn-primary text-white btn-lg">ابدأ الاختبار</button>
    </form>
</div>
