@model List<StrategyHouse.Domain.Entities.QuizQuestion>
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "اختبار الاستراتيجية";
    var sessionId = ViewBag.SessionId as Guid?;
    var scope = ViewBag.Scope as string ?? "General";
    var deptCode = ViewBag.DeptCode as string;
    var payload = Model.Select(q => new {
        id = q.Id,
        text = q.QuestionAr,
        options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new List<string>()
    });
}

@if (!Model.Any())
{
    <div class="quiz-card quiz-card--empty">
        <h2>لا توجد أسئلة معتمدة بعد</h2>
        <p class="quiz-muted">سيتم إضافة الأسئلة قريباً.</p>
        <a href="/" class="quiz-btn quiz-btn--ghost">العودة للرئيسية</a>
    </div>
}
else
{
    <div class="quiz-card">
        <h1 class="quiz-title">اختبار معرفة الاستراتيجية</h1>
        <div class="quiz-progress"><div id="bar" class="quiz-progress__fill" style="width:0%"></div></div>
        <div id="quizArea"></div>
        <div id="resultArea" style="display:none;"></div>
    </div>
}

@section Scripts {
<script>
if (@(Model.Any() ? "true" : "false")) {
const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(payload));
const sessionId = @(sessionId != null ? $"\"{sessionId}\"" : "null");
const scope = "@scope";
const deptCode = @(deptCode != null ? $"\"{deptCode}\"" : "null");
const answers = new Array(questions.length).fill(-1);
let cur = 0;

const area = document.getElementById('quizArea');
const bar = document.getElementById('bar');

function esc(s) {
    return String(s).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
}

function render() {
    const q = questions[cur];
    bar.style.width = Math.round((cur) / questions.length * 100) + '%';
    let html = `<div class="quiz-step">سؤال ${cur + 1} من ${questions.length}</div>`;
    html += `<h3 class="quiz-question">${esc(q.text)}</h3>`;
    html += `<div class="quiz-options">`;
    q.options.forEach((opt, i) => {
        const checked = answers[cur] === i ? 'checked' : '';
        const active = answers[cur] === i ? ' is-selected' : '';
        html += `<label class="quiz-option${active}">
            <input type="radio" name="opt" value="${i}" ${checked} onclick="pick(${i})">
            <span>${esc(opt)}</span></label>`;
    });
    html += `</div>`;
    html += `<div class="quiz-nav">`;
    html += cur > 0 ? `<button class="quiz-btn quiz-btn--ghost" onclick="prev()">السابق</button>` : `<span></span>`;
    html += cur < questions.length - 1
        ? `<button class="quiz-btn quiz-btn--primary" onclick="next()">التالي</button>`
        : `<button class="quiz-btn quiz-btn--primary" onclick="submit()">إرسال الإجابات</button>`;
    html += `</div>`;
    area.innerHTML = html;
}
function pick(i) { answers[cur] = i; render(); }
function next() { if (cur < questions.length - 1) { cur++; render(); } }
function prev() { if (cur > 0) { cur--; render(); } }

async function submit() {
    const body = {
        sessionId, scope, deptCode,
        answers: questions.map((q, i) => ({ qid: q.id, picked: answers[i] }))
    };
    const res = await fetch('/Quiz/Submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const data = await res.json();
    bar.style.width = '100%';
    area.style.display = 'none';
    const r = document.getElementById('resultArea');
    r.style.display = 'block';
    let html = `<div class="quiz-score"><div class="quiz-score__label">نتيجتك</div>
        <div class="quiz-score__value">${data.score} / ${data.total}</div></div>`;
    data.detail.forEach((d) => {
        const q = questions.find(x => x.id === d.qid);
        const picked = d.picked >= 0 ? esc(q.options[d.picked]) : '— لم تتم الإجابة —';
        const correct = esc(q.options[d.correctIndex]);
        html += `<div class="quiz-review ${d.correct ? 'is-correct' : 'is-wrong'}">
            <div class="quiz-review__q">${esc(q.text)}</div>
            <div class="quiz-review__a">إجابتك: ${picked} ${d.correct ? '✓' : '✗'}</div>
            ${d.correct ? '' : `<div class="quiz-review__correct">الصحيح: ${correct}</div>`}
            ${d.explanation ? `<div class="quiz-muted">${esc(d.explanation)}</div>` : ''}</div>`;
    });
    html += `<div class="quiz-nav quiz-nav--center"><button class="quiz-btn quiz-btn--ghost" onclick="location.reload()">إعادة المحاولة</button></div>`;
    r.innerHTML = html;
}
render();
}
</script>
}
