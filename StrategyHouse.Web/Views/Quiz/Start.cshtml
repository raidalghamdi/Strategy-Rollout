@model List<StrategyHouse.Domain.Entities.QuizQuestion>
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "اختبار الاستراتيجية";
    var sessionId = ViewBag.SessionId as Guid?;
    var scope = ViewBag.Scope as string ?? "General";
    var deptCode = ViewBag.DeptCode as string;
    var payload = Model.Select(q => new {
        id = q.Id,
        text = q.QuestionAr,
        options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new List<string>()
    }).ToList();
    var firstQ = payload.FirstOrDefault();
}

@if (!Model.Any())
{
    <div class="quiz-card quiz-card--empty">
        <h2>لا توجد أسئلة معتمدة بعد</h2>
        <p class="quiz-muted">سيتم إضافة الأسئلة قريباً.</p>
        <a href="/" class="quiz-btn quiz-btn--ghost">العودة للرئيسية</a>
    </div>
}
else
{
    @* Phase 19.12 — Quiz reliability fix. Three changes to address repeated reports
       that the quiz "doesn't work":

       1. Server-side render the FIRST question into #quizArea so the page is never
          blank if JS is still loading. Subsequent questions are re-rendered by JS.
       2. Move the quiz script INLINE inside the quiz-card (not in @@section Scripts
          at the bottom of body). This makes it run BEFORE the CDN scripts
          (bootstrap/d3/konva) so a slow/failed CDN can no longer delay or block
          the quiz boot.
       3. Add a visible status line under the progress bar that says "جارٍ التحميل…"
          on render and is cleared once JS boots — so the user always knows whether
          something is happening. *@
    <div class="quiz-card">
        <h1 class="quiz-title">اختبار معرفة الاستراتيجية</h1>
        <div class="quiz-progress"><div id="bar" class="quiz-progress__fill" style="width:0%"></div></div>
        <div id="quizStatus" class="text-muted small mt-2" style="min-height:1.2em;">جارٍ التحميل…</div>
        <div id="quizArea">
            @* SSR fallback: first question rendered server-side so the page is
               never visually empty even if JS hasn't booted yet. *@
            <noscript>
                <div class="alert alert-warning">يتطلب الاختبار تشغيل JavaScript في المتصفح. فعّل JavaScript وحدّث الصفحة.</div>
            </noscript>
            @if (firstQ != null)
            {
                <div class="quiz-step">سؤال 1 من @payload.Count</div>
                <h3 class="quiz-question">@firstQ.text</h3>
                <div class="quiz-options">
                    @for (int i = 0; i < firstQ.options.Count; i++)
                    {
                        <label class="quiz-option">
                            <input type="radio" name="opt" value="@i" disabled />
                            <span>@firstQ.options[i]</span>
                        </label>
                    }
                </div>
                <div class="quiz-nav sticky-bottom-cta">
                    <span></span>
                    <button type="button" class="quiz-btn quiz-btn--primary" disabled>جارٍ التحميل…</button>
                </div>
            }
        </div>
        <div id="resultArea" style="display:none;"></div>
    </div>

    @* INLINE script — runs immediately as the parser reaches it, BEFORE the
       CDN scripts at the bottom of _JourneyLayout. This is the key reliability
       fix: the quiz no longer depends on bootstrap/d3/konva downloading first. *@
    <script>
    (function () {
        var questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(payload));
        var sessionId = @(sessionId != null ? $"\"{sessionId}\"" : "null");
        var scope = "@scope";
        var deptCode = @(deptCode != null ? $"\"{deptCode}\"" : "null");
        var answers = new Array(questions.length);
        for (var k = 0; k < questions.length; k++) answers[k] = -1;
        var cur = 0;

        function $(id) { return document.getElementById(id); }
        function esc(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
                return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
            });
        }

        function setStatus(t) { var s = $('quizStatus'); if (s) s.textContent = t || ''; }

        function render() {
            var area = $('quizArea');
            var bar = $('bar');
            if (!area) { setStatus('تعذّر العثور على منطقة الأسئلة'); return; }
            if (!questions || questions.length === 0) {
                area.innerHTML = '<div class="alert alert-warning">لا توجد أسئلة متاحة الآن.</div>';
                setStatus('');
                return;
            }
            var q = questions[cur];
            if (bar) bar.style.width = Math.round((cur) / questions.length * 100) + '%';
            var html = '';
            html += '<div class="quiz-step">سؤال ' + (cur + 1) + ' من ' + questions.length + '</div>';
            html += '<h3 class="quiz-question">' + esc(q.text) + '</h3>';
            html += '<div class="quiz-options">';
            for (var i = 0; i < q.options.length; i++) {
                var checkedAttr = answers[cur] === i ? 'checked' : '';
                var activeCls = answers[cur] === i ? ' is-selected' : '';
                html += '<label class="quiz-option' + activeCls + '">'
                     + '<input type="radio" name="opt" value="' + i + '" ' + checkedAttr + ' onclick="quizPick(' + i + ')">'
                     + '<span>' + esc(q.options[i]) + '</span></label>';
            }
            html += '</div>';
            html += '<div class="quiz-nav sticky-bottom-cta">';
            html += cur > 0
                ? '<button type="button" class="quiz-btn quiz-btn--ghost" onclick="quizPrev()">السابق</button>'
                : '<span></span>';
            html += cur < questions.length - 1
                ? '<button type="button" class="quiz-btn quiz-btn--primary" onclick="quizNext()">التالي</button>'
                : '<button type="button" class="quiz-btn quiz-btn--primary" onclick="quizSubmit()">إرسال الإجابات</button>';
            html += '</div>';
            area.innerHTML = html;
            setStatus('');
        }

        function pick(i) { answers[cur] = i; render(); }
        function next() { if (cur < questions.length - 1) { cur++; render(); } }
        function prev() { if (cur > 0) { cur--; render(); } }

        function submit() {
            setStatus('جارٍ إرسال الإجابات…');
            var body = {
                sessionId: sessionId,
                scope: scope,
                deptCode: deptCode,
                answers: questions.map(function (q, i) { return { qid: q.id, picked: answers[i] }; })
            };
            fetch('/Quiz/Submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            }).then(function (res) { return res.json(); }).then(function (data) {
                var bar = $('bar'); if (bar) bar.style.width = '100%';
                var area = $('quizArea'); if (area) area.style.display = 'none';
                var r = $('resultArea'); if (!r) return;
                r.style.display = 'block';
                var html = '<div class="quiz-score"><div class="quiz-score__label">نتيجتك</div>'
                         + '<div class="quiz-score__value">' + data.score + ' / ' + data.total + '</div></div>';
                for (var i = 0; i < data.detail.length; i++) {
                    var d = data.detail[i];
                    var q = null;
                    for (var j = 0; j < questions.length; j++) { if (questions[j].id === d.qid) { q = questions[j]; break; } }
                    if (!q) continue;
                    var picked = d.picked >= 0 ? esc(q.options[d.picked]) : '— لم تتم الإجابة —';
                    var correct = esc(q.options[d.correctIndex]);
                    html += '<div class="quiz-review ' + (d.correct ? 'is-correct' : 'is-wrong') + '">'
                          + '<div class="quiz-review__q">' + esc(q.text) + '</div>'
                          + '<div class="quiz-review__a">إجابتك: ' + picked + ' ' + (d.correct ? '✓' : '✗') + '</div>'
                          + (d.correct ? '' : '<div class="quiz-review__correct">الصحيح: ' + correct + '</div>')
                          + (d.explanation ? '<div class="quiz-muted">' + esc(d.explanation) + '</div>' : '')
                          + '</div>';
                }
                html += '<div class="quiz-nav quiz-nav--center"><button type="button" class="quiz-btn quiz-btn--ghost" onclick="location.reload()">إعادة المحاولة</button></div>';
                r.innerHTML = html;
                setStatus('');
            }).catch(function (err) {
                setStatus('');
                var area = $('quizArea');
                if (area) area.innerHTML = '<div class="alert alert-danger">تعذّر إرسال الإجابات. حاول مرة أخرى.</div>';
            });
        }

        // Expose to global scope so iOS Safari inline onclick can resolve them.
        window.quizPick = pick;
        window.quizNext = next;
        window.quizPrev = prev;
        window.quizSubmit = submit;

        function boot() {
            try {
                render();
            } catch (e) {
                setStatus('');
                var a = $('quizArea');
                if (a) a.innerHTML = '<div class="alert alert-danger">تعذّر تحميل الاختبار: ' + esc(String(e)) + '. حدّث الصفحة.</div>';
            }
        }

        // Phase 19.13 — call boot() unconditionally. The script tag sits right
        // after the quiz-card markup in the DOM, so document.getElementById will
        // find the elements at parse time. Waiting for DOMContentLoaded turned
        // out to be a trap: on iOS Safari that event is held back until ALL the
        // CDN <script src> tags later in the body have loaded (bootstrap/d3/d3-sankey/konva
        // — together ~600KB). On a flaky network or CDN hiccup the quiz never
        // booted. Running boot() right here, before the parser even sees the
        // CDN scripts, makes the quiz independent of them.
        boot();
    })();
    </script>
}
