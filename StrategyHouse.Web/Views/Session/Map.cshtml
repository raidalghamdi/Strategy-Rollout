@using StrategyHouse.Domain.Entities
@using StrategyHouse.Domain.Enums
@model StrategyMap
@{
    ViewData["Title"] = "الخريطة الاستراتيجية للإدارة";
    var session = (Session)ViewBag.Session;
    var dept = (Department)ViewBag.Department;
    var map = (StrategyMap)ViewBag.Map;
    var framework = session.Framework!;
    var layers = framework.Layers.OrderBy(l => l.Order).ToList();
}

@section Styles {
    <style>
        .map-header { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:12px; }
        .live-chip { background: var(--accent-green); color:#fff; padding:4px 10px; border-radius:999px; font-size:12px; font-weight:600; }
        .live-chip.off { background: var(--text-muted); }
    </style>
}

<div class="map-header">
    <div>
        <h1>@dept.NameAr — الخريطة الاستراتيجية</h1>
        <p class="muted">جلسة: @session.TitleAr · رمز: @session.AccessCode · <span id="liveStatus" class="live-chip off">غير متصل</span></p>
    </div>
    <div class="row">
        <a class="btn btn--primary" href="/Session/Commit?code=@session.AccessCode&departmentId=@dept.Id">المتابعة إلى الالتزامات →</a>
    </div>
</div>

<div class="alert alert--info">
    <strong>الحركة الثانية (٤٠ دقيقة) — البناء الجماعي:</strong>
    اسحبوا مشاريع وأهداف الإدارة وأدوارها على الركائز والأهداف المناسبة من بيت الاستراتيجية. المُيسّر يقود النقاش، الجميع يبني.
</div>

<div class="canvas-wrap">
    <aside class="palette">
        <h3>عناصر الإدارة</h3>

        <div class="palette__section">
            <h4>المشاريع</h4>
            @foreach (var p in dept.Projects)
            {
                <div class="palette-item" draggable="true" data-kind="project" data-id="@p.Id">@p.NameAr</div>
            }
            @if (!dept.Projects.Any()) { <p class="muted">لا توجد مشاريع — يمكن إضافتها من لوحة الإدارة.</p> }
        </div>

        <div class="palette__section">
            <h4>المؤشرات</h4>
            @foreach (var k in dept.Kpis)
            {
                <div class="palette-item" draggable="true" data-kind="kpi" data-id="@k.Id">@k.NameAr</div>
            }
            @if (!dept.Kpis.Any()) { <p class="muted">لا توجد مؤشرات.</p> }
        </div>

        <div class="palette__section">
            <h4>الأدوار</h4>
            @foreach (var r in dept.Roles)
            {
                <div class="palette-item" draggable="true" data-kind="role" data-id="@r.Id">@r.TitleAr</div>
            }
            @if (!dept.Roles.Any()) { <p class="muted">لا توجد أدوار.</p> }
        </div>

        <div class="palette__section">
            <h4>إضافة عنصر مخصص</h4>
            <input id="customLabel" type="text" class="input" placeholder="اسم العنصر..." />
            <p class="hint">اكتب اسماً ثم اسحب من هذه النقطة.</p>
            <div class="palette-item" draggable="true" data-kind="custom" id="customDrag">⊕ سحب العنصر المخصص</div>
        </div>
    </aside>

    <section class="canvas" id="canvas" data-map-id="@map.Id" data-session-id="@session.Id">
        @foreach (var layer in layers)
        {
            <div class="canvas__layer-group">
                <div class="canvas__layer-title">@layer.NameAr</div>
                <div class="canvas__elements">
                    @foreach (var el in layer.Elements.OrderBy(e => e.Order))
                    {
                        var placedHere = map.Placements.Where(p => p.FrameworkElementId == el.Id).ToList();
                        <div class="canvas__layer element-card @(placedHere.Any() ? "has-items" : "")" data-element-id="@el.Id" style="@(el.ColorHex != null ? $"border-color:{el.ColorHex};" : "")">
                            <div style="font-weight:700; margin-bottom:6px;">@el.NameAr</div>
                            @if (!string.IsNullOrEmpty(el.DescriptionAr))
                            {
                                <div style="font-size:11px; color: var(--text-muted);">@el.DescriptionAr</div>
                            }
                            <div class="element-card__items">
                                @foreach (var p in placedHere)
                                {
                                    var label = p.PlacementKind switch
                                    {
                                        "project" => p.Project?.NameAr ?? "—",
                                        "kpi" => p.Kpi?.NameAr ?? "—",
                                        "role" => p.Role?.TitleAr ?? "—",
                                        _ => p.CustomLabelAr ?? "—"
                                    };
                                    <span class="placed-item" data-placement-id="@p.Id">@label <button type="button" onclick="removePlacement(@p.Id, this)">×</button></span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/map-canvas.js" asp-append-version="true"></script>
}
