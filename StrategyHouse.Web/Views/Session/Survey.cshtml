@using StrategyHouse.Domain.Entities
@using StrategyHouse.Domain.Enums
@model Survey
@{
    ViewData["Title"] = "استبيان نهاية الجلسة";
    var session = (Session)ViewBag.Session;
}

<div class="container--narrow">
    <div class="card">
        <h1>@Model.NameAr</h1>
        @if (!string.IsNullOrEmpty(Model.IntroAr)) { <p class="muted">@Model.IntroAr</p> }

        <form method="post" action="/Session/Survey">
            @Html.AntiForgeryToken()
            <input type="hidden" name="code" value="@session.AccessCode" />
            <input type="hidden" name="surveyId" value="@Model.Id" />

            @foreach (var q in Model.Questions.OrderBy(q => q.Order))
            {
                <div class="form-row">
                    <label>@q.Order. @q.TextAr @(q.IsRequired ? "*" : "")</label>
                    @switch (q.Type)
                    {
                        case SurveyQuestionType.Rating:
                            var min = q.MinValue ?? 1;
                            var max = q.MaxValue ?? 5;
                            <div class="row">
                                @for (int i = min; i <= max; i++)
                                {
                                    <label class="checkbox-row">
                                        <input type="radio" name="answers[@q.Id]" value="@i" @(q.IsRequired ? "required" : "") />
                                        <span>@i</span>
                                    </label>
                                }
                            </div>
                            break;
                        case SurveyQuestionType.SingleChoice:
                        case SurveyQuestionType.MultiChoice:
                            var opts = string.IsNullOrEmpty(q.OptionsJson) ? new List<string>() : System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson)!;
                            foreach (var opt in opts)
                            {
                                <label class="checkbox-row">
                                    <input type="@(q.Type == SurveyQuestionType.SingleChoice ? "radio" : "checkbox")" name="answers[@q.Id]" value="@opt" />
                                    <span>@opt</span>
                                </label>
                            }
                            break;
                        case SurveyQuestionType.OpenText:
                            <textarea name="answers[@q.Id]" class="textarea" placeholder="اكتب إجابتك..." @(q.IsRequired ? "required" : "")></textarea>
                            break;
                    }
                </div>
            }

            <button type="submit" class="btn btn--primary btn--block">إرسال الاستبيان</button>
        </form>
    </div>
</div>
