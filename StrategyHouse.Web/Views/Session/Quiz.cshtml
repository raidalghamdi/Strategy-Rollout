@using StrategyHouse.Domain.Entities
@using StrategyHouse.Domain.Enums
@model Quiz
@{
    ViewData["Title"] = "اختبار ما بعد الجلسة";
    var session = (Session)ViewBag.Session;
}

<div class="container--narrow">
    <div class="card">
        <h1>@Model.NameAr</h1>
        <p class="muted">@(Model.IntroAr ?? "اختبار قصير اختياري. النتائج تُجمَّع بشكل إجمالي ومجهول الهوية، لا تُعرض هوية أحد.")</p>

        <form method="post" action="/Session/Quiz">
            @Html.AntiForgeryToken()
            <input type="hidden" name="code" value="@session.AccessCode" />
            <input type="hidden" name="quizId" value="@Model.Id" />

            @{ int qIdx = 0; }
            @foreach (var q in Model.Questions.OrderBy(q => q.Order))
            {
                qIdx++;
                var opts = System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new();
                <div class="form-row">
                    <label>@qIdx. @q.TextAr</label>
                    @for (int i = 0; i < opts.Count; i++)
                    {
                        <label class="checkbox-row">
                            <input type="@(q.Type == QuizQuestionType.SingleChoice ? "radio" : "checkbox")"
                                   name="answers[@q.Id]" value="@i" />
                            <span>@opts[i]</span>
                        </label>
                    }
                </div>
            }

            <button type="submit" class="btn btn--primary btn--block">إرسال الإجابات</button>
        </form>
    </div>
</div>
