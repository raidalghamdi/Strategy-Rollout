@model List<StrategyHouse.Domain.Entities.MapInkAsset>
@{
    ViewData["Title"] = "مراجعة المحتوى";
    var status = ViewBag.Status as string ?? "Pending";
    var mapDept = ViewBag.MapDept as Dictionary<Guid, string> ?? new();
    var deptNames = ViewBag.DeptNames as Dictionary<string, string> ?? new();
    var depts = ViewBag.Depts as List<string> ?? new();
    var kinds = ViewBag.Kinds as List<string> ?? new();
    var statuses = new[] { "Pending", "Approved", "Rejected", "Hidden" };
    string KindAr(string k) => k switch
    {
        "opinion" => "رأي", "commitment" => "التزام", "signature" => "توقيع", _ => k
    };
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
}

<div class="container py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center">
        <h1 style="color:#28334A;">مراجعة المحتوى</h1>
        <div>
            <a class="btn btn-outline-secondary btn-sm" asp-action="AuditLog">سجل المراجعة</a>
            <a class="btn btn-outline-secondary btn-sm" href="/Admin">رجوع</a>
        </div>
    </div>

    <ul class="nav nav-pills my-3">
        @foreach (var s in statuses)
        {
            <li class="nav-item">
                <a class="nav-link @(s == status ? "active" : "")" asp-action="Index" asp-route-status="@s">@s (@(s == status ? Model.Count : 0))</a>
            </li>
        }
    </ul>

    @if (!Model.Any())
    {
        <div class="alert alert-info">لا توجد عناصر بحالة "@status".</div>
    }
    else
    {
        @if (status == "Pending")
        {
            <div class="card mb-3"><div class="card-body">
                <h6>إجراءات جماعية بالنطاق</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <form method="post" asp-action="BulkDept" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="@status" />
                            <select name="deptCode" class="form-select form-select-sm">
                                @foreach (var d in depts)
                                {
                                    <option value="@d">@(deptNames.TryGetValue(d!, out var n) ? n : d)</option>
                                }
                            </select>
                            <button name="action" value="Approve" class="btn btn-sm btn-success">قبول كل الإدارة</button>
                            <button name="action" value="Reject" class="btn btn-sm btn-danger">رفض</button>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <form method="post" asp-action="BulkKind" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="@status" />
                            <select name="kind" class="form-select form-select-sm">
                                @foreach (var k in kinds)
                                {
                                    <option value="@k">@KindAr(k)</option>
                                }
                            </select>
                            <button name="action" value="Approve" class="btn btn-sm btn-success">قبول كل النوع</button>
                            <button name="action" value="Reject" class="btn btn-sm btn-danger">رفض</button>
                        </form>
                    </div>
                </div>
            </div></div>
        }

        <form method="post" asp-action="Bulk">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" id="bulkAction" value="Approve" />
            <div class="mb-2">
                <button type="submit" onclick="document.getElementById('bulkAction').value='Approve'" class="btn btn-sm btn-success">قبول المحدد</button>
                <button type="submit" onclick="document.getElementById('bulkAction').value='Reject'" class="btn btn-sm btn-danger">رفض المحدد</button>
                <button type="submit" onclick="document.getElementById('bulkAction').value='Hide'" class="btn btn-sm btn-warning">إخفاء المحدد</button>
                @if (status is "Hidden" or "Rejected")
                {
                    <button type="submit" onclick="document.getElementById('bulkAction').value='Reactivate'" class="btn btn-sm btn-outline-success">إعادة تفعيل المحدد</button>
                }
            </div>
            <div class="row g-3">
                @foreach (var a in Model)
                {
                    var dcode = mapDept.TryGetValue(a.MapId, out var d) ? d : null;
                    <div class="col-md-3">
                        <div class="card h-100">
                            <img src="/Admin/Moderation/Thumb/@a.Id" class="card-img-top" style="height:120px;object-fit:contain;background:#f6f8fb;" />
                            <div class="card-body p-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="ids" value="@a.Id" />
                                    <label class="form-check-label small">تحديد</label>
                                </div>
                                <div><strong>@(dcode != null && deptNames.TryGetValue(dcode, out var dn) ? dn : dcode)</strong></div>
                                <div class="badge bg-info text-dark">@KindAr(a.AssetKind)</div>
                                <div class="small text-muted">@a.AuthorName</div>
                                <div class="small text-muted">@a.CapturedAt.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                            <div class="card-footer p-1 d-flex gap-1">
                                <button formaction="/Admin/Moderation/Approve/@a.Id" formmethod="post" class="btn btn-sm btn-success flex-fill">قبول</button>
                                <button formaction="/Admin/Moderation/Reject/@a.Id" formmethod="post" class="btn btn-sm btn-danger flex-fill">رفض</button>
                                @if (a.IsActive)
                                {
                                    <button formaction="/Admin/Moderation/Hide/@a.Id" formmethod="post" class="btn btn-sm btn-warning flex-fill">إخفاء</button>
                                }
                                else
                                {
                                    <button formaction="/Admin/Moderation/Reactivate/@a.Id" formmethod="post" class="btn btn-sm btn-outline-success flex-fill">تفعيل</button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </form>
    }
</div>
