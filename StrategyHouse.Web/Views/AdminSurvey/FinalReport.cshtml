@using StrategyHouse.Domain.Enums
@model StrategyHouse.Web.Models.FinalReportViewModel
@{
    ViewData["Title"] = "التقرير النهائي للاستبيان";
    string TypeAr(QuestionType t) => t switch
    {
        QuestionType.Likert5 => "مقياس ليكرت",
        QuestionType.MultipleChoice => "اختيار من متعدد",
        QuestionType.OpenText => "سؤال مفتوح",
        _ => ""
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
    <h1 class="mb-0">التقرير النهائي للاستبيان</h1>
    <div class="d-flex flex-wrap gap-2">
        <a href="/Admin/Survey/FinalReport.pdf" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل PDF</a>
        <a href="/Admin/Survey/FinalReport.pptx" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل PowerPoint</a>
        <a href="/Admin/Survey/FinalReport.xlsx" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;border-radius:999px;">تحميل Excel</a>
        <button type="button" id="btn-email-report" class="btn btn-sm" style="background:#fff;color:#00192B;font-weight:700;border-radius:999px;">إرسال بالبريد</button>
        <a href="/Admin/Survey/Analytics" class="btn btn--secondary btn-sm">⟶ التحليلات</a>
    </div>
</div>
<p class="muted">@Model.SurveyTitle</p>

@Html.AntiForgeryToken()

<div id="email-report-modal" style="display:none;position:fixed;inset:0;z-index:1080;background:rgba(0,25,43,0.55);">
    <div style="max-width:420px;margin:8% auto;background:#fff;border-radius:14px;padding:20px;direction:rtl;box-shadow:0 12px 40px rgba(0,0,0,0.3);">
        <h2 class="h5" style="color:#00192B;">إرسال التقرير بالبريد الإلكتروني</h2>
        <label class="form-label small" for="email-report-to">البريد الإلكتروني</label>
        <input type="email" id="email-report-to" class="form-control" placeholder="name@gac.gov.sa" />
        <label class="form-label small mt-2" for="email-report-format">صيغة الملف</label>
        <select id="email-report-format" class="form-select">
            <option value="pdf">PDF</option>
            <option value="pptx">PowerPoint</option>
            <option value="xlsx">Excel</option>
        </select>
        <div id="email-report-msg" class="small mt-2" style="display:none;"></div>
        <div class="d-flex gap-2 mt-3 justify-content-end">
            <button type="button" id="email-report-cancel" class="btn btn--secondary btn-sm">إلغاء</button>
            <button type="button" id="email-report-submit" class="btn btn-sm" style="background:#FAC126;color:#00192B;font-weight:700;">إرسال</button>
        </div>
    </div>
</div>

<div class="card mb-3">
    <h2 class="h5">الملخص التنفيذي</h2>
    <div class="grid-3 my-2">
        <div class="card"><h3>@Model.TotalResponses</h3><p class="muted small">إجمالي الردود</p></div>
        <div class="card"><h3>@Model.Cards.Count</h3><p class="muted small">عدد الأسئلة</p></div>
        <div class="card">
            <h3 style="font-size:1rem;">@(Model.DateFrom != null ? $"{Model.DateFrom:yyyy-MM-dd} ← {Model.DateTo:yyyy-MM-dd}" : "—")</h3>
            <p class="muted small">فترة الجمع</p>
        </div>
    </div>
    @if (Model.Takeaways.Any())
    {
        <h3 class="h6 text-warning">أبرز النتائج</h3>
        <ul>
            @foreach (var t in Model.Takeaways) { <li>@t</li> }
        </ul>
    }
</div>

@foreach (var c in Model.Cards.OrderBy(x => x.Order))
{
    <div class="card mb-3">
        <h2 class="h6">السؤال @c.Order: @c.QuestionAr</h2>
        <p class="muted small">النوع: @TypeAr(c.Type) · المقياس: @c.Metric</p>

        @if (c.Type == QuestionType.Likert5 && c.Likert != null)
        {
            <p class="fw-bold text-success">المتوسط: @c.Likert.Mean.ToString("0.##") / 5 · نسبة العالية (4-5): @c.Likert.PctHigh.ToString("0.#")% · العدد: @c.Likert.Total</p>
            <div class="chart-wrap" style="height:160px;"><canvas id="rep-@c.Order"></canvas></div>
        }
        else if (c.Type == QuestionType.MultipleChoice && c.Choices != null)
        {
            <div class="chart-wrap" style="height:200px;"><canvas id="rep-@c.Order"></canvas></div>
        }
        else if (c.Type == QuestionType.OpenText && c.OpenText != null)
        {
            <p class="fw-bold text-success">إجمالي: @c.OpenText.TotalResponses · غير مصنّف: @c.OpenText.UncategorizedCount</p>
            @if (c.OpenText.Categories.Any())
            {
                <div class="chart-wrap" style="height:200px;"><canvas id="rep-@c.Order"></canvas></div>
            }
        }

        @if (Model.Interpretations.TryGetValue(c.QuestionId, out var interp))
        {
            <p class="muted small fst-italic">التفسير: @interp</p>
        }
    </div>
}

@if (Model.Insights.Any())
{
    <div class="card mb-3">
        <h2 class="h5">رؤى شاملة</h2>
        <ul>
            @foreach (var ins in Model.Insights) { <li>@ins</li> }
        </ul>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function () {
    var openBtn = document.getElementById('btn-email-report');
    var modal = document.getElementById('email-report-modal');
    var cancelBtn = document.getElementById('email-report-cancel');
    var submitBtn = document.getElementById('email-report-submit');
    var msg = document.getElementById('email-report-msg');
    if (!openBtn || !modal) { return; }

    function showMsg(text, ok) {
        msg.style.display = 'block';
        msg.textContent = text;
        msg.style.color = ok ? '#009845' : '#C0392B';
    }
    function openModal() { modal.style.display = 'block'; msg.style.display = 'none'; }
    function closeModal() { modal.style.display = 'none'; }

    openBtn.onclick = openModal;
    cancelBtn.onclick = closeModal;
    modal.onclick = function (e) { if (e.target === modal) { closeModal(); } };

    submitBtn.onclick = function () {
        var email = document.getElementById('email-report-to').value;
        var format = document.getElementById('email-report-format').value;
        if (!email || email.indexOf('@@') === -1) {
            showMsg('يرجى إدخال بريد إلكتروني صحيح.', false);
            return;
        }
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenEl ? tokenEl.value : '';
        submitBtn.disabled = true;
        showMsg('جارٍ الإرسال...', true);
        var data = 'email=' + encodeURIComponent(email) + '&format=' + encodeURIComponent(format);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/Admin/Survey/FinalReport/Email', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('RequestVerificationToken', token);
        xhr.onreadystatechange = function () {
            if (xhr.readyState !== 4) { return; }
            submitBtn.disabled = false;
            var ok = false, message = 'تعذّر الإرسال.';
            try {
                var res = JSON.parse(xhr.responseText);
                ok = !!res.success;
                message = res.message || message;
            } catch (err) { message = 'تعذّر الاتصال بالخادم.'; }
            showMsg(message, ok);
        };
        xhr.send(data);
    };
})();
</script>
<script>
(function () {
    if (typeof Chart === 'undefined') return;
    var cards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Cards.Select(c => new {
            order = c.Order,
            type = (int)c.Type,
            likert = c.Likert == null ? null : c.Likert.Distribution,
            choices = c.Choices == null ? null : c.Choices.Select(x => new { label = x.ChoiceText, count = x.Count }),
            cats = c.OpenText == null ? null : c.OpenText.Categories.Select(x => new { label = x.Category, count = x.Count })
        })));
    var palette = ['#194F90','#46BCCD','#009845','#FAC126','#9B59B6','#E67E22','#1ABC9C','#E74C3C'];
    cards.forEach(function (c) {
        var el = document.getElementById('rep-' + c.order);
        if (!el) return;
        if (c.type === 1 && c.likert) {
            new Chart(el, { type: 'bar', data: { labels: ['1','2','3','4','5'], datasets: [{ data: c.likert, backgroundColor: '#194F90' }] }, options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, ticks: { precision: 0 } } } } });
        } else if (c.type === 2 && c.choices) {
            new Chart(el, { type: 'bar', data: { labels: c.choices.map(x => x.label), datasets: [{ data: c.choices.map(x => x.count), backgroundColor: '#009845' }] }, options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, ticks: { precision: 0 } } } } });
        } else if (c.type === 3 && c.cats && c.cats.length) {
            new Chart(el, { type: 'doughnut', data: { labels: c.cats.map(x => x.label), datasets: [{ data: c.cats.map(x => x.count), backgroundColor: palette }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } } });
        }
    });
})();
</script>
}
