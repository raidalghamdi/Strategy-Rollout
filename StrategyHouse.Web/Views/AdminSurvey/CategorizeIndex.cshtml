@model List<StrategyHouse.Web.Models.OpenTextQuestionLink>
@{
    ViewData["Title"] = "تصنيف إجابات الاستبيان";
}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1 class="mb-0">تصنيف إجابات الاستبيان</h1>
    <div class="d-flex gap-2 flex-wrap">
        <form method="post" action="/Admin/Survey/Categorize/AutoAll" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn--primary btn-sm" title="تصنيف تلقائي حسب المحاور الرسمية">⚡ تصنيف تلقائي للكل</button>
        </form>
        <a href="/Admin/Survey/Analytics" class="btn btn--secondary btn-sm">⟶ التحليلات</a>
    </div>
</div>
<p class="muted">اختر سؤالاً مفتوحاً لتصنيف إجاباته يدويًا، أو اضغط زر «تصنيف تلقائي» لتطبيق المحاور الرسمية من ورقة الآلية (سـ 4 التحديات، سـ 5 القيم، سـ 7 التطلعات).</p>
@if (TempData["SurveyMsg"] is string msg)
{
    <div class="card mb-2" style="border-color:#1f8a4c;background:#e9f6ec;color:#0c4d20"><strong>@msg</strong></div>
}

@if (!Model.Any())
{
    <div class="card"><p class="muted">لا توجد أسئلة مفتوحة.</p></div>
}
else
{
    <div class="row g-3">
        @foreach (var q in Model)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <h2 class="h6">السؤال @q.Order</h2>
                    <p>@q.QuestionAr</p>
                    @* Phase 20.33 (Comment 12) — show blank vs uncategorized *@
                    <p class="muted small">
                        إجمالي: @q.Total ·
                        غير مصنّف: @q.Uncategorized
                        @if (q.BlankCount > 0) { <span> · فارغ: @q.BlankCount</span> }
                    </p>
                    <a href="/Admin/Survey/Categorize/@q.QuestionId" class="btn btn--primary btn-sm">فتح التصنيف</a>
                </div>
            </div>
        }
    </div>
}
