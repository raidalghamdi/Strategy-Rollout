@model List<StrategyHouse.Domain.Entities.Initiative>
@{ ViewData["Title"] = "المبادرات"; }
<h1>المبادرات (@Model.Count)</h1>
<div class="table-responsive">
<table class="table">
    <thead>
        <tr><th>الرمز</th><th>الاسم</th><th>الهدف</th><th>المالك</th><th>الميزانية</th></tr>
    </thead>
    <tbody>
    @foreach (var i in Model)
    {
        <tr>
            <td>@i.InitiativeCode</td>
            <td>@i.InitiativeName</td>
            <td>@i.ObjectiveCode</td>
            <td>@i.Owners</td>
            <td>@i.Budget?.ToString("N0")</td>
        </tr>
    }
    </tbody>
</table>
</div>
