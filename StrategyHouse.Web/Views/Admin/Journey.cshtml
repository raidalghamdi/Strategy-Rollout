@using StrategyHouse.Web.Services
@model JourneyMapBrief
@{ ViewData["Title"] = $"خريطة رحلة رئيس الإدارة — {Model.DepartmentName}"; }

<h1>خريطة رحلة رئيس الإدارة</h1>
<p class="muted">@Model.SessionTitle · @Model.DepartmentName · @Model.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</p>

<div class="journey">
    <h3>الخط الزمني (٩٠ دقيقة)</h3>
    @foreach (var b in Model.Blocks)
    {
        <div class="journey-block @(b.IsHeadSpeakingMoment ? "journey-block--head" : "")">
            <div class="journey-block__time">@b.FromMin'–@b.ToMin' دقيقة @(b.IsHeadSpeakingMoment ? "· لحظة كلامية للرئيس 🎙" : "")</div>
            <div class="journey-block__title">@b.Title</div>
            <div class="journey-block__guide">@b.Guidance</div>
        </div>
    }

    <h3 class="mt-3">ملاحظات للراعي</h3>
    <ul>
        @foreach (var n in Model.Notes) { <li>@n</li> }
    </ul>
</div>

<div class="row mt-3">
    <a href="javascript:window.print()" class="btn btn--secondary">طباعة هذه الوثيقة</a>
</div>
