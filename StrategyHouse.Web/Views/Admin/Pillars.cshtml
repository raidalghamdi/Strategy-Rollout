@model List<StrategyHouse.Domain.Entities.Pillar>
@{ ViewData["Title"] = "الركائز"; }
<h1>الركائز (@Model.Count)</h1>
<table class="table">
    <thead>
        <tr><th>الرمز</th><th>الاسم</th><th>الميزانية</th><th>السيولة</th><th>الفترة</th></tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.PlrCode</td>
            <td>@p.PillarName</td>
            <td>@p.Budget?.ToString("N0")</td>
            <td>@p.Liquidity?.ToString("N0")</td>
            <td>@p.PlrPeriods</td>
        </tr>
    }
    </tbody>
</table>
