@using StrategyHouse.Domain.Entities
@model Session
@{ ViewData["Title"] = Model.TitleAr; }

<h1>@Model.TitleAr</h1>
<p class="muted">رمز: <strong>@Model.AccessCode</strong> · الموعد: @Model.ScheduledAt.ToString("yyyy-MM-dd HH:mm") · المكان: @(Model.VenueAr ?? "—")</p>

<div class="row mb-2">
    <a href="/Session/Console?code=@Model.AccessCode" class="btn btn--primary">فتح طاولة الجلسة</a>
    <a href="/Wall?code=@Model.AccessCode" class="btn btn--secondary">جدار الجلسة</a>
</div>

<div class="card">
    <h3>الإدارات المشاركة</h3>
    <div class="commitments">
        @foreach (var sd in Model.SessionDepartments)
        {
            <div class="commitment-card">
                <div class="commitment-card__text">@sd.Department!.NameAr</div>
                <a href="/Admin/Journey?sessionId=@Model.Id&departmentId=@sd.DepartmentId" class="btn btn--sm btn--secondary mt-1">خريطة رحلة رئيس الإدارة</a>
            </div>
        }
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3>الحضور (@Model.Attendees.Count)</h3>
        <table class="table">
            <thead><tr><th>الاسم</th><th>الإدارة</th><th>دور</th></tr></thead>
            <tbody>
                @foreach (var a in Model.Attendees)
                {
                    <tr>
                        <td>@a.FullNameAr</td>
                        <td>@(a.Department?.NameAr ?? "")</td>
                        <td>@(a.IsDepartmentHead ? "رئيس إدارة" : "موظف") · @(a.Attended ? "حضر" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>

        <form method="post" action="/Admin/AddAttendee" class="mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sessionId" value="@Model.Id" />
            <select name="departmentId" class="select" required>
                @foreach (var sd in Model.SessionDepartments) { <option value="@sd.DepartmentId">@sd.Department!.NameAr</option> }
            </select>
            <input name="fullName" class="input mt-1" placeholder="الاسم الكامل" required />
            <input name="email" class="input mt-1" placeholder="البريد (اختياري)" type="email" />
            <label class="checkbox-row mt-1"><input type="checkbox" name="isHead" value="true" /> رئيس الإدارة</label>
            <button class="btn btn--secondary btn--sm mt-1" type="submit">+ إضافة حاضر</button>
        </form>
    </div>

    <div class="card">
        <h3>الخرائط الاستراتيجية المُكتملة (@Model.Maps.Count(m => m.IsFinalized))</h3>
        <ul style="list-style:none; padding:0;">
            @foreach (var m in Model.Maps)
            {
                <li class="mt-1">
                    <strong>@m.Department!.NameAr</strong>
                    @if (m.IsFinalized) { <span class="badge badge--green">مُثبَّتة</span> }
                    else { <span class="badge badge--orange">قيد البناء</span> }
                </li>
            }
        </ul>
    </div>
</div>
