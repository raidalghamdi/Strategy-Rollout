@using StrategyHouse.Domain.Entities
@{
    ViewData["Title"] = "إنشاء جلسة";
    var frameworks = (List<Framework>)ViewBag.Frameworks;
    var depts = (List<Department>)ViewBag.Departments;
}

<h1>إنشاء جلسة جديدة</h1>

<form method="post" action="/Admin/CreateSession" class="card">
    @Html.AntiForgeryToken()
    <div class="form-row">
        <label>الإطار</label>
        <select name="frameworkId" class="select" required>
            @foreach (var f in frameworks) { <option value="@f.Id">@f.NameAr</option> }
        </select>
    </div>
    <div class="form-row">
        <label>العنوان</label>
        <input name="title" class="input" placeholder="مثال: جلسة إدارة الموارد البشرية — يوم ٢" required />
    </div>
    <div class="grid-2">
        <div class="form-row">
            <label>الموعد</label>
            <input name="scheduledAt" type="datetime-local" class="input" required />
        </div>
        <div class="form-row">
            <label>المكان</label>
            <input name="venue" class="input" placeholder="مثال: قاعة C-3" />
        </div>
    </div>
    <div class="form-row">
        <label>الإدارات المشاركة</label>
        <div class="commitments">
            @foreach (var d in depts)
            {
                <label class="commitment-card">
                    <input type="checkbox" name="departmentIds" value="@d.Id" />
                    <span class="commitment-card__text">@d.NameAr</span>
                    <span class="commitment-card__hint">@d.Code</span>
                </label>
            }
        </div>
    </div>
    <button type="submit" class="btn btn--primary btn--lg">إنشاء الجلسة</button>
</form>
