@model StrategyHouse.Web.Controllers.AdminDashboardCounters
@{ ViewData["Title"] = "لوحة الإدارة"; }
<h1>لوحة الإدارة</h1>
<p class="muted">استعراض بيانات الاستراتيجية: الركائز، الأهداف، الإدارات، المبادرات، المشاريع، ومؤشرات الأداء.</p>

<div class="grid-3">
    <a href="/Admin/Pillars" class="card card--accent">
        <h3>الركائز</h3>
        <p class="muted">@Model.PillarCount ركائز استراتيجية بميزانياتها وفتراتها.</p>
    </a>
    <a href="/Admin/Objectives" class="card card--accent">
        <h3>الأهداف</h3>
        <p class="muted">@Model.ObjectiveCount هدفاً استراتيجياً مرتبطة بالركائز.</p>
    </a>
    <a href="/Admin/Departments" class="card card--accent">
        <h3>الإدارات</h3>
        <p class="muted">@Model.DepartmentCount إدارة من المستوى الثاني للهيكل التنظيمي.</p>
    </a>
    <a href="/Admin/Initiatives" class="card card--accent">
        <h3>المبادرات</h3>
        <p class="muted">@Model.InitiativeCount مبادرة موزعة على الأهداف.</p>
    </a>
    <a href="/Admin/Projects" class="card card--accent">
        <h3>المشاريع</h3>
        <p class="muted">@Model.ProjectCount مشروعاً (@Model.StrategicProjectCount استراتيجي / @Model.OperationalProjectCount تشغيلي).</p>
    </a>
    <a href="/Admin/Kpis" class="card card--accent">
        <h3>مؤشرات الأداء</h3>
        <p class="muted">@Model.KpiCount مؤشراً (@Model.StrategicKpiCount استراتيجي / @Model.OperationalKpiCount تشغيلي).</p>
    </a>
</div>

@if (User.IsInRole("Admin"))
{
    <h2 style="margin-top:2rem;">الإدارة المتقدمة</h2>
    <div class="grid-3">
        <a href="/Admin/Users" class="card card--accent">
            <h3>إدارة المستخدمين</h3>
            <p class="muted">إضافة وتعديل المستخدمين، إعادة تعيين كلمات المرور، وتعطيل الحسابات.</p>
        </a>
        <a href="/Admin/JourneyReset" class="card card--accent">
            <h3>إعادة تشغيل رحلة إدارة</h3>
            <p class="muted">إعادة ضبط مراحل مختارة لإدارة معيّنة مع تسجيل العملية في سجل التدقيق.</p>
        </a>
        <a href="/Admin/TestResults" class="card card--accent">
            <h3>حذف نتائج الاختبار</h3>
            <p class="muted">عرض وحذف جلسات مستخدم الاختبار (كاملة أو انتقائية).</p>
        </a>
        <a href="/Admin/AuditLog" class="card card--accent">
            <h3>سجل التدقيق</h3>
            <p class="muted">سجل كامل بكل العمليات الإدارية الحسّاسة مع إمكانية التصفية والتصدير.</p>
        </a>
    </div>
}

<h2 style="margin-top:2rem;">رحلة الاستراتيجية</h2>
<div class="grid-3">
    <a href="/Admin/LiveDashboard" class="card card--accent">
        <h3>اللوحة الحية</h3>
        <p class="muted">متابعة جلسات الإدارات لحظياً — المرحلة والنشاط والمشاركة.</p>
    </a>
    <a href="/Admin/Codes" class="card card--accent">
        <h3>رموز الدخول</h3>
        <p class="muted">إنشاء وإلغاء رموز دخول الإدارات وطباعة أوراق الـ QR.</p>
    </a>
    <a href="/Admin/JourneyCodes" class="card card--accent">
        <h3>إدارة رموز الرحلة</h3>
        <p class="muted">إضافة وتعديل وحذف رموز الرحلة (مثل GAC202) وربطها بالإدارات.</p>
    </a>
    <a href="/Admin/Wall" class="card card--accent">
        <h3>جدار الخرائط</h3>
        <p class="muted">عرض الخرائط الموقّعة وتنزيل ملفات الـ PDF.</p>
    </a>
    <a href="/Admin/Moderation" class="card card--accent">
        <h3>مراجعة المحتوى</h3>
        <p class="muted">مراجعة العناصر وسجل التدقيق (جاهز للمرحلة الثالثة).</p>
    </a>
</div>

<h2 style="margin-top:2rem;">التحليلات والتقييم</h2>
<div class="grid-3">
    <a href="/Admin/Insights" class="card card--accent">
        <h3>لوحة الرؤى</h3>
        <p class="muted">نظرة شاملة، خريطة التغطية، تحليل التعهدات، وملصق البرنامج.</p>
    </a>
    <a href="/Admin/StrategyReport" class="card card--accent">
        <h3>التقرير التنفيذي للبيانات</h3>
        <p class="muted">ملخص بيانات الاستراتيجية (المرتكزات والأهداف والمبادرات والمشاريع والمؤشرات) مع تصدير Excel.</p>
    </a>
    <a href="/Admin/Quiz" class="card card--accent">
        <h3>بنك الأسئلة</h3>
        <p class="muted">توليد واعتماد أسئلة الاختبار المعرفي.</p>
    </a>
    <a href="/Admin/Quiz/Analytics" class="card card--accent">
        <h3>تحليلات الاختبار</h3>
        <p class="muted">متوسط النتائج، نسبة الإجابة لكل سؤال، وتصدير CSV.</p>
    </a>
    <a href="/Admin/Surveys" class="card card--accent">
        <h3>الاستبيانات</h3>
        <p class="muted">إنشاء الاستبيانات، رموز QR، وتقارير النتائج.</p>
    </a>
    <a href="/Admin/Content" class="card card--accent">
        <h3>تحرير النصوص</h3>
        <p class="muted">تعديل نصوص الصفحات الظاهرة للمستخدمين فوراً.</p>
    </a>
    <a href="/Admin/ExternalData" class="card card--accent">
        <h3>قاعدة البيانات الخارجية</h3>
        <p class="muted">حالة الربط مع MSSQL (Option A)، عدد السجلات، وعيّنات من الجداول الخمسة.</p>
    </a>
    <a href="/Admin/DbImport" class="card card--accent">
        <h3>استيراد قاعدة البيانات من Excel</h3>
        <p class="muted">رفع ملف تصدير Excel ومزامنته بالكامل مع قاعدة البيانات (مع معاينة ونسخة احتياطية تلقائية).</p>
    </a>
    <a href="/Admin/DataSources" class="card card--accent">
        <h3>مصادر البيانات</h3>
        <p class="muted">المصدر الحالي لكل كيان (نسخة MSSQL ← SQLite ← لا توجد بيانات) وربط الإدارات بأقسام MSSQL.</p>
    </a>
</div>
