@{ ViewData["Title"] = "لوحة الإدارة"; }
<h1>لوحة الإدارة</h1>
<p class="muted">استعراض بيانات الاستراتيجية: الركائز، الأهداف، الإدارات، المبادرات، المشاريع، ومؤشرات الأداء.</p>

<div class="grid-3">
    <a href="/Admin/Pillars" class="card card--accent">
        <h3>الركائز</h3>
        <p class="muted">٥ ركائز استراتيجية بميزانياتها وفتراتها.</p>
    </a>
    <a href="/Admin/Objectives" class="card card--accent">
        <h3>الأهداف</h3>
        <p class="muted">١٣ هدفاً استراتيجياً مرتبطة بالركائز.</p>
    </a>
    <a href="/Admin/Departments" class="card card--accent">
        <h3>الإدارات</h3>
        <p class="muted">١٧ إدارة من المستوى الثاني للهيكل التنظيمي.</p>
    </a>
    <a href="/Admin/Initiatives" class="card card--accent">
        <h3>المبادرات</h3>
        <p class="muted">٢٣ مبادرة موزعة على الأهداف.</p>
    </a>
    <a href="/Admin/Projects" class="card card--accent">
        <h3>المشاريع</h3>
        <p class="muted">٢٢٠ مشروعاً (١١٠ استراتيجي / ١١٠ تشغيلي).</p>
    </a>
    <a href="/Admin/Kpis" class="card card--accent">
        <h3>مؤشرات الأداء</h3>
        <p class="muted">١٣٤ مؤشراً (١٤ استراتيجي / ١٢٠ تشغيلي).</p>
    </a>
</div>

<h2 style="margin-top:2rem;">رحلة الاستراتيجية الإدارية</h2>
<div class="grid-3">
    <a href="/Admin/LiveDashboard" class="card card--accent">
        <h3>اللوحة الحية</h3>
        <p class="muted">متابعة جلسات الإدارات لحظياً — المرحلة والنشاط والمشاركة.</p>
    </a>
    <a href="/Admin/Codes" class="card card--accent">
        <h3>رموز الدخول</h3>
        <p class="muted">إنشاء وإلغاء رموز دخول الإدارات وطباعة أوراق الـ QR.</p>
    </a>
    <a href="/Admin/Wall" class="card card--accent">
        <h3>جدار الخرائط</h3>
        <p class="muted">عرض الخرائط الموقّعة وتنزيل ملفات الـ PDF.</p>
    </a>
    <a href="/Admin/Moderation" class="card card--accent">
        <h3>مراجعة المحتوى</h3>
        <p class="muted">مراجعة العناصر وسجل التدقيق (جاهز للمرحلة الثالثة).</p>
    </a>
</div>

<h2 style="margin-top:2rem;">التحليلات والتقييم</h2>
<div class="grid-3">
    <a href="/Admin/Insights" class="card card--accent">
        <h3>لوحة الرؤى</h3>
        <p class="muted">نظرة شاملة، خريطة التغطية، تحليل التعهدات، وملصق البرنامج.</p>
    </a>
    <a href="/Admin/Quiz" class="card card--accent">
        <h3>بنك الأسئلة</h3>
        <p class="muted">توليد واعتماد أسئلة الاختبار المعرفي.</p>
    </a>
    <a href="/Admin/Quiz/Analytics" class="card card--accent">
        <h3>تحليلات الاختبار</h3>
        <p class="muted">متوسط النتائج، نسبة الإجابة لكل سؤال، وتصدير CSV.</p>
    </a>
    <a href="/Admin/Surveys" class="card card--accent">
        <h3>الاستبيانات</h3>
        <p class="muted">إنشاء الاستبيانات، رموز QR، وتقارير النتائج.</p>
    </a>
    <a href="/Admin/Content" class="card card--accent">
        <h3>تحرير النصوص</h3>
        <p class="muted">تعديل نصوص الصفحات الظاهرة للمستخدمين فوراً.</p>
    </a>
</div>
