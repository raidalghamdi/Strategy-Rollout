@using StrategyHouse.Domain.Entities
@model List<Session>
@{ ViewData["Title"] = "الجلسات"; }

<div class="row row--between mb-2">
    <h1>الجلسات (@Model.Count)</h1>
    <a href="/Admin/CreateSession" class="btn btn--primary">+ جلسة جديدة</a>
</div>

<table class="table">
    <thead><tr><th>العنوان</th><th>الرمز</th><th>الموعد</th><th>الإدارات</th><th>الحالة</th><th></th></tr></thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.TitleAr</td>
                <td><code>@s.AccessCode</code></td>
                <td>@s.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@string.Join("، ", s.SessionDepartments.Select(sd => sd.Department!.NameAr))</td>
                <td><span class="badge badge--primary">@s.Status</span></td>
                <td>
                    <a href="/Admin/SessionDetail/@s.Id" class="btn btn--sm btn--secondary">تفاصيل</a>
                    <a href="/Session/Console?code=@s.AccessCode" class="btn btn--sm btn--primary">طاولة</a>
                </td>
            </tr>
        }
    </tbody>
</table>
