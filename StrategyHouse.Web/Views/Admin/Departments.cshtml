@model List<StrategyHouse.Domain.Entities.Department>
@{ ViewData["Title"] = "الإدارات"; }
<h1>الإدارات (@Model.Count)</h1>
<table class="table">
    <thead>
        <tr><th>الرمز</th><th>الاسم</th><th>القطاع الأم</th><th>المستوى</th><th>الحالة</th></tr>
    </thead>
    <tbody>
    @foreach (var d in Model)
    {
        <tr>
            <td>@d.DeptCode</td>
            <td>@d.NameAr</td>
            <td>@d.ParentSector</td>
            <td>@d.Level</td>
            <td>@(d.IsActive ? "نشط" : "غير نشط")</td>
        </tr>
    }
    </tbody>
</table>
