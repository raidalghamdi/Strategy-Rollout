@using StrategyHouse.Domain.Entities
@model List<Department>
@{ ViewData["Title"] = "الإدارات"; }

<h1>الإدارات (@Model.Count)</h1>
<p class="muted">قائمة الإدارات الـ ١٨ المسجلة. اضغط على إدارة لإدارة مشاريعها، مؤشراتها، وأدوارها.</p>

<table class="table">
    <thead><tr><th>الرمز</th><th>الاسم</th><th>مشاريع</th><th>مؤشرات</th><th>أدوار</th><th></th></tr></thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td><code>@d.Code</code></td>
                <td>@d.NameAr</td>
                <td>@d.Projects.Count</td>
                <td>@d.Kpis.Count</td>
                <td>@d.Roles.Count</td>
                <td><a href="/Admin/Department/@d.Id" class="btn btn--sm btn--secondary">إدارة</a></td>
            </tr>
        }
    </tbody>
</table>
