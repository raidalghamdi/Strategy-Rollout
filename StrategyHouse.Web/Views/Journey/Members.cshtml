@model StrategyHouse.Domain.Entities.StrategySession
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "فريق العمل";
    var dept = ViewBag.Dept as StrategyHouse.Domain.Entities.Department;
}

<div class="gac-step">
    <div class="pip active">الفريق</div>
    <div class="pip">الصورة الكبرى</div>
    <div class="pip">بيت الاستراتيجية</div>
    <div class="pip">المساهمة</div>
    <div class="pip">الخريطة</div>
    <div class="pip">التوقيع</div>
</div>

<div class="gac-card">
    <h2>@dept?.NameAr</h2>
    <p class="text-muted">أضف أعضاء فريق الإدارة المشاركين في هذه الرحلة.</p>

    <form method="post" asp-action="AddMembers" asp-route-sessionId="@Model.Id">
        @Html.AntiForgeryToken()
        <div id="members">
            <div class="row g-2 mb-2 member-row">
                <div class="col-md-7"><input name="names" class="form-control" placeholder="الاسم" required /></div>
                <div class="col-md-5"><input name="roles" class="form-control" placeholder="الدور / المنصب" /></div>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addRow()">+ إضافة عضو</button>
        <hr />
        <button type="submit" class="btn gac-btn-primary text-white">متابعة إلى الصورة الكبرى</button>
    </form>
</div>

@section Scripts {
<script>
function addRow() {
    const tpl = document.querySelector('.member-row').cloneNode(true);
    tpl.querySelectorAll('input').forEach(i => i.value = '');
    tpl.querySelector('input[name="names"]').removeAttribute('required');
    document.getElementById('members').appendChild(tpl);
}
</script>
}
