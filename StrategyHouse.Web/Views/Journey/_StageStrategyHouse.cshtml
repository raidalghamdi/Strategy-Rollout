@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var content = Model.Content;
    var pillars = Model.HousePillars;
    var live = Model.StrategyDataLive;
}
<div class="gac-card" id="house-card">
    <h2 class="h4 h-md-2">البيت الاستراتيجي</h2>
    <p class="text-muted">كل مبادرة داخل الهيئة ترتبط بأحد الأهداف والركائز وصولاً للرؤية. استعرض البيت من الأعلى (الرؤية) إلى الأسفل (الأهداف).</p>

    @if (!live)
    {
        <div class="alert alert-info" role="note">البيانات الاستراتيجية ستتوفر عند الربط — تُعرض الآن بيانات توضيحية.</div>
    }

    @* Phase 19 — two views of the strategy house: the tree (default) and an
       interactive Sankey flow (Pillars → Objectives → Initiatives → Projects). *@
    <div class="house-tabs" role="tablist">
        <button type="button" class="house-tab is-active" data-view="tree" role="tab" aria-selected="true">شجرة</button>
        <button type="button" class="house-tab" data-view="flow" role="tab" aria-selected="false">تدفق تفاعلي</button>
    </div>

    <div class="house-view" id="house-view-tree">
        <div class="house-vision text-center">
            <div class="house-vision__label">الرؤية</div>
            <div class="house-vision__text">@content?.Vision.Ar</div>
        </div>

        <div class="house-pillars pillars-grid">
            @foreach (var p in pillars)
            {
                <div class="house-pillar" data-code="@p.Code">
                    <button type="button" class="house-pillar__head" aria-expanded="false">
                        <span class="house-pillar__name">@p.Name</span>
                        <span class="house-pillar__chev">▾</span>
                    </button>
                    <div class="house-objs" hidden>
                        @if (p.Objectives.Count == 0)
                        {
                            <div class="house-obj house-obj--empty">لا توجد أهداف مرتبطة.</div>
                        }
                        else
                        {
                            @foreach (var o in p.Objectives)
                            {
                                <div class="house-obj" data-code="@o.Code">@o.Name</div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="house-view" id="house-view-flow" hidden>
        <p class="text-muted small">مخطط تدفق يربط الركائز بالأهداف فالمبادرات فالمشاريع. مرّر فوق العناصر لإبراز المسار.</p>
        <div class="house-legend">
            <span><i style="background:#067647"></i>ركيزة</span>
            <span><i style="background:#299ECE"></i>هدف</span>
            <span><i style="background:#FAC126"></i>مبادرة</span>
            <span><i style="background:#28334A"></i>مشروع</span>
        </div>
        <div id="sankey-chart" class="sankey-chart" style="width:100%;min-height:800px;"></div>
    </div>
</div>

<style>
    #stage-2 .house-vision {
        background: #067647; color: #fff; border-radius: 14px; padding: 22px 18px;
        margin: 6px 0 16px; box-shadow: 0 4px 16px rgba(6,118,71,.25);
    }
    #stage-2 .house-vision__label { font-size: .9rem; opacity: .9; margin-bottom: 6px; }
    #stage-2 .house-vision__text { font-size: 1.15rem; font-weight: 800; line-height: 1.7; }
    /* Phase 20.8.3 — the five pillars MUST sit side by side on desktop. We use a fixed
       5-column grid above 1024px so the layout never collapses to 4+1 again. Below
       1024px we step down: 3 → 2 → 1 columns so phones and tablets stack cleanly. */
    #stage-2 .house-pillars { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 12px; }
    @@media (max-width: 1199px) { #stage-2 .house-pillars { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @@media (max-width: 767px)  { #stage-2 .house-pillars { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @@media (max-width: 479px)  { #stage-2 .house-pillars { grid-template-columns: 1fr; } }
    #stage-2 .house-pillar { border: 2px solid #d5dbe4; border-radius: 14px; background: #fff; overflow: hidden; min-width: 0; }
    #stage-2 .house-pillar.is-open { border-color: #067647; box-shadow: 0 2px 12px rgba(6,118,71,.18); }
    #stage-2 .house-pillar__head {
        width: 100%; border: none; background: #0f8f5b; color: #fff; cursor: pointer;
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        padding: 14px 12px; font-weight: 800; font-size: .95rem; min-height: 56px;
        line-height: 1.4;
    }
    #stage-2 .house-pillar__name { flex: 1 1 auto; overflow-wrap: anywhere; word-break: break-word; text-align: start; }
    #stage-2 .house-pillar__chev { transition: transform .2s; }
    #stage-2 .house-pillar.is-open .house-pillar__chev { transform: rotate(180deg); }
    #stage-2 .house-objs { display: flex; flex-direction: column; gap: 8px; padding: 12px; }
    #stage-2 .house-obj {
        background: #eef6f1; color: #1d4d39; border-radius: 10px; padding: 12px 14px;
        font-weight: 600; font-size: .92rem; line-height: 1.6; border-right: 4px solid #067647;
    }
    #stage-2 .house-obj--empty { color: #5a6b80; border-right-color: #ccd; background: #f3f5f8; font-weight: 500; }
    #stage-2 .house-tabs { display: flex; gap: 8px; margin: 4px 0 16px; }
    #stage-2 .house-tab {
        flex: 1 1 auto; border: 2px solid #d5dbe4; background: #fff; color: #5a6b80;
        border-radius: 10px; padding: 10px 12px; font-weight: 700; cursor: pointer; min-height: 44px;
    }
    #stage-2 .house-tab.is-active { background: #067647; border-color: #067647; color: #fff; }
    #stage-2 .house-legend { display: flex; flex-wrap: wrap; gap: 14px; margin: 4px 0 10px; font-size: .85rem; color: #28334A; }
    #stage-2 .house-legend span { display: inline-flex; align-items: center; gap: 6px; }
    #stage-2 .house-legend i { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }
</style>

<script src="~/js/strategy-sankey.js" asp-append-version="true"></script>
<script>
// Phase 18/19 — Stage 2 (البيت الاستراتيجي). Tree toggling + tree/flow tabs with a
// lazily-rendered Sankey. Pure DOM, iOS Safari-safe ES5.
(function () {
    function bindTree() {
        var heads = document.querySelectorAll('#stage-2 .house-pillar__head');
        for (var i = 0; i < heads.length; i++) {
            (function (head) {
                if (head.__bound) return; head.__bound = true;
                head.addEventListener('click', function () {
                    var pillar = head.parentNode;
                    var objs = pillar.querySelector('.house-objs');
                    var open = pillar.className.indexOf('is-open') === -1;
                    pillar.className = open ? 'house-pillar is-open' : 'house-pillar';
                    head.setAttribute('aria-expanded', open ? 'true' : 'false');
                    if (objs) { if (open) objs.removeAttribute('hidden'); else objs.setAttribute('hidden', 'hidden'); }
                });
            })(heads[i]);
        }
    }

    function bindTabs() {
        var tabs = document.querySelectorAll('#stage-2 .house-tab');
        var treeView = document.getElementById('house-view-tree');
        var flowView = document.getElementById('house-view-flow');
        for (var i = 0; i < tabs.length; i++) {
            (function (tab) {
                if (tab.__bound) return; tab.__bound = true;
                tab.addEventListener('click', function () {
                    var view = tab.getAttribute('data-view');
                    for (var j = 0; j < tabs.length; j++) {
                        var on = tabs[j] === tab;
                        tabs[j].className = on ? 'house-tab is-active' : 'house-tab';
                        tabs[j].setAttribute('aria-selected', on ? 'true' : 'false');
                    }
                    if (view === 'flow') {
                        if (treeView) treeView.setAttribute('hidden', 'hidden');
                        if (flowView) flowView.removeAttribute('hidden');
                        // Phase 20.8.5 — wait for the browser to lay out the now-visible
                        // panel before rendering, otherwise ECharts measures the host
                        // element as 0 × 0 and produces a single tall green bar.
                        var chart = document.getElementById('sankey-chart');
                        if (chart && window.StrategySankey) {
                            if (window.requestAnimationFrame) {
                                requestAnimationFrame(function () {
                                    requestAnimationFrame(function () {
                                        window.StrategySankey.render(chart);
                                    });
                                });
                            } else {
                                setTimeout(function () { window.StrategySankey.render(chart); }, 50);
                            }
                        }
                    } else {
                        if (flowView) flowView.setAttribute('hidden', 'hidden');
                        if (treeView) treeView.removeAttribute('hidden');
                    }
                });
            })(tabs[i]);
        }
    }

    function init() { bindTree(); bindTabs(); }
    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 2) init(); });
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
})();
</script>
