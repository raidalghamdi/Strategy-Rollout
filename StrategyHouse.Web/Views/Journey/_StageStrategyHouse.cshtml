@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var dept = Model.Dept;
    var content = Model.Content;
    var pillars = Model.Pillars;
    var objectives = Model.Objectives;
    var deptObjCodes = Model.DeptObjectiveCodes;
}
<div class="gac-card">
    <h2 class="h4 h-md-2">بيت الاستراتيجية — @dept?.NameAr</h2>
    <p class="text-muted">العناصر المرتبطة بإدارتك مميزة باللون الأزرق. اضغط على أي عنصر لعرض التفاصيل.</p>

    <div class="gac-vision text-center mb-2">
        <div class="label">الرؤية</div>
        <div>@content?.Vision.Ar</div>
    </div>
    <div class="text-center p-2 mb-2" style="background:#299ECE;border-radius:10px;">
        <strong>الرسالة:</strong> @content?.Mission.Ar
    </div>

    <div class="row g-2 mb-2">
        @foreach (var p in pillars)
        {
            <div class="col-6 col-md">
                <div class="p-2 text-white text-center" style="background:#5F9600;border-radius:10px;height:100%;">@p.PillarName</div>
            </div>
        }
    </div>

    <div class="row g-2">
        @foreach (var o in objectives)
        {
            var mine = deptObjCodes.Contains(o.ObjectiveCode);
            var bg = mine ? "#28334A" : "#e7edf5";
            var fg = mine ? "#fff" : "#9aa7b8";
            <div class="col-12 col-sm-6 col-md-3">
                <div class="p-2 text-center house-obj" style="background:@bg;color:@fg;border-radius:8px;cursor:pointer;font-size:.85rem;"
                     data-name="@o.ObjectiveName" data-mine="@mine.ToString().ToLower()">
                    @o.ObjectiveName
                </div>
            </div>
        }
    </div>

    <div class="mt-4">
        <h3 class="values-heading">القيم</h3>
        <div class="values-grid mt-1">
            @foreach (var v in content?.Values ?? new List<StrategyHouse.Web.Configuration.LocalizedText>())
            {
                <div class="value-card">@v.Ar</div>
            }
        </div>
    </div>
</div>

<style>
    #stage-3 .values-heading {
        color: #28334A; font-weight: 800; display: inline-block;
        border-bottom: 4px solid #FAC126; padding-bottom: 6px; margin-bottom: 4px;
    }
    #stage-3 .value-card {
        padding: 24px 16px; font-size: 1.25rem; font-weight: 700; text-align: center;
        background: #fff; color: #28334A; border-radius: 10px; height: 100%;
        border-bottom: 3px solid #FAC126; box-shadow: 0 2px 10px rgba(40,51,74,.08);
    }
</style>

<script>
document.querySelectorAll('#stage-3 .house-obj').forEach(el => {
    el.addEventListener('click', () => {
        const mine = el.dataset.mine === 'true';
        alert(el.dataset.name + (mine ? '\n(من مسؤوليات إدارتك)' : ''));
    });
});
</script>
