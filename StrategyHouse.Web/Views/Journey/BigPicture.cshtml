@model StrategyHouse.Domain.Entities.StrategySession
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "الصورة الكبرى";
    var dept = ViewBag.Dept as StrategyHouse.Domain.Entities.Department;
    var content = ViewBag.Content as StrategyHouse.Web.Services.StrategyContentService;
    var sankeyJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.Sankey);
}

<div class="gac-step">
    <div class="pip done">الفريق</div>
    <div class="pip active">الصورة الكبرى</div>
    <div class="pip">بيت الاستراتيجية</div>
    <div class="pip">المساهمة</div>
    <div class="pip">الخريطة</div>
    <div class="pip">التوقيع</div>
</div>

<div class="gac-vision mb-3 text-center">
    <div class="label">الرؤية</div>
    <div>@content?.Vision.Ar</div>
</div>

<div class="gac-card">
    <h2>كيف يرتبط عمل @dept?.NameAr بالرؤية</h2>
    <p class="text-muted">يوضح المخطط أدناه تدفق مؤشرات ومشاريع إدارتك نحو الأهداف والركائز والرؤية.</p>
    <div id="sankey" style="width:100%;overflow-x:auto;"></div>
</div>

<div class="text-end mt-3">
    <a class="btn gac-btn-primary text-white" asp-action="StrategyHouse" asp-route-sessionId="@Model.Id">متابعة إلى بيت الاستراتيجية</a>
</div>

@section Scripts {
<script>
const data = @Html.Raw(sankeyJson);
const colors = { vision:'#194F90', pillar:'#009845', objective:'#46BCCD', initiative:'#D79A2B', kpi:'#9DC41A', project:'#194F90' };
const width = Math.max(900, document.getElementById('sankey').clientWidth);
const height = 520;
const svg = d3.select('#sankey').append('svg').attr('width', width).attr('height', height);

if (!data.nodes || data.nodes.length === 0) {
    svg.append('text').attr('x', 20).attr('y', 40).text('لا توجد عناصر مرتبطة بهذه الإدارة بعد.').attr('fill','#5a6b80');
} else {
    const sankey = d3.sankey().nodeWidth(16).nodePadding(12).extent([[10,10],[width-10,height-10]]);
    const graph = sankey({ nodes: data.nodes.map(d => Object.assign({}, d)), links: data.links.map(d => Object.assign({}, d)) });

    svg.append('g').attr('fill','none').selectAll('path').data(graph.links).join('path')
        .attr('d', d3.sankeyLinkHorizontal()).attr('stroke', d => colors[d.source.layer] || '#ccc')
        .attr('stroke-opacity', .35).attr('stroke-width', d => Math.max(1, d.width));

    const node = svg.append('g').selectAll('g').data(graph.nodes).join('g');
    node.append('rect').attr('x', d => d.x0).attr('y', d => d.y0)
        .attr('height', d => Math.max(2, d.y1 - d.y0)).attr('width', d => d.x1 - d.x0)
        .attr('fill', d => colors[d.layer] || '#194F90');
    node.append('text').attr('x', d => d.x0 - 6).attr('y', d => (d.y0 + d.y1) / 2)
        .attr('dy', '0.35em').attr('text-anchor', 'end').attr('font-size', '11px')
        .text(d => d.name).filter(d => d.x0 < width / 2)
        .attr('x', d => d.x1 + 6).attr('text-anchor', 'start');
}
</script>
}
