@*
    Phase 20.15 — sector chooser shown to GLOBAL / Admin journey users so they
    can walk the same Stage 1–6 flow VPs see (one sector at a time). Sector
    accounts (VPs) never reach this page — they're redirected directly into
    their own sector journey.
*@
@model List<string>
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "اختيار القطاع";

    string Label(string key) => key switch
    {
        "SECTOR:CORP_SUPPORT" => "قطاع الدعم المؤسسي",
        "SECTOR:ECONOMIC" => "قطاع الشؤون الاقتصادية",
        "SECTOR:LEGAL" => "قطاع الشؤون القانونية",
        _ => key,
    };
    string Icon(string key) => key switch
    {
        "SECTOR:CORP_SUPPORT" => "🏛️",
        "SECTOR:ECONOMIC" => "📊",
        "SECTOR:LEGAL" => "⚖️",
        _ => "🔹",
    };
}

<div class="gac-card" style="max-width: 920px; margin: 24px auto;">
    <h1 class="h3 text-center" style="color:#28334A; font-family:'Cairo',sans-serif; font-weight:800;">
        اختر القطاع لبدء الرحلة
    </h1>
    <p class="text-muted text-center">
        لديك صلاحية الوصول لجميع القطاعات. اختر أحدها لتعرض رحلته بنفس تجربة نواب الرئيس.
    </p>

    <div class="sector-grid">
        @foreach (var key in Model)
        {
            <a class="sector-card" href="/Journey/Sector?sector=@Uri.EscapeDataString(key)">
                <div class="sector-card__icon" aria-hidden="true">@Icon(key)</div>
                <div class="sector-card__name">@Label(key)</div>
                <div class="sector-card__cta">ابدأ الرحلة ←</div>
            </a>
        }
    </div>
</div>

<style>
    .sector-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
        margin-top: 20px;
    }
    @@media (min-width: 720px) {
        .sector-grid { grid-template-columns: 1fr 1fr 1fr; }
    }
    .sector-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 28px 18px;
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 14px;
        box-shadow: 0 2px 10px rgba(40,51,74,.06);
        text-decoration: none;
        color: inherit;
        text-align: center;
        transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }
    .sector-card:hover,
    .sector-card:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(40,51,74,.12);
        border-color: #067647;
    }
    .sector-card__icon { font-size: 2.2rem; }
    .sector-card__name {
        font-family: "Cairo", sans-serif;
        font-weight: 800;
        font-size: 1.05rem;
        color: #28334A;
        line-height: 1.4;
    }
    .sector-card__cta { color: #067647; font-weight: 700; font-size: .9rem; }
</style>
