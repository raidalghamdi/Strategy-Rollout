@model StrategyHouse.Domain.Entities.StrategySession
@{
    Layout = "_JourneyLayout";
    ViewData["Title"] = "المساهمة";
    var dept = ViewBag.Dept as StrategyHouse.Domain.Entities.Department;
    var objectives = ViewBag.Objectives as List<StrategyHouse.Domain.Entities.Objective> ?? new();
    var initiatives = ViewBag.Initiatives as List<StrategyHouse.Domain.Entities.Initiative> ?? new();
    var pledges = ViewBag.Pledges as List<StrategyHouse.Domain.Entities.ContributionPledge> ?? new();
}

<div class="gac-step">
    <div class="pip done">الفريق</div>
    <div class="pip done">الصورة الكبرى</div>
    <div class="pip done">بيت الاستراتيجية</div>
    <div class="pip active">المساهمة</div>
    <div class="pip">الخريطة</div>
    <div class="pip">التوقيع</div>
</div>

<div class="gac-card">
    <h2>أين ترغب إدارتك بالمساهمة؟</h2>
    <p class="text-muted">اسحب العناصر التي ترغب إدارتك بدعمها إلى قائمة المساهمات.</p>
    <div class="row">
        <div class="col-md-6">
            <h5>العناصر المتاحة</h5>
            <ul id="available" class="list-group" style="min-height:300px;">
                @foreach (var o in objectives)
                {
                    <li class="list-group-item" data-type="OBJ" data-code="@o.ObjectiveCode">@o.ObjectiveName</li>
                }
                @foreach (var i in initiatives)
                {
                    <li class="list-group-item" data-type="INIT" data-code="@i.InitiativeCode">@i.InitiativeName</li>
                }
            </ul>
        </div>
        <div class="col-md-6">
            <h5>أرغب بالمساهمة</h5>
            <ul id="chosen" class="list-group" style="min-height:300px;background:#eaf4ec;border-radius:8px;">
                @foreach (var p in pledges)
                {
                    <li class="list-group-item" data-type="@p.ElementType" data-code="@p.ElementCode" data-saved="1">@p.ElementCode — @p.ContributionKind</li>
                }
            </ul>
        </div>
    </div>
</div>

<div class="text-end mt-3">
    <a class="btn gac-btn-primary text-white" asp-action="Map" asp-route-sessionId="@Model.Id">متابعة إلى الخريطة</a>
</div>

@section Scripts {
<script>
const sessionId = '@Model.Id';
const kinds = ['تنفيذ مباشر','دعم فني','موارد بشرية','بيانات','استشاري'];
new Sortable(document.getElementById('available'), { group: 'pledges', animation: 150 });
new Sortable(document.getElementById('chosen'), {
    group: 'pledges', animation: 150,
    onAdd: function (evt) {
        const el = evt.item;
        if (el.dataset.saved) return;
        const kind = prompt('نوع المساهمة:\n' + kinds.join(' / '), kinds[0]) || kinds[0];
        el.textContent = el.dataset.code + ' — ' + kind;
        el.dataset.saved = '1';
        fetch('@Url.Action("SavePledge")', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sessionId, elementType: el.dataset.type, elementCode: el.dataset.code, contributionKind: kind })
        });
    }
});
</script>
}
