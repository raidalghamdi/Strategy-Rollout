@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var dept = Model.Dept;
    var content = Model.Content;
    var sankeyJson = System.Text.Json.JsonSerializer.Serialize(Model.Sankey);
}
<div class="gac-vision mb-3 text-center">
    <div class="label">الرؤية</div>
    <div>@content?.Vision.Ar</div>
</div>

<div class="gac-card">
    <h2 class="h4 h-md-2">كيف يرتبط عمل @dept?.NameAr بالرؤية</h2>
    <p class="text-muted">يوضح المخطط أدناه تدفق مؤشرات ومشاريع إدارتك نحو الأهداف والركائز والرؤية.</p>
    <div class="sankey-hint">← مرّر أفقياً →</div>
    <div class="sankey-scroll" style="width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;">
        <div id="sankey" data-sankey='@Html.Raw(sankeyJson)' style="min-width:1800px;"></div>
    </div>
    <p class="text-muted small mt-2">مرّر أفقياً لعرض المخطط كاملاً.</p>
</div>
