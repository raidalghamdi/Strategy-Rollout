@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var content = Model.Content;
    var missionText = string.IsNullOrWhiteSpace(content?.Mission.Ar)
        ? "تعزيز المنافسة العادلة في السوق السعودي من خلال تطبيق نظام المنافسة ومنع الممارسات الاحتكارية، بما يحقق رفاه المستهلك ويدعم النمو الاقتصادي"
        : content!.Mission.Ar;
    var values = content?.Values ?? new System.Collections.Generic.List<StrategyHouse.Web.Configuration.LocalizedText>();
    var selectedValueText = Model.SelectedTeamValue;
    var savedReflection = Model.OpeningReflectionText;
}

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6">
        <div class="gac-vision text-center h-100">
            <div class="label">الرؤية</div>
            <div>@content?.Vision.Ar</div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="gac-vision text-center h-100">
            <div class="label">الرسالة</div>
            <div>@missionText</div>
        </div>
    </div>
</div>

<div class="gac-card" id="reflection-card">
    <h2 class="h4 h-md-2">قبل أن نبدأ… لحظة تأمّل</h2>
    <p class="text-muted">برأيك، ما الذي يجعل عمل إدارتك مهماً لتحقيق رؤية الهيئة؟ شاركنا فكرتك بإيجاز.</p>
    <textarea id="reflectionText" class="form-control" rows="4" maxlength="4000"
              style="max-width:100%;" placeholder="اكتب تأمّلك هنا… (اختياري)">@savedReflection</textarea>
    <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
        <button type="button" id="reflectionSave" class="btn gac-btn-primary text-white" style="min-height:44px;">حفظ ومتابعة</button>
        <span id="reflectionStatus" class="small @(string.IsNullOrEmpty(savedReflection) ? "text-muted" : "text-success")">@(string.IsNullOrEmpty(savedReflection) ? "" : "تم حفظ تأمّلك ✓")</span>
    </div>
</div>

@if (values.Count > 0)
{
    <div class="gac-card mt-3" id="team-values">
        <h2 class="h4 h-md-2">اختر القيمة التي تعبّر عن فريقكم</h2>
        <p class="text-muted">اختياري — اختر القيمة الأقرب لروح فريقكم من قيم الهيئة.</p>
        <div class="tv-grid">
            @foreach (var v in values)
            {
                var isSel = !string.IsNullOrEmpty(selectedValueText) && selectedValueText == v.Ar;
                <label class="tv-card @(isSel ? "is-selected" : "")" data-key="@v.En" data-text="@v.Ar">
                    <input type="radio" name="teamValue" value="@v.Ar" @(isSel ? "checked" : "") />
                    <span class="tv-name">@v.Ar</span>
                </label>
            }
        </div>
        <div id="tv-status" class="small text-muted mt-2" style="min-height:1.2em;"></div>
    </div>
    <style>
        #team-values .tv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
        #team-values .tv-card {
            border: 2px solid #d5dbe4; border-radius: 12px; padding: 16px 14px; background: #fff;
            text-align: center; cursor: pointer; transition: border-color .15s, box-shadow .15s;
            display: flex; align-items: center; justify-content: center; gap: 8px; min-height: 56px; margin: 0;
        }
        #team-values .tv-card.is-selected { border-color: #067647; box-shadow: 0 2px 10px rgba(6,118,71,.2); }
        #team-values .tv-card input[type=radio] { width: 20px; height: 20px; accent-color: #067647; }
        #team-values .tv-name { font-weight: 700; color: #28334A; }
    </style>
}

<script>
// Phase 18 — Stage 1 (الصورة الكبرى). iOS Safari-safe ES5: IIFE, string concat,
// for-loops, no template literals, no block scope, try/catch with fallback.
(function () {
    var sessionId = '@Model.Session.Id';

    function bindReflection() {
        var btn = document.getElementById('reflectionSave');
        var ta = document.getElementById('reflectionText');
        var status = document.getElementById('reflectionStatus');
        if (!btn || btn.__bound) return; btn.__bound = true;
        btn.addEventListener('click', function () {
            var text = ta ? ta.value.replace(/^\s+|\s+$/g, '') : '';
            if (status) { status.textContent = 'جارٍ الحفظ...'; status.className = 'small text-muted'; }
            try {
                fetch('@Url.Action("SaveReflection")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId: sessionId, reflectionText: text })
                }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                  .then(function () { if (status) { status.textContent = 'تم حفظ تأمّلك ✓'; status.className = 'small text-success'; } })
                  .catch(function () { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } });
            } catch (e) { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } }
        });
    }

    function bindValues() {
        var radios = document.querySelectorAll('#team-values input[name="teamValue"]');
        var status = document.getElementById('tv-status');
        for (var i = 0; i < radios.length; i++) {
            (function (radio) {
                if (radio.__bound) return; radio.__bound = true;
                radio.addEventListener('change', function () {
                    var card = radio.closest('.tv-card');
                    var key = card ? card.getAttribute('data-key') : '';
                    var text = card ? card.getAttribute('data-text') : radio.value;
                    var cards = document.querySelectorAll('#team-values .tv-card');
                    for (var j = 0; j < cards.length; j++) cards[j].className = 'tv-card';
                    if (card) card.className = 'tv-card is-selected';
                    if (status) status.textContent = 'جارٍ الحفظ...';
                    try {
                        fetch('@Url.Action("SaveTeamValue")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sessionId: sessionId, valueKey: key, valueText: text })
                        }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                          .then(function () { if (status) status.textContent = 'تم حفظ اختياركم: ' + text; })
                          .catch(function () { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; });
                    } catch (e) { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; }
                });
            })(radios[i]);
        }
    }

    function init() { bindReflection(); bindValues(); }
    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 1) init(); });
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
})();
</script>
