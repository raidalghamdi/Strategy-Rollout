@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var content = Model.Content;
    var missionText = string.IsNullOrWhiteSpace(content?.Mission.Ar)
        ? "تعزيز المنافسة العادلة في السوق السعودي من خلال تطبيق نظام المنافسة ومنع الممارسات الاحتكارية، بما يحقق رفاه المستهلك ويدعم النمو الاقتصادي"
        : content!.Mission.Ar;
    var savedReflection = Model.OpeningReflectionText;
}

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6">
        <div class="gac-vision text-center h-100">
            <div class="label">الرؤية</div>
            <div>@content?.Vision.Ar</div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="gac-vision text-center h-100">
            <div class="label">الرسالة</div>
            <div>@missionText</div>
        </div>
    </div>
</div>

<div class="gac-card" id="reflection-card">
    <h2 class="h4 h-md-2">قبل أن نبدأ… لحظة تأمّل</h2>
    <p class="text-muted">برأيك، ما الذي يجعل عمل إدارتك مهماً لتحقيق رؤية الهيئة؟ شاركنا فكرتك بإيجاز.</p>
    <textarea id="reflectionText" class="form-control" rows="4" maxlength="4000"
              style="max-width:100%;" placeholder="اكتب تأمّلك هنا… (اختياري)">@savedReflection</textarea>
    <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
        <button type="button" id="reflectionSave" class="btn gac-btn-primary text-white" style="min-height:44px;">حفظ ومتابعة</button>
        <span id="reflectionStatus" class="small @(string.IsNullOrEmpty(savedReflection) ? "text-muted" : "text-success")">@(string.IsNullOrEmpty(savedReflection) ? "" : "تم حفظ تأمّلك ✓")</span>
    </div>
</div>

<script>
// Phase 18 — Stage 1 (الصورة الكبرى). iOS Safari-safe ES5: IIFE, string concat,
// for-loops, no template literals, no block scope, try/catch with fallback.
(function () {
    var sessionId = '@Model.Session.Id';

    function bindReflection() {
        var btn = document.getElementById('reflectionSave');
        var ta = document.getElementById('reflectionText');
        var status = document.getElementById('reflectionStatus');
        if (!btn || btn.__bound) return; btn.__bound = true;
        btn.addEventListener('click', function () {
            var text = ta ? ta.value.replace(/^\s+|\s+$/g, '') : '';
            if (status) { status.textContent = 'جارٍ الحفظ...'; status.className = 'small text-muted'; }
            try {
                fetch('@Url.Action("SaveReflection")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId: sessionId, reflectionText: text })
                }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                  .then(function () { if (status) { status.textContent = 'تم حفظ تأمّلك ✓'; status.className = 'small text-success'; } })
                  .catch(function () { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } });
            } catch (e) { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } }
        });
    }

    function init() { bindReflection(); }
    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 1) init(); });
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
})();
</script>
