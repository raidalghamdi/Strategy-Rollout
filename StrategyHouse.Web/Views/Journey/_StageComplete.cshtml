@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var hashtag = "#أنا_مشارك";
    var selectedTeamValue = Model.SelectedTeamValue;
    // Phase 19 — team values moved here from stage 1 with a reworded prompt.
    var teamValues = new[] { "الشفافية", "التعاون", "التميز", "العدالة", "الابتكار" };
}
@if (TempData["Saved"] != null) { <div class="alert alert-success">@TempData["Saved"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

@* Phase 20.33 — Stage 5 (الأثر) order: 1) team values, 2) interactive
   questions (inline quiz), 3) thank-you (hidden until the quiz completes).
   The optional "attendee count" form was removed from the UI; the backend
   endpoint /Journey/SaveAttendeeCount is kept for compatibility. *@

@* 2) Team values — Phase 19.11: swapped order so team values come BEFORE the
   interactive questions block. Moved from stage 1 in Phase 19 with reworded prompt. *@
<div class="gac-card mt-3" id="team-values">
    <h3 class="h5" style="color:#28334A;font-weight:800;">بعد هذه التجربة… أي قيمة ستكون الأقرب لك في عملك اليومي؟</h3>
    <p class="text-muted">اختياري — اختر قيمة واحدة</p>
    <div class="tv-grid">
        @foreach (var v in teamValues)
        {
            var isSel = !string.IsNullOrEmpty(selectedTeamValue) && selectedTeamValue == v;
            <label class="tv-card @(isSel ? "is-selected" : "")" data-key="@v" data-text="@v">
                <input type="radio" name="teamValue" value="@v" @(isSel ? "checked" : "") />
                <span class="tv-name">@v</span>
            </label>
        }
    </div>
    <div id="tv-status" class="small text-muted mt-2" style="min-height:1.2em;"></div>
</div>

@* 3) Interactive questions — inline quiz. Phase 19.6: a standalone-quiz fallback
   link is always rendered below the title so users still reach the quiz even when
   the inline widget fails to load (e.g. iOS Safari, JS disabled, fetch error).
   Phase 19.10: button goes DIRECTLY to /Quiz/Start (the actual quiz play page),
   bypassing /Quiz Index which redirects admins to /Admin/Quiz (the bank manager). *@
<div class="gac-card mt-3" id="inline-quiz-card">
    <h3 class="h5" style="color:#28334A;font-weight:800;">الأسئلة التفاعلية</h3>
    <p class="text-muted mb-3">اختبر معرفتك بالاستراتيجية المؤسسية في أسئلة قصيرة وممتعة.</p>
    <div id="inlineQuizArea"></div>
    <div class="mt-3">
        <a href="/Quiz/Start/@Model.Session.Id" id="quizFallbackLink" class="btn quiz-fallback-btn" target="_blank" rel="noopener" style="min-height:44px;background:#FAC126;border-color:#FAC126;color:#00192B;font-weight:700;">ابدأ الاختبار الآن</a>
    </div>
</div>

@* 4) Thank-you — hidden until the inline quiz is completed. No department name. *@
<div class="gac-card mt-3 text-center" id="thanks-card" style="display:none;">
    <div style="font-size:3rem;">🎉</div>
    <h1 class="h2">شكراً لك!</h1>
    <p class="lead text-muted">لقد أتممت رحلة استراتيجية الهيئة. أنت الآن جزء من قصة تحقيق الرؤية.</p>
    <div class="share-tag" id="shareTag">@hashtag</div>
    <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
        <button type="button" id="copyShare" class="btn gac-btn-primary text-white" style="min-height:44px;">نسخ الوسم</button>
        <span id="shareStatus" class="small text-success" style="align-self:center;"></span>
    </div>
</div>

<style>
    /* Phase 19.5 — explicit 1 / 2 / 5 columns (mobile / tablet / desktop). */
    #team-values .tv-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
    @@media (min-width: 576px) { #team-values .tv-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (min-width: 992px) { #team-values .tv-grid { grid-template-columns: repeat(5, 1fr); } }
    #team-values .tv-card {
        border: 2px solid #d5dbe4; border-radius: 12px; padding: 16px 14px; background: #fff;
        text-align: center; cursor: pointer; transition: border-color .15s, box-shadow .15s;
        display: flex; align-items: center; justify-content: center; gap: 8px; min-height: 56px; margin: 0;
    }
    #team-values .tv-card.is-selected { border-color: #067647; box-shadow: 0 2px 10px rgba(6,118,71,.2); }
    #team-values .tv-card input[type=radio] { width: 20px; height: 20px; accent-color: #067647; }
    #team-values .tv-name { font-weight: 700; color: #28334A; }
    #thanks-card .share-tag {
        display: inline-block; margin-top: 8px; background: #eef6f1; color: #067647;
        font-size: 1.8rem; font-weight: 900; border-radius: 14px; padding: 14px 28px;
        border: 2px dashed #067647;
    }
</style>

<script src="~/js/quiz-inline.js" asp-append-version="true"></script>
<script>
// Phase 19 — Stage 5 (الأثر). Inline quiz + team values + reveal thank-you on
// quiz completion + copy-to-clipboard share. iOS Safari-safe ES5.
window.__stageCompleteConfetti = function () {
    if (window.__confettiDone) return; window.__confettiDone = true;
    try {
        var c = document.createElement('canvas');
        c.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:999';
        document.body.appendChild(c);
        c.width = window.innerWidth; c.height = window.innerHeight;
        var ctx = c.getContext('2d');
        var colors = ['#28334A', '#299ECE', '#5F9600', '#FAC126', '#067647'];
        var parts = [];
        for (var i = 0; i < 120; i++) {
            parts.push({
                x: Math.random() * c.width, y: -20 - Math.random() * c.height,
                r: 4 + Math.random() * 6, col: colors[Math.floor(Math.random() * colors.length)],
                v: 2 + Math.random() * 3
            });
        }
        var frames = 0;
        function loop() {
            ctx.clearRect(0, 0, c.width, c.height);
            for (var j = 0; j < parts.length; j++) {
                var p = parts[j]; p.y += p.v; ctx.fillStyle = p.col; ctx.fillRect(p.x, p.y, p.r, p.r);
            }
            if (frames++ < 200) requestAnimationFrame(loop); else c.parentNode && c.parentNode.removeChild(c);
        }
        loop();
    } catch (e) { /* confetti is decorative; ignore failures */ }
};

(function () {
    var sessionId = '@Model.Session.Id';
    var deptCode = @(Model.Session.DeptCode != null ? "'" + Model.Session.DeptCode + "'" : "null");

    function startQuiz() {
        var area = document.getElementById('inlineQuizArea');
        if (!area || area.__started) return; area.__started = true;
        try {
            if (window.console) console.log('[stage5] starting inline quiz');
            if (!window.StrategyInlineQuiz || !window.StrategyInlineQuiz.init) {
                throw new Error('StrategyInlineQuiz not loaded');
            }
            window.StrategyInlineQuiz.init({
                mount: area,
                sessionId: sessionId,
                scope: 'General',
                deptCode: deptCode,
                onComplete: function () { revealThanks(); }
            });
        } catch (e) {
            if (window.console) console.log('[stage5] inline quiz unavailable: ' + e + ' — fallback link remains visible');
            area.innerHTML = '<div class="alert alert-warning">تعذّر تحميل الأسئلة هنا. اضغط زر «ابدأ الاختبار الآن» بالأسفل.</div>';
        }
    }

    function revealThanks() {
        var card = document.getElementById('thanks-card');
        if (!card) return;
        card.style.display = '';
        if (window.__stageCompleteConfetti) window.__stageCompleteConfetti();
        try { card.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) {}
    }

    function bindShare() {
        var btn = document.getElementById('copyShare');
        var status = document.getElementById('shareStatus');
        var tag = document.getElementById('shareTag');
        if (!btn || btn.__bound) return; btn.__bound = true;
        btn.addEventListener('click', function () {
            var text = tag ? tag.textContent : '#أنا_مشارك';
            function done() { if (status) status.textContent = 'تم نسخ الوسم ✓'; }
            function fail() {
                try {
                    var ta = document.createElement('textarea');
                    ta.value = text; document.body.appendChild(ta); ta.select();
                    document.execCommand('copy'); document.body.removeChild(ta); done();
                } catch (e) { if (status) status.textContent = 'انسخ الوسم يدوياً: ' + text; }
            }
            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(done, fail);
                } else { fail(); }
            } catch (e) { fail(); }
        });
    }

    function bindValues() {
        var radios = document.querySelectorAll('#team-values input[name="teamValue"]');
        var status = document.getElementById('tv-status');
        for (var i = 0; i < radios.length; i++) {
            (function (radio) {
                if (radio.__bound) return; radio.__bound = true;
                radio.addEventListener('change', function () {
                    var card = radio.closest('.tv-card');
                    var key = card ? card.getAttribute('data-key') : '';
                    var text = card ? card.getAttribute('data-text') : radio.value;
                    var cards = document.querySelectorAll('#team-values .tv-card');
                    for (var j = 0; j < cards.length; j++) cards[j].className = 'tv-card';
                    if (card) card.className = 'tv-card is-selected';
                    if (status) status.textContent = 'جارٍ الحفظ...';
                    try {
                        fetch('@Url.Action("SaveTeamValue")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sessionId: sessionId, valueKey: key, valueText: text })
                        }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                          .then(function () { if (status) status.textContent = 'تم حفظ اختياركم: ' + text; })
                          .catch(function () { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; });
                    } catch (e) { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; }
                });
            })(radios[i]);
        }
    }

    function init() { startQuiz(); bindValues(); bindShare(); }
    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 5) init(); });
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
})();
</script>
