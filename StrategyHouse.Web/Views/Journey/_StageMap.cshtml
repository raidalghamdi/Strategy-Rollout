@* Phase 20.10 — stage 5 (الرحلة نحو الرؤية). Initiatives mode now uses TWO
   dropdowns (initiative → project) and the chain reads project → initiative
   → goal → pillar → vision. KPIs mode unchanged. *@
@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var sel = Model.SelectedInitiative;
    var visionText = Model.Content?.Vision.Ar;
    var hasSelection = sel != null && !string.IsNullOrEmpty(sel.Code);

    var scopedKpis = Model.Kpis ?? new List<StrategyHouse.Domain.Entities.Kpi>();

    // Phase 20.11 — build initiative→projects map for the two-dropdown picker.
    // Use FULL project + initiative lists (all departments) so each initiative can
    // show every linked project regardless of the current user's department.
    var allProjects = Model.AllProjects ?? new List<StrategyHouse.Domain.Entities.Project>();
    var pickerInits = (Model.AllInitiatives ?? new List<StrategyHouse.Domain.Entities.Initiative>())
        .Select(i =>
        {
            var obj = Model.Objectives.FirstOrDefault(o => o.ObjectiveCode == i.ObjectiveCode);
            var pillar = obj == null ? null : Model.Pillars.FirstOrDefault(p => p.PlrCode == obj.PlrCode);
            var projs = allProjects.Where(pr => !string.IsNullOrEmpty(pr.InitiativeCode)
                                                && string.Equals(pr.InitiativeCode, i.InitiativeCode, StringComparison.OrdinalIgnoreCase))
                                   .ToList();
            return new
            {
                Code = i.InitiativeCode,
                Name = i.InitiativeName ?? i.InitiativeCode,
                ObjectiveName = obj?.ObjectiveName ?? sel?.ObjectiveName ?? "—",
                PillarName = pillar?.PillarName ?? sel?.PillarName ?? "—",
                Projects = projs,
            };
        })
        .Where(x => !string.IsNullOrEmpty(x.Code))
        .ToList();
    if (sel != null && !string.IsNullOrEmpty(sel.Code) && !pickerInits.Any(x => x.Code == sel.Code))
    {
        var projs2 = allProjects.Where(pr => !string.IsNullOrEmpty(pr.InitiativeCode)
                                             && string.Equals(pr.InitiativeCode, sel.Code, StringComparison.OrdinalIgnoreCase))
                                .ToList();
        pickerInits.Insert(0, new
        {
            Code = sel.Code,
            Name = sel.Name,
            ObjectiveName = sel.ObjectiveName ?? "—",
            PillarName = sel.PillarName ?? "—",
            Projects = projs2,
        });
    }
}
<div class="gac-card" id="journey-card">
    <h2 class="h4 h-md-2 text-center">الرحلة نحو الرؤية</h2>

    @if (!hasSelection)
    {
        <div class="alert alert-info mt-2 text-center">
            اختر مبادرتك في مرحلة «دوري في الاستراتيجية» لعرض ارتباط دورك بالرؤية.
        </div>
    }
    else
    {
        <p class="text-muted text-center">شاهد كيف يتصل دورك — خطوة بخطوة — حتى رؤية الهيئة.</p>

        <div class="journey-toggle" role="tablist" aria-label="نوع الربط">
            <button type="button" class="jtoggle is-active" data-mode="initiatives" role="tab" aria-selected="true">المبادرات</button>
            <button type="button" class="jtoggle" data-mode="kpis" role="tab" aria-selected="false">مؤشّرات الأداء</button>
        </div>

        <div id="journeyInitPicker" class="jkpi-picker jkpi-picker--init">
            <label for="jInitPicker">اختر مبادرة:</label>
            <select id="jInitPicker">
                @foreach (var ini in pickerInits)
                {
                    <option value="@ini.Code"
                            data-name="@ini.Name"
                            data-objective="@ini.ObjectiveName"
                            data-pillar="@ini.PillarName"
                            data-projects-json='@System.Text.Json.JsonSerializer.Serialize(ini.Projects.Select(p => new { code = p.ProjectCode, name = p.ProjectName ?? p.ProjectCode }))'
                            selected="@(ini.Code == sel!.Code ? "selected" : null)">@ini.Name</option>
                }
            </select>
            <label for="jProjPicker">اختر مشروعاً:</label>
            <select id="jProjPicker">
                <option value="">—</option>
            </select>
        </div>

        <div id="journeyChain" class="jchain jchain--initiatives">
            <div class="jnode jnode--proj" data-step="0">
                <span class="jlabel">مشروعك</span>
                <span class="jtext" id="jInitProjectName">—</span>
            </div>
            <div class="jarrow" data-step="1">↓</div>
            <div class="jnode jnode--init" data-step="2">
                <span class="jlabel">المبادرة</span>
                <span class="jtext" id="jInitName">@sel!.Name</span>
            </div>
            <div class="jarrow" data-step="3">↓</div>
            <div class="jnode jnode--obj" data-step="4">
                <span class="jlabel">الهدف</span>
                <span class="jtext" id="jInitObjective">@(string.IsNullOrEmpty(sel.ObjectiveName) ? "—" : sel.ObjectiveName)</span>
            </div>
            <div class="jarrow" data-step="5">↓</div>
            <div class="jnode jnode--pillar" data-step="6">
                <span class="jlabel">الركيزة</span>
                <span class="jtext" id="jInitPillar">@(string.IsNullOrEmpty(sel.PillarName) ? "—" : sel.PillarName)</span>
            </div>
            <div class="jarrow" data-step="7">↓</div>
            <div class="jnode jnode--vision" data-step="8"><span class="jlabel">الرؤية</span><span class="jtext">@visionText</span></div>
        </div>

        <div id="journeyChainKpis" class="jchain jchain--kpis" hidden>
            @if (scopedKpis.Count == 0)
            {
                <div class="alert alert-info text-center">
                    لا توجد مؤشّرات أداء ضمن صلاحيتك حالياً.
                </div>
            }
            else
            {
                <div class="jkpi-picker">
                    <label for="jkpiPicker">اختر مؤشّراً:</label>
                    <select id="jkpiPicker">
                        @foreach (var k in scopedKpis)
                        {
                            var oName = Model.Objectives.FirstOrDefault(o => o.ObjectiveCode == k.ObjectiveCode)?.ObjectiveName ?? "";
                            var pCode = Model.Objectives.FirstOrDefault(o => o.ObjectiveCode == k.ObjectiveCode)?.PlrCode;
                            var pName = Model.Pillars.FirstOrDefault(pi => pi.PlrCode == pCode)?.PillarName ?? "";
                            <option value="@k.KpiCode"
                                    data-name="@k.KpiName"
                                    data-objective="@oName"
                                    data-pillar="@pName">@k.KpiName</option>
                        }
                    </select>
                </div>

                <div class="jnode jnode--init" data-step="0">
                    <span class="jlabel">مؤشّرك</span>
                    <span class="jtext" id="jkpiName">@scopedKpis[0].KpiName</span>
                </div>
                <div class="jarrow" data-step="1">↓</div>
                <div class="jnode jnode--obj" data-step="2">
                    <span class="jlabel">الهدف</span>
                    <span class="jtext" id="jkpiObjective">
                        @{
                            var firstObj = Model.Objectives.FirstOrDefault(o => o.ObjectiveCode == scopedKpis[0].ObjectiveCode);
                        }
                        @(firstObj?.ObjectiveName ?? "—")
                    </span>
                </div>
                <div class="jarrow" data-step="3">↓</div>
                <div class="jnode jnode--pillar" data-step="4">
                    <span class="jlabel">الركيزة</span>
                    <span class="jtext" id="jkpiPillar">
                        @{
                            var firstPillar = firstObj == null ? null : Model.Pillars.FirstOrDefault(pi => pi.PlrCode == firstObj.PlrCode);
                        }
                        @(firstPillar?.PillarName ?? "—")
                    </span>
                </div>
                <div class="jarrow" data-step="5">↓</div>
                <div class="jnode jnode--vision" data-step="6">
                    <span class="jlabel">الرؤية</span>
                    <span class="jtext">@visionText</span>
                </div>
            }
        </div>

        <div class="jmsg-wrap">
            <div id="journeyMsg" class="jmsg">أنت أقرب للرؤية مما تتصور</div>
        </div>
    }
</div>

<style>
    #stage-5 .jchain { display: flex; flex-direction: column; align-items: stretch; gap: 8px; max-width: 640px; margin: 18px auto 0; }
    #stage-5 .jnode {
        border-radius: 14px; padding: 16px 18px; color: #fff; text-align: center;
        opacity: 0; transform: translateY(14px) scale(.98); transition: opacity .5s ease, transform .5s ease;
    }
    #stage-5 .jnode.is-in { opacity: 1; transform: translateY(0) scale(1); }
    #stage-5 .jnode--proj { background: #28334A; }
    #stage-5 .jnode--init { background: #5F9600; }
    #stage-5 .jnode--obj { background: #299ECE; }
    #stage-5 .jnode--pillar { background: #0f8f5b; }
    #stage-5 .jnode--vision { background: #067647; }
    #stage-5 .jlabel { display: block; font-size: .82rem; opacity: .9; }
    #stage-5 .jtext { display: block; font-weight: 800; line-height: 1.7; margin-top: 4px; }
    #stage-5 .jarrow { text-align: center; color: #067647; font-size: 1.5rem; line-height: 1; opacity: 0; transition: opacity .5s ease; }
    #stage-5 .jarrow.is-in { opacity: 1; }

    #stage-5 .jmsg-wrap { display: flex; justify-content: center; align-items: center; width: 100%; margin-top: 22px; }
    #stage-5 .jmsg {
        color: #067647; font-size: 1.6rem; font-weight: 900; line-height: 1.6;
        text-align: center;
        opacity: 0; transform: translateY(10px); transition: opacity .6s ease, transform .6s ease;
    }
    #stage-5 .jmsg.is-in { opacity: 1; transform: translateY(0); }

    #stage-5 .journey-toggle {
        display: flex; justify-content: center; gap: 8px;
        margin: 14px 0 6px;
    }
    #stage-5 .jtoggle {
        font-family: "Cairo", sans-serif; font-weight: 700;
        padding: 8px 18px; border-radius: 999px;
        border: 1.5px solid #067647; background: #fff; color: #067647;
        cursor: pointer; transition: background .15s, color .15s;
    }
    #stage-5 .jtoggle.is-active { background: #067647; color: #fff; }
    #stage-5 .jtoggle:hover { background: #ECF6F0; }
    #stage-5 .jtoggle.is-active:hover { background: #05623A; }

    /* Phase 20.11 — compact dropdown picker (was oversized on mobile). */
    #stage-5 .jkpi-picker {
        max-width: 520px; margin: 0 auto 14px;
        display: flex; flex-wrap: wrap; gap: 6px 12px;
        align-items: center; justify-content: center;
    }
    #stage-5 .jkpi-picker label {
        font-weight: 700; color: #28334A; font-size: .9rem;
        flex: 0 0 auto;
    }
    #stage-5 .jkpi-picker select {
        flex: 1 1 200px; min-width: 0; max-width: 100%;
        height: 38px; padding: 6px 10px; box-sizing: border-box;
        border-radius: 8px; border: 1px solid #c9d1de; background: #fff;
        font-family: "Cairo", sans-serif; font-size: .9rem; line-height: 1.4;
        appearance: auto; -webkit-appearance: menulist;
    }
    #stage-5 .jkpi-picker--init {
        flex-direction: column; align-items: stretch; gap: 10px;
        max-width: 520px;
    }
    #stage-5 .jkpi-picker--init label { text-align: start; margin-bottom: -4px; }

    #stage-5 .jdetails {
        margin-top: 12px; text-align: start;
        background: rgba(255,255,255,.12);
        border-radius: 10px; padding: 8px 12px;
    }
    #stage-5 .jdetails summary {
        cursor: pointer; font-size: .85rem; font-weight: 700;
        color: #fff; list-style: none; outline: none; user-select: none;
        padding: 4px 0;
    }
    #stage-5 .jdetails summary::-webkit-details-marker { display: none; }
    #stage-5 .jdetails summary::before {
        content: '◀'; display: inline-block; margin-inline-end: 6px;
        font-size: .7rem; transition: transform .2s;
    }
    #stage-5 .jdetails[open] summary::before { transform: rotate(-90deg); }
    #stage-5 .jchildren { padding: 8px 0 4px; font-size: .82rem; color: #fff; }
    #stage-5 .jchild-group { margin-bottom: 8px; }
    #stage-5 .jchild-group:last-child { margin-bottom: 0; }
    #stage-5 .jchild-group h6 {
        font-size: .78rem; font-weight: 700;
        color: rgba(255,255,255,.85); margin: 0 0 4px;
    }
    #stage-5 .jchild-group ul { list-style: none; padding: 0; margin: 0; }
    #stage-5 .jchild-group li {
        padding: 4px 8px; background: rgba(255,255,255,.18);
        border-radius: 6px; margin-bottom: 3px;
        line-height: 1.5; font-weight: 600;
    }
    #stage-5 .jchild-meta { color: rgba(255,255,255,.75); font-size: .75rem; font-weight: 400; }
</style>

<script>
// Phase 20.10 — Stage 5 (الرحلة نحو الرؤية). Animated reveal + Initiatives/KPIs
// toggle. Initiatives mode now has TWO dropdowns (initiative → project).
window.__stageMapInit = (function () {
    var done = false;
    function revealChain(scope) {
        var steps = scope.querySelectorAll('[data-step]');
        if (!steps || steps.length === 0) return;
        for (var i = 0; i < steps.length; i++) {
            (function (node, idx) {
                setTimeout(function () {
                    node.className = node.className + ' is-in';
                }, 220 * idx);
            })(steps[i], i);
        }
    }
    function showMsgOnce() {
        var msg = document.getElementById('journeyMsg');
        if (msg && msg.className.indexOf('is-in') === -1) {
            setTimeout(function () { msg.className = 'jmsg is-in'; }, 1600);
        }
    }
    function resetReveal(scope) {
        var steps = scope.querySelectorAll('[data-step]');
        for (var i = 0; i < steps.length; i++) {
            steps[i].className = steps[i].className.replace(/\s*is-in/g, '');
        }
    }
    // Phase 20.11 — force-hide helper so leftover inline/CSS state can't leak
    // between the Initiatives mode and the KPIs mode.
    function setShown(el, shown) {
        if (!el) return;
        if (shown) { el.removeAttribute('hidden'); el.style.display = ''; }
        else { el.setAttribute('hidden', 'hidden'); el.style.display = 'none'; }
    }
    function bindToggle() {
        var btns = document.querySelectorAll('#stage-5 .jtoggle');
        if (!btns || btns.length === 0) return;
        var chainInit = document.getElementById('journeyChain');
        var chainKpi = document.getElementById('journeyChainKpis');
        var pickerInitWrap = document.getElementById('journeyInitPicker');
        for (var i = 0; i < btns.length; i++) {
            btns[i].addEventListener('click', function () {
                var mode = this.getAttribute('data-mode');
                for (var j = 0; j < btns.length; j++) {
                    var on = btns[j].getAttribute('data-mode') === mode;
                    btns[j].classList.toggle('is-active', on);
                    btns[j].setAttribute('aria-selected', on ? 'true' : 'false');
                }
                // Phase 20.11 — exclusive: either Initiatives details OR KPIs details.
                if (mode === 'kpis') {
                    setShown(chainInit, false);
                    setShown(pickerInitWrap, false);
                    setShown(chainKpi, true);
                    if (chainKpi) { resetReveal(chainKpi); revealChain(chainKpi); }
                } else {
                    setShown(chainKpi, false);
                    setShown(pickerInitWrap, true);
                    setShown(chainInit, true);
                    if (chainInit) { resetReveal(chainInit); revealChain(chainInit); }
                }
            });
        }
        // KPI dropdown
        var picker = document.getElementById('jkpiPicker');
        if (picker) {
            picker.addEventListener('change', function () {
                var opt = picker.options[picker.selectedIndex];
                if (!opt) return;
                var n = document.getElementById('jkpiName');
                var o = document.getElementById('jkpiObjective');
                var p = document.getElementById('jkpiPillar');
                if (n) n.textContent = opt.getAttribute('data-name') || opt.text;
                if (o) o.textContent = opt.getAttribute('data-objective') || '—';
                if (p) p.textContent = opt.getAttribute('data-pillar') || '—';
            });
        }

        // Phase 20.10 — dual dropdown: initiative → projects.
        var iniPicker = document.getElementById('jInitPicker');
        var prjPicker = document.getElementById('jProjPicker');
        function refreshChainFromInit() {
            if (!iniPicker) return;
            var opt = iniPicker.options[iniPicker.selectedIndex];
            if (!opt) return;
            var name = document.getElementById('jInitName');
            var obj = document.getElementById('jInitObjective');
            var pil = document.getElementById('jInitPillar');
            if (name) name.textContent = opt.getAttribute('data-name') || opt.text;
            if (obj) obj.textContent = opt.getAttribute('data-objective') || '—';
            if (pil) pil.textContent = opt.getAttribute('data-pillar') || '—';
            if (prjPicker) {
                while (prjPicker.firstChild) prjPicker.removeChild(prjPicker.firstChild);
                var projsJson = opt.getAttribute('data-projects-json') || '[]';
                var projs = [];
                try { projs = JSON.parse(projsJson) || []; } catch (e) { projs = []; }
                var blank = document.createElement('option');
                blank.value = ''; blank.textContent = projs.length ? '— اختر مشروعاً —' : 'لا توجد مشاريع';
                prjPicker.appendChild(blank);
                for (var k = 0; k < projs.length; k++) {
                    var o2 = document.createElement('option');
                    o2.value = projs[k].code || ''; o2.textContent = projs[k].name || projs[k].code || '—';
                    prjPicker.appendChild(o2);
                }
                var pname = document.getElementById('jInitProjectName');
                if (pname) pname.textContent = '—';
            }
        }
        if (iniPicker) iniPicker.addEventListener('change', refreshChainFromInit);
        if (prjPicker) {
            prjPicker.addEventListener('change', function () {
                var pname = document.getElementById('jInitProjectName');
                if (!pname) return;
                pname.textContent = prjPicker.value ? (prjPicker.options[prjPicker.selectedIndex].textContent || '—') : '—';
            });
        }
        if (iniPicker) refreshChainFromInit();
    }
    return function () {
        if (done) return; done = true;
        try {
            var chainInit = document.getElementById('journeyChain');
            if (chainInit) revealChain(chainInit);
            showMsgOnce();
            bindToggle();
        } catch (err) {
            var nodes = document.querySelectorAll('#stage-5 [data-step]');
            for (var k = 0; k < nodes.length; k++) nodes[k].className = nodes[k].className + ' is-in';
            var m = document.getElementById('journeyMsg');
            if (m) m.className = 'jmsg is-in';
        }
    };
})();
</script>
