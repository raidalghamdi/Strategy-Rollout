@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var sel = Model.SelectedInitiative;
    var visionText = Model.Content?.Vision.Ar;
    var hasSelection = sel != null && !string.IsNullOrEmpty(sel.Code);
}
<div class="gac-card text-center" id="journey-card">
    <h2 class="h4 h-md-2">الرحلة نحو الرؤية</h2>

    @if (!hasSelection)
    {
        <div class="alert alert-info mt-2">اختر مبادرتك في مرحلة «دوري في الاستراتيجية» لعرض ارتباط دورك بالرؤية.</div>
    }
    else
    {
        <p class="text-muted">شاهد كيف يتصل دورك — خطوة بخطوة — حتى رؤية الهيئة.</p>
        <div id="journeyChain" class="jchain">
            <div class="jnode jnode--init" data-step="0"><span class="jlabel">مبادرتك</span><span class="jtext">@sel!.Name</span></div>
            <div class="jarrow" data-step="1">↓</div>
            <div class="jnode jnode--obj" data-step="2"><span class="jlabel">الهدف</span><span class="jtext">@(string.IsNullOrEmpty(sel.ObjectiveName) ? "—" : sel.ObjectiveName)</span></div>
            <div class="jarrow" data-step="3">↓</div>
            <div class="jnode jnode--pillar" data-step="4"><span class="jlabel">الركيزة</span><span class="jtext">@(string.IsNullOrEmpty(sel.PillarName) ? "—" : sel.PillarName)</span></div>
            <div class="jarrow" data-step="5">↓</div>
            <div class="jnode jnode--vision" data-step="6"><span class="jlabel">الرؤية</span><span class="jtext">@visionText</span></div>
        </div>
        <div id="journeyMsg" class="jmsg">أنت أقرب للرؤية مما تتصور</div>
    }
</div>

<style>
    #stage-4 .jchain { display: flex; flex-direction: column; align-items: stretch; gap: 8px; max-width: 640px; margin: 18px auto 0; }
    #stage-4 .jnode {
        border-radius: 14px; padding: 16px 18px; color: #fff; text-align: center;
        opacity: 0; transform: translateY(14px) scale(.98); transition: opacity .5s ease, transform .5s ease;
    }
    #stage-4 .jnode.is-in { opacity: 1; transform: translateY(0) scale(1); }
    #stage-4 .jnode--init { background: #5F9600; }
    #stage-4 .jnode--obj { background: #299ECE; }
    #stage-4 .jnode--pillar { background: #0f8f5b; }
    #stage-4 .jnode--vision { background: #067647; }
    #stage-4 .jlabel { display: block; font-size: .82rem; opacity: .9; }
    #stage-4 .jtext { display: block; font-weight: 800; line-height: 1.7; margin-top: 4px; }
    #stage-4 .jarrow { text-align: center; color: #067647; font-size: 1.5rem; line-height: 1; opacity: 0; transition: opacity .5s ease; }
    #stage-4 .jarrow.is-in { opacity: 1; }
    #stage-4 .jmsg {
        margin-top: 22px; color: #067647; font-size: 1.6rem; font-weight: 900; line-height: 1.6;
        opacity: 0; transform: translateY(10px); transition: opacity .6s ease, transform .6s ease;
    }
    #stage-4 .jmsg.is-in { opacity: 1; transform: translateY(0); }
</style>

<script>
// Phase 18 — Stage 4 (الرحلة نحو الرؤية). Animated reveal of the linkage chain.
// iOS Safari-safe ES5: IIFE, for-loops, setTimeout stagger, no template literals,
// no block scope, try/catch with fallback (reveal everything at once).
window.__stageMapInit = (function () {
    var done = false;
    return function () {
        if (done) return; done = true;
        try {
            var steps = document.querySelectorAll('#stage-4 [data-step]');
            if (!steps || steps.length === 0) return;
            for (var i = 0; i < steps.length; i++) {
                (function (node, idx) {
                    setTimeout(function () {
                        node.className = node.className + ' is-in';
                    }, 350 * idx);
                })(steps[i], i);
            }
            var msg = document.getElementById('journeyMsg');
            if (msg) setTimeout(function () { msg.className = 'jmsg is-in'; }, 350 * steps.length + 200);
        } catch (err) {
            var nodes = document.querySelectorAll('#stage-4 [data-step]');
            for (var k = 0; k < nodes.length; k++) nodes[k].className = nodes[k].className + ' is-in';
            var m = document.getElementById('journeyMsg');
            if (m) m.className = 'jmsg is-in';
        }
    };
})();
</script>
