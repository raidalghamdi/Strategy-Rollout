@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var dept = Model.Dept;
    var kpis = Model.Kpis;
    var projects = Model.Projects;
    var pledges = Model.Pledges;
    var map = Model.Map;
    var ink = Model.InkAssets;
    var locked = map?.SignedAt != null;
    var attendee = Model.Session.AttendeeCount;

    // Phase 13 — the single active group signature for this session (MemberId == null).
    var groupSig = ink
        .Where(a => a.AssetKind == "signature" && a.MemberId == null && a.IsActive)
        .OrderByDescending(a => a.CapturedAt)
        .FirstOrDefault();
    var groupComment = groupSig?.TypedText;
    var hasGroupInk = groupSig?.PngBlob != null;
}

@if (TempData["Saved"] != null) { <div class="alert alert-success">@TempData["Saved"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

@{
    var valueColors = new[] { "#299ECE", "#5F9600", "#FAC126", "#5F9600", "#28334A" };
    var values = Model.Content?.Values ?? new List<StrategyHouse.Web.Configuration.LocalizedText>();

    string PledgeName(string type, string code)
    {
        if (type == "OBJ") return Model.Objectives.FirstOrDefault(o => o.ObjectiveCode == code)?.ObjectiveName ?? code;
        if (type == "INIT") return Model.Initiatives.FirstOrDefault(i => i.InitiativeCode == code)?.InitiativeName ?? code;
        return code;
    }
}

@* Phase 13 — attendee count entered by the team (top of the Map stage). *@
<div class="gac-card mb-3">
    <h3 class="h5" style="color:#28334A;font-weight:800;border-bottom:4px solid #FAC126;display:inline-block;padding-bottom:6px;">عدد الموظفين الحاضرين من هذه الإدارة</h3>
    <p class="text-muted small mt-2 mb-2">أدخل عدد منسوبي الإدارة المشاركين في هذه الجلسة.</p>
    <form method="post" asp-action="SaveAttendeeCount" asp-route-sessionId="@Model.Session.Id" class="d-flex flex-wrap gap-2 align-items-center">
        @Html.AntiForgeryToken()
        <input type="number" id="attendeeCount" name="attendeeCount" class="form-control" style="max-width:160px;min-height:44px;"
               min="1" max="500" value="@(attendee.HasValue ? attendee.Value.ToString() : "")" placeholder="مثال: 12" required />
        <button type="submit" class="btn gac-btn-primary text-white" style="min-height:44px;">حفظ العدد</button>
        @if (attendee.HasValue)
        {
            <span class="text-success small">العدد المحفوظ حالياً: <strong>@attendee</strong></span>
        }
    </form>
</div>

@if (pledges.Any())
{
    <div class="gac-card mb-3">
        <h3 class="h5" style="color:#28334A;font-weight:800;border-bottom:4px solid #FAC126;display:inline-block;padding-bottom:6px;">مساهمات الفريق</h3>
        <p class="text-muted small mt-2">الالتزامات التي اختارت إدارتك المساهمة فيها في المرحلة السابقة.</p>
        <div class="d-grid gap-2" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
            @foreach (var p in pledges)
            {
                var typeLabel = p.ElementType == "OBJ" ? "هدف" : p.ElementType == "INIT" ? "مبادرة" : p.ElementType;
                var typeColor = p.ElementType == "OBJ" ? "#28334A" : "#5F9600";
                <div class="commitment-card" style="border:2px solid #FAC126;border-radius:12px;padding:14px;background:#fff;box-shadow:0 2px 10px rgba(250,193,38,.18);">
                    <span class="badge" style="background:@typeColor;">@typeLabel</span>
                    <p class="mb-0 mt-2" style="color:#28334A;font-weight:600;font-size:1.02rem;line-height:1.7;">@PledgeName(p.ElementType, p.ElementCode)</p>
                </div>
            }
        </div>
    </div>
}

<div class="gac-card mb-3">
    <h2 class="h4 h-md-2">خريطة الاستراتيجية — @dept?.NameAr</h2>
    <p class="text-muted">معاينة عناصر إدارتك: المؤشرات والمشاريع والمساهمات.</p>
    @if (values.Any())
    {
        <div class="mb-3">
            <div class="text-muted small mb-2">القيم</div>
            <div class="d-flex flex-wrap gap-2">
                @for (var vi = 0; vi < values.Count; vi++)
                {
                    <span class="value-chip" style="background:@valueColors[vi % valueColors.Length];">@values[vi].Ar</span>
                }
            </div>
        </div>
    }
    <div id="mapCanvas" style="border:1px dashed #299ECE;border-radius:10px;background:#fff;max-height:60vh;overflow:auto;"></div>
</div>

@* Phase 13 — one group signature + comment, replacing per-member signature pads. *@
<div class="gac-card">
    <h3 class="h5" style="color:#28334A;font-weight:800;border-bottom:4px solid #FAC126;display:inline-block;padding-bottom:6px;">توقيع الفريق وتعليقاته</h3>
    @if (locked)
    {
        <div class="alert alert-success mt-3">تم توقيع الخريطة وقفلها.</div>
        @if (hasGroupInk)
        {
            <img src="/Journey/Ink/@groupSig!.Id" style="max-width:100%;width:600px;border:1px solid #eee;border-radius:8px;" alt="توقيع الفريق" />
        }
        @if (!string.IsNullOrWhiteSpace(groupComment))
        {
            <div class="mt-2" style="color:#28334A;font-weight:600;white-space:pre-wrap;">@groupComment</div>
        }
    }
    else
    {
        <p class="text-muted small mt-2">وقّع باسم الفريق — يمكنك الرسم بالقلم و/أو كتابة تعليق. يكفي أحدهما.</p>
        <div class="mb-2">
            <label class="form-label fw-bold" style="color:#28334A;">توقيع/رسم الفريق</label>
            <div id="groupCanvasWrap" style="touch-action:none;border:1px solid #299ECE;border-radius:8px;background:#fff;max-width:100%;">
                <div id="groupCanvas"></div>
            </div>
            <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                <button type="button" id="groupClear" class="btn btn-sm btn-outline-secondary" style="min-height:44px;">مسح</button>
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label fw-bold" for="groupComment" style="color:#28334A;">تعليق الفريق</label>
            <textarea id="groupComment" class="form-control" rows="5" maxlength="2000" style="max-width:100%;"
                      placeholder="اكتب تعليقات الفريق وملاحظاته حول الاستراتيجية...">@groupComment</textarea>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <button type="button" id="groupSave" class="btn gac-btn-primary text-white" style="min-height:44px;">حفظ توقيع الفريق</button>
            <span id="groupStatus" class="small @(groupSig != null ? "text-success" : "text-muted")">@(groupSig != null ? "تم حفظ التوقيع ✓" : "")</span>
        </div>
    }
</div>

<script>
// Phase 13 — Map stage (stage 4). iOS Safari-safe ES5: IIFE, string concat, for-loops,
// window.* exposure, try/catch with a visible fallback. No template literals, no block scoping.
window.__stageMapInit = (function () {
    var done = false;
    return function () {
        if (done) return; done = true;
        try {
            var sessionId = "@Model.Session.Id";
            var tokenEl = document.querySelector('#stage-4 input[name="__RequestVerificationToken"]')
                       || document.querySelector('input[name="__RequestVerificationToken"]');
            var csrf = tokenEl ? tokenEl.value : '';

            var kpis = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(kpis.Select(k => k.KpiName ?? k.KpiCode)));
            var projects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(projects.Select(p => p.ProjectName ?? p.ProjectCode)));
            var pledges = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pledges.Select(p => PledgeName(p.ElementType, p.ElementCode))));

            var cont = document.getElementById('mapCanvas');
            var width = (cont && cont.clientWidth) ? cont.clientWidth : 900;
            var stage = new Konva.Stage({ container: 'mapCanvas', width: width, height: 360 });
            var layer = new Konva.Layer(); stage.add(layer);

            function column(title, items, x, color) {
                layer.add(new Konva.Text({ x: x, y: 10, text: title, fontSize: 16, fontStyle: 'bold', fill: color, width: width / 3 - 20, align: 'right' }));
                var n = Math.min(items.length, 8);
                for (var i = 0; i < n; i++) {
                    var y = 40 + i * 38;
                    layer.add(new Konva.Rect({ x: x, y: y, width: width / 3 - 20, height: 32, fill: '#FAFBFC', stroke: color, cornerRadius: 6, draggable: true }));
                    layer.add(new Konva.Text({ x: x + 6, y: y + 8, text: items[i], fontSize: 12, fill: '#1d2733', width: width / 3 - 32, align: 'right' }));
                }
            }
            function drawColumns() {
                layer.destroyChildren();
                column('مؤشرات', kpis, 10, '#28334A');
                column('مشاريع', projects, width / 3 + 5, '#5F9600');
                column('المساهمة', pledges, 2 * width / 3, '#FAC126');
                layer.draw();
            }
            drawColumns();

            var rT;
            window.addEventListener('resize', function () {
                clearTimeout(rT);
                rT = setTimeout(function () {
                    var w = (cont && cont.clientWidth) ? cont.clientWidth : width;
                    if (Math.abs(w - width) < 8) return;
                    width = w; stage.width(width); drawColumns();
                }, 200);
            });

            @if (!locked)
            {
                <text>
                // Build the single group signature pad.
                var pad = null;
                var groupNode = document.getElementById('groupCanvas');
                if (groupNode) {
                    var isMobile = window.matchMedia('(max-width: 767.98px)').matches;
                    var wrap = document.getElementById('groupCanvasWrap');
                    var gw = (wrap && wrap.clientWidth) ? wrap.clientWidth : 600;
                    var padW = isMobile ? gw : Math.min(gw, 600);
                    var padH = isMobile ? 280 : 300;
                    var pst = new Konva.Stage({ container: 'groupCanvas', width: padW, height: padH });
                    var ply = new Konva.Layer(); pst.add(ply);
                    var painting = false, line = null;
                    var strokes = [];
                    pst.on('pointerdown', function (e) {
                        painting = true;
                        var pos = pst.getPointerPosition();
                        var pressure = (e.evt && e.evt.pressure) ? e.evt.pressure : 0.5;
                        line = new Konva.Line({ stroke: '#28334A', strokeWidth: 1 + pressure * 3, lineCap: 'round', lineJoin: 'round', points: [pos.x, pos.y], tension: 0.2 });
                        ply.add(line);
                        strokes.push({ c: '#28334A', p: [pos.x, pos.y] });
                    });
                    pst.on('pointermove', function () {
                        if (!painting || !line) return;
                        var pos = pst.getPointerPosition();
                        line.points(line.points().concat([pos.x, pos.y]));
                        strokes[strokes.length - 1].p.push(pos.x, pos.y);
                        ply.batchDraw();
                    });
                    function stop() { painting = false; line = null; }
                    pst.on('pointerup', stop); pst.on('pointerleave', stop);
                    pad = {
                        clear: function () { ply.destroyChildren(); ply.draw(); strokes.length = 0; },
                        isEmpty: function () { return strokes.length === 0; },
                        png: function () { return pst.toDataURL({ pixelRatio: 1, mimeType: 'image/png' }); },
                        strokesJson: function () { return JSON.stringify(strokes); }
                    };
                }

                var clearBtn = document.getElementById('groupClear');
                if (clearBtn) clearBtn.addEventListener('click', function () { if (pad) pad.clear(); });

                var saveBtn = document.getElementById('groupSave');
                var statusEl = document.getElementById('groupStatus');
                if (saveBtn) saveBtn.addEventListener('click', function () {
                    var commentEl = document.getElementById('groupComment');
                    var comment = commentEl ? commentEl.value.replace(/^\s+|\s+$/g, '') : '';
                    var hasInk = pad && !pad.isEmpty();
                    if (!hasInk && !comment) {
                        statusEl.textContent = 'ارسم توقيع الفريق أو اكتب تعليقاً أولاً';
                        statusEl.className = 'small text-danger';
                        return;
                    }
                    statusEl.textContent = 'جارٍ الحفظ...';
                    statusEl.className = 'small text-muted';
                    var body = {
                        sessionId: sessionId,
                        pngBase64: hasInk ? pad.png() : null,
                        strokesJson: hasInk ? pad.strokesJson() : null,
                        typedText: comment ? comment : null
                    };
                    fetch('/Journey/SaveGroupSignature', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf },
                        body: JSON.stringify(body)
                    }).then(function (r) { return r.json(); }).then(function (data) {
                        if (data && data.ok) {
                            statusEl.textContent = 'تم حفظ التوقيع ✓';
                            statusEl.className = 'small text-success';
                            setTimeout(function () { location.reload(); }, 700);
                        } else {
                            statusEl.textContent = 'تعذّر الحفظ';
                            statusEl.className = 'small text-danger';
                        }
                    }).catch(function () {
                        statusEl.textContent = 'تعذّر الحفظ — تحقق من الاتصال';
                        statusEl.className = 'small text-danger';
                    });
                });
                </text>
            }
        } catch (err) {
            var host = document.getElementById('mapCanvas');
            if (host) host.innerHTML = '<div style="padding:16px;color:#b00;">تعذّر تحميل الخريطة. يرجى تحديث الصفحة.</div>';
        }
    };
})();
</script>
