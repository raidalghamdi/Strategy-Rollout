@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    Layout = "_JourneyLayout";
    var stage = (int)ViewBag.Stage;
    var sessionId = Model.Session.Id;
    var dept = Model.Dept;
    var stages = new[]
    {
        (1, "الصورة الكبرى"),
        (2, "البيت الاستراتيجي"),
        (3, "دوري في الاستراتيجية"),
        (4, "الرحلة نحو الرؤية"),
        (5, "الأثر"),
    };
    var current = stages.First(s => s.Item1 == stage);
    var introKey = $"journey.stage{stage}.intro";
    string PartialFor(int s) => s switch
    {
        1 => "_StageBigPicture",
        2 => "_StageStrategyHouse",
        3 => "_StageContribute",
        4 => "_StageMap",
        _ => "_StageComplete",
    };
    ViewData["Title"] = $"المرحلة {stage} — {current.Item2}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <style>
        /* Phase 19.13 — unified stepper palette aligned with GAC brand:
           done   = navy #00192B (white text)
           active = gold #FAC126 (navy text, gold-accent border)
           locked = soft gray (muted text)
           Removes the previous green/cyan/gray mix that clashed with the
           authority brand and had weak contrast (green text on green chip). */
        .journey-stepper {
            position: sticky; top: 0; z-index: 50; background: #fff;
            box-shadow: 0 2px 12px rgba(40,51,74,.08);
            display: flex; gap: 6px; padding: 10px; overflow-x: auto; -webkit-overflow-scrolling: touch;
        }
        .journey-stepper .pip {
            flex: 1 0 auto; min-width: 96px; text-align: center; padding: 8px 10px;
            border-radius: 999px; background: #EFEFEF; color: #5a6b80; font-size: .82rem;
            text-decoration: none; white-space: nowrap; transition: background .2s, color .2s;
            border: 1px solid transparent;
        }
        .journey-stepper .pip.active {
            background: #FAC126; color: #00192B; font-weight: 800;
            border-color: #E5AF1F;
            box-shadow: 0 2px 10px rgba(250, 193, 38, .35);
        }
        .journey-stepper .pip.done {
            background: #00192B; color: #FFFFFF; font-weight: 700;
            border-color: #00192B;
        }
        .journey-stepper .pip.locked {
            background: #EFEFEF; color: #8a96a8; opacity: 1; pointer-events: none;
            border-color: #E1E5EB;
        }
        .journey-section .section-title { color: var(--gac-primary); margin-bottom: 6px; }
        .journey-nav { display:flex; justify-content:space-between; gap:12px; margin-top: 20px; }
        .journey-nav .nav-side { display: flex; }
        .journey-progress { font-size:.85rem; color:#5a6b80; text-align:center; margin: 4px 0 14px; }

        /* Phase 19.13 — Back button gets a proper ghost-button shape so it
           reads as a button (not floating text). Navy outline + navy text on
           white, with a subtle navy hover fill. Matches the Next button's pill
           shape (border-radius:999px) and minimum height for touch (44px). */
        .journey-nav .btn.btn-outline-secondary {
            background: #FFFFFF !important;
            color: #00192B !important;
            border: 1.5px solid #00192B !important;
            border-radius: 999px !important;
            font-weight: 700;
            min-height: 44px;
            padding: .55rem 1.4rem;
            display: inline-flex; align-items: center; justify-content: center;
            transition: background .15s ease, color .15s ease;
        }
        .journey-nav .btn.btn-outline-secondary:hover,
        .journey-nav .btn.btn-outline-secondary:focus {
            background: #00192B !important;
            color: #FFFFFF !important;
            border-color: #00192B !important;
        }
        @@media (max-width: 576px) {
            .journey-stepper { gap: 4px; padding: 8px; }
            .journey-stepper .pip { min-width: 0; flex: 1 1 auto; font-size: .68rem; padding: 7px 3px; }
            /* Stack nav: Next on top, Back below (RTL reads top-down). */
            .journey-nav { flex-direction: column; gap: 10px; }
            .journey-nav .nav-side { width: 100%; }
            .journey-nav .nav-side .btn { width: 100%; }
            .journey-nav .nav-next { order: 0; }
            .journey-nav .nav-back { order: 1; }
        }
    </style>
}

<div class="journey-stepper" id="stepper">
    @foreach (var (n, label) in stages)
    {
        var cls = n == stage ? "active" : (n < stage ? "done" : "locked");
        var reachable = n <= Math.Min(Model.Session.CurrentStage, 5);
        if (reachable && n != stage)
        {
            <a class="pip @cls" href="/Journey/Run/@sessionId/@n">@n. @label</a>
        }
        else
        {
            <span class="pip @cls">@n. @label</span>
        }
    }
</div>

<div class="container-fluid px-0 px-md-2 mt-2">
    <h1 class="h4 text-center my-2">رحلة @dept?.NameAr</h1>
    <div class="journey-progress">المرحلة @stage من 5 — @current.Item2</div>

    <section id="stage-@stage" class="journey-section is-active" data-stage="@stage">
        <h2 class="section-title h5">@stage — @current.Item2</h2>
        @* Phase 19.6 — stage 1 no longer shows the "select members" instruction line. *@
        @if (stage != 1)
        {
            <p class="text-muted small">@Html.Content(introKey)</p>
        }
        @await Html.PartialAsync(PartialFor(stage), Model)
    </section>

    <div class="journey-nav">
        <div class="nav-side nav-back">
            @if (stage > 1)
            {
                <a class="btn btn-outline-secondary" href="/Journey/Run/@sessionId/@(stage - 1)">⟶ رجوع</a>
            }
        </div>
        <div class="nav-side nav-next">
            @if (stage == 4)
            {
                <a class="btn gac-btn-primary text-white" href="/Journey/Run/@sessionId/5">المتابعة إلى مرحلة الأثر ⟵</a>
            }
            else if (stage < 5)
            {
                <a class="btn gac-btn-primary text-white" href="/Journey/Run/@sessionId/@(stage + 1)">التالي ⟵</a>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // The stage partials lazily initialise heavy widgets when they receive a
    // 'stageReady' event (sankey, Konva map, contribution checkboxes, confetti). On a single-stage
    // page we fire it once for the rendered stage.
    var stage = @stage;
    function fireReady() {
        if (stage === 4 && window.__stageMapInit) window.__stageMapInit();
        // Phase 19 — stage 5 confetti now fires only after the inline quiz completes
        // (the thank-you block is revealed then), so it is no longer fired on load.
        document.dispatchEvent(new CustomEvent('stageReady', { detail: { stage: stage } }));
    }
    document.addEventListener('DOMContentLoaded', fireReady);
    if (document.readyState !== 'loading') fireReady();
})();
</script>
}
