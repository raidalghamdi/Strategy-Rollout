@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var objectives = Model.Objectives;
    var initiatives = Model.Initiatives;
    var pledges = Model.Pledges;
    var pledgedKeys = pledges.Select(p => p.ElementType + ":" + p.ElementCode).ToHashSet();
}
<div class="gac-card">
    <h2 class="h4 h-md-2">أين ترغب إدارتك بالمساهمة؟</h2>
    <p class="text-muted">اختر المساهمات التي يلتزم بها فريقك بتحديد المربع «اعتماد» على كل بطاقة. يمكنك إلغاء التحديد لإزالة الاعتماد.</p>
    <style>
        #stage-3 .contrib-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
        #stage-3 .contrib-card {
            border: 2px solid #d5dbe4; border-radius: 12px; padding: 14px;
            background: #fff; transition: border-color .15s, box-shadow .15s;
        }
        #stage-3 .contrib-card.is-approved {
            border-color: #FAC126; box-shadow: 0 2px 10px rgba(250,193,38,.25);
        }
        #stage-3 .contrib-card .approve-row {
            display: flex; align-items: center; gap: 10px; margin-top: 12px;
            min-height: 44px;
        }
        #stage-3 .contrib-card .approve-row input[type=checkbox] {
            width: 24px; height: 24px; flex: 0 0 auto; cursor: pointer;
        }
        #stage-3 .contrib-card .approve-row label { cursor: pointer; font-weight: 700; margin: 0; }
        #stage-3 .check-badge {
            display: none; margin-inline-start: auto; background: #FAC126; color: #28334A;
            font-weight: 800; border-radius: 999px; padding: 2px 12px; font-size: .9rem;
        }
        #stage-3 .contrib-card.is-approved .check-badge { display: inline-block; }
        #stage-3 .type-badge { font-size: .78rem; border-radius: 6px; padding: 2px 8px; color: #fff; }
        #stage-3 .t-OBJ { background: #28334A; }
        #stage-3 .t-INIT { background: #5F9600; }
        #stage-3 .el-name { display: block; margin-top: 8px; font-weight: 600; color: #28334A; }
        @@media (max-width: 576px) {
            #stage-3 .contrib-grid { grid-template-columns: 1fr; }
        }
    </style>

    @{
        var cards = objectives
            .Select(o => (Type: "OBJ", Code: o.ObjectiveCode, Name: o.ObjectiveName, Label: "هدف"))
            .Concat(initiatives.Select(i => (Type: "INIT", Code: i.InitiativeCode, Name: i.InitiativeName, Label: "مبادرة")))
            .ToList();
    }
    @if (cards.Count == 0)
    {
        <div class="alert alert-info">لا توجد عناصر متاحة لهذه الإدارة.</div>
    }
    else
    {
        <div class="contrib-grid">
            @foreach (var c in cards)
            {
                var approved = pledgedKeys.Contains(c.Type + ":" + c.Code);
                <div class="contrib-card @(approved ? "is-approved" : "")" data-type="@c.Type" data-code="@c.Code">
                    <div>
                        <span class="type-badge t-@c.Type">@c.Label</span>
                        <span class="check-badge">✓ معتمد</span>
                    </div>
                    <span class="el-name">@c.Name</span>
                    <div class="approve-row">
                        <input type="checkbox" id="chk-@c.Type-@c.Code" class="contrib-check" @(approved ? "checked" : "") />
                        <label for="chk-@c.Type-@c.Code">اعتماد</label>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
(function () {
    var sessionId = '@Model.Session.Id';

    function bind() {
        document.querySelectorAll('#stage-3 .contrib-check').forEach(function (chk) {
            if (chk.__bound) return; chk.__bound = true;
            chk.addEventListener('change', function () {
                var card = chk.closest('.contrib-card');
                var type = card.dataset.type, code = card.dataset.code;
                chk.disabled = true;
                var url = chk.checked ? '@Url.Action("SavePledge")' : '@Url.Action("RemovePledge")';
                var body = chk.checked
                    ? { sessionId: sessionId, elementType: type, elementCode: code, contributionKind: 'التزام' }
                    : { sessionId: sessionId, elementType: type, elementCode: code };
                fetch(url, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                  .then(function () { card.classList.toggle('is-approved', chk.checked); })
                  .catch(function () { chk.checked = !chk.checked; })
                  .finally(function () { chk.disabled = false; });
            });
        });
    }

    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 3) bind(); });
    if (document.getElementById('stage-3') && document.getElementById('stage-3').classList.contains('is-active')) bind();
})();
</script>
