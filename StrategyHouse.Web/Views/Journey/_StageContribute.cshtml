@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var departments = Model.DepartmentNames;
    var role = Model.RoleContribution;
    var savedImpact = role?.PerceivedImpact;
    var savedDept = role?.DepartmentCode;
    var savedInit = role?.SelectedInitiativeCode;

    // Phase 19.13 — the journey already knows the department from the journey
    // code (GAC202 / GAC206 / GAC208), so re-asking on stage 3 is redundant.
    // Prefer the saved RoleContribution dept (if the user previously chose),
    // otherwise fall back to the session's department name. Only fall back to
    // the dropdown when neither is available (defensive).
    var sessionDeptName = Model.Dept?.NameAr;
    var lockedDept = !string.IsNullOrWhiteSpace(savedDept) ? savedDept
                    : !string.IsNullOrWhiteSpace(sessionDeptName) ? sessionDeptName
                    : null;
    // Phase 20.17 — unified agency journey (gac.admin). The journey context is
    // "الهيئة الشاملة" (used by the API to load ALL initiatives), but the
    // dept-chip label reads "الهيئة بالكامل" for clarity to executive users.
    var lockedDeptLabel = string.Equals(lockedDept, "الهيئة الشاملة", StringComparison.Ordinal)
        ? "الهيئة بالكامل"
        : lockedDept;
}
<div class="gac-card" id="contribute-card">
    <h2 class="h4 h-md-2">دوري في الاستراتيجية</h2>
    <p class="text-muted">اختر المبادرة الأقرب لعملك وشاركنا الأثر الذي تراه — لنُظهر كيف يرتبط دورك بالرؤية.</p>

    <div class="mb-3">
        <label class="form-label fw-bold" style="color:#28334A;">الإدارة</label>
        @if (!string.IsNullOrWhiteSpace(lockedDept))
        {
            @* Department already known from the journey context — show as a
               read-only chip and stash it in a hidden input. The original
               #deptSelect id is preserved (as a hidden field) so the existing
               JS that reads el('deptSelect').value continues to work without
               changes. *@
            <div class="dept-chip" aria-readonly="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6" stroke="#067647" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="dept-chip__name">@lockedDeptLabel</span>
            </div>
            <input type="hidden" id="deptSelect" value="@lockedDept" />
        }
        else
        {
            <select id="deptSelect" class="form-select" style="max-width:520px;min-height:44px;">
                <option value="">— اختر الإدارة —</option>
                @foreach (var d in departments)
                {
                    <option value="@d" selected="@(d == savedDept)">@d</option>
                }
            </select>
        }
    </div>

    <div id="initiativesBlock" class="mb-3" hidden>
        <label class="form-label fw-bold" style="color:#28334A;">المبادرة الأقرب لعملك</label>
        <div id="initiativesStatus" class="small text-muted mb-2"></div>
        <div id="initiativesGrid" class="contrib-grid"></div>
    </div>

    <div id="impactBlock" class="mb-3" hidden>
        <label class="form-label fw-bold" for="impactText" style="color:#28334A;">برأيك… ما الأثر الذي تسهم هذه المبادرة في تحقيقه؟</label>
        <textarea id="impactText" class="form-control" rows="3" maxlength="4000" style="max-width:100%;"
                  placeholder="اكتب الأثر الذي تراه… (اختياري)">@savedImpact</textarea>
        <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
            <span id="contribStatus" class="small text-muted"></span>
        </div>
    </div>

    @* Phase 20.10 — the linkage chain that used to live here (مبادرة → هدف → ركيزة → رؤية)
       was removed; the same chain is shown in the next stage (الرحلة نحو الرؤية). *@
</div>

<style>
    /* Phase 20.10 — initiative cards now match the colored chain style used
       in the next stage. Selected initiative gets the brighter green; the
       inner projects details panel keeps a soft translucent backdrop. */
    #stage-4 .contrib-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
    #stage-4 .contrib-card {
        background: #5F9600;
        color: #fff;
        border: 2px solid transparent;
        border-radius: 14px;
        padding: 16px 18px;
        cursor: pointer;
        transition: background .15s, border-color .15s, box-shadow .15s, transform .12s;
        display: block;
        margin: 0;
        box-shadow: 0 2px 10px rgba(95,150,0,.18);
    }
    #stage-4 .contrib-card:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(95,150,0,.28); }
    #stage-4 .contrib-card.is-selected { background: #067647; border-color: #fff; box-shadow: 0 4px 18px rgba(6,118,71,.35); }
    #stage-4 .contrib-card input[type=radio] { width: 20px; height: 20px; accent-color: #fff; vertical-align: middle; }
    #stage-4 .contrib-card .ci-name { font-weight: 800; color: #fff; margin-inline-start: 8px; font-size: 1rem; line-height: 1.6; }
    #stage-4 .contrib-card .ci-meta { display: block; margin-top: 8px; font-size: .82rem; color: rgba(255,255,255,.92); line-height: 1.7; }

    /* Expandable projects under each initiative card. */
    #stage-4 .ci-details {
        margin-top: 10px;
        border-top: 1px dashed rgba(255,255,255,.45);
        padding-top: 8px;
    }
    #stage-4 .ci-details summary {
        cursor: pointer;
        font-size: .85rem;
        font-weight: 700;
        color: #fff;
        list-style: none;
        padding: 4px 0;
        outline: none;
        user-select: none;
    }
    #stage-4 .ci-details summary::-webkit-details-marker { display: none; }
    #stage-4 .ci-details summary::before {
        content: '◀';
        display: inline-block;
        margin-inline-end: 6px;
        font-size: .7rem;
        transition: transform .2s;
    }
    #stage-4 .ci-details[open] summary::before { transform: rotate(-90deg); }
    #stage-4 .ci-children { padding: 8px 0 4px; font-size: .82rem; color: #fff; }
    #stage-4 .ci-child-group { margin-bottom: 8px; }
    #stage-4 .ci-child-group:last-child { margin-bottom: 0; }
    #stage-4 .ci-child-group h6 {
        font-size: .78rem;
        font-weight: 700;
        color: rgba(255,255,255,.9);
        margin: 0 0 4px;
        text-transform: none;
    }
    #stage-4 .ci-child-group ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    #stage-4 .ci-child-group li {
        padding: 6px 10px;
        background: rgba(255,255,255,.2);
        border-radius: 8px;
        margin-bottom: 4px;
        line-height: 1.5;
        color: #fff;
        font-weight: 600;
    }
    #stage-4 .ci-child-meta { color: rgba(255,255,255,.8); font-size: .75rem; font-weight: 400; }
    @@media (max-width: 576px) { #stage-4 .contrib-grid { grid-template-columns: 1fr; } }

    /* Phase 19.13 — read-only department chip for stage 4 (the dept is already
       known from the journey context, no need for a dropdown). */
    #stage-4 .dept-chip {
        display: inline-flex; align-items: center; gap: 10px;
        background: rgba(6, 118, 71, .08);
        border: 1.5px solid rgba(6, 118, 71, .35);
        border-radius: 12px; padding: 10px 16px;
        font-weight: 700; color: #28334A; min-height: 44px;
        max-width: 520px;
    }
    #stage-4 .dept-chip__name { line-height: 1.4; }
</style>

<script>
// Phase 18 — Stage «دوري في الاستراتيجية» (was 3, now 4). iOS Safari-safe ES5:
// IIFE, string concat, for-loops, no template literals, no block scope,
// try/catch with fallback.
// Phase 20.10 — removed the bottom linkage chain (shown in the next stage instead).
(function () {
    var sessionId = '@Model.Session.Id';
    var savedInit = '@(savedInit ?? "")';
    var selectedCode = '', selectedName = '', selectedObj = '', selectedPillar = '';

    function el(id) { return document.getElementById(id); }

    function renderInitiatives(items) {
        var grid = el('initiativesGrid');
        if (!grid) return;
        grid.innerHTML = '';
        if (!items || items.length === 0) {
            el('initiativesStatus').textContent = 'لا توجد مبادرات مرتبطة بهذه الإدارة.';
            return;
        }
        el('initiativesStatus').textContent = '';
        for (var i = 0; i < items.length; i++) {
            (function (it) {
                var label = document.createElement('label');
                label.className = 'contrib-card';
                label.setAttribute('data-code', it.code);
                var meta = '';
                if (it.objectiveName) meta += 'الهدف: ' + it.objectiveName;
                if (it.pillarName) meta += (meta ? ' · ' : '') + 'الركيزة: ' + it.pillarName;

                // Phase 20.9 — step "دوري في الاستراتيجية" (was 3, now 4) now shows projects
                // only. KPI linkage moved to the next stage (الرحلة نحو الرؤية)
                // where users toggle between Initiatives and KPIs.
                var projects = it.projects || [];
                var detailsHtml = '';
                if (projects.length > 0) {
                    var projLis = '';
                    for (var pi = 0; pi < projects.length; pi++) {
                        var pr = projects[pi];
                        var pmeta = pr.meta ? ' <span class="ci-child-meta">— ' + pr.meta + '</span>' : '';
                        projLis += '<li>' + (pr.name || pr.code) + pmeta + '</li>';
                    }
                    detailsHtml = '<details class="ci-details" onclick="event.stopPropagation();">'
                        + '<summary>عرض المشاريع (' + projects.length + ' مشروع)</summary>'
                        + '<div class="ci-children">'
                        +   '<div class="ci-child-group"><h6>المشاريع</h6><ul>' + projLis + '</ul></div>'
                        + '</div>'
                        + '</details>';
                }

                label.innerHTML = '<input type="radio" name="initiative" value="' + it.code + '" />'
                    + '<span class="ci-name">' + (it.name || it.code) + '</span>'
                    + (meta ? '<span class="ci-meta">' + meta + '</span>' : '')
                    + detailsHtml;
                // Clicking inside <details> (the summary or list) must NOT bubble
                // up to the label and toggle the radio.
                var detailsEl = label.querySelector('details');
                if (detailsEl) {
                    detailsEl.addEventListener('click', function (ev) { ev.stopPropagation(); });
                }
                var radio = label.querySelector('input');
                radio.addEventListener('change', function () {
                    var cards = grid.querySelectorAll('.contrib-card');
                    for (var j = 0; j < cards.length; j++) cards[j].className = 'contrib-card';
                    label.className = 'contrib-card is-selected';
                    selectedCode = it.code; selectedName = it.name || it.code;
                    selectedObj = it.objectiveName || ''; selectedPillar = it.pillarName || '';
                    if (el('impactBlock')) el('impactBlock').removeAttribute('hidden');
                    saveContribution();
                });
                if (savedInit && savedInit === it.code) { radio.checked = true; radio.dispatchEvent(new CustomEvent('change')); }
                grid.appendChild(label);
            })(items[i]);
        }
    }

    function loadInitiatives(division) {
        var block = el('initiativesBlock');
        if (!division) { if (block) block.setAttribute('hidden', 'hidden'); return; }
        if (block) block.removeAttribute('hidden');
        el('initiativesStatus').textContent = 'جارٍ التحميل...';
        el('initiativesGrid').innerHTML = '';
        try {
            fetch('@Url.Action("InitiativesForDepartment")?division=' + encodeURIComponent(division), { method: 'GET' })
                .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                .then(function (data) { renderInitiatives(data ? data.initiatives : []); })
                .catch(function () { el('initiativesStatus').textContent = 'تعذّر تحميل المبادرات، حاول مرة أخرى.'; });
        } catch (e) { el('initiativesStatus').textContent = 'تعذّر تحميل المبادرات، حاول مرة أخرى.'; }
    }

    function saveContribution() {
        var status = el('contribStatus');
        var impact = el('impactText') ? el('impactText').value.replace(/^\s+|\s+$/g, '') : '';
        var dept = el('deptSelect') ? el('deptSelect').value : '';
        if (status) { status.textContent = 'جارٍ الحفظ...'; status.className = 'small text-muted'; }
        try {
            fetch('@Url.Action("SaveRoleContribution")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId: sessionId, departmentCode: dept, selectedInitiativeCode: selectedCode, perceivedImpact: impact })
            }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
              .then(function () { if (status) { status.textContent = 'تم الحفظ ✓'; status.className = 'small text-success'; } })
              .catch(function () { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } });
        } catch (e) { if (status) { status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; status.className = 'small text-danger'; } }
    }

    function init() {
        var sel = el('deptSelect');
        if (sel && !sel.__bound) {
            sel.__bound = true;
            if (sel.tagName === 'SELECT') {
                sel.addEventListener('change', function () { loadInitiatives(sel.value); });
            }
            if (sel.value) loadInitiatives(sel.value);
        }
        var impact = el('impactText');
        if (impact && !impact.__bound) {
            impact.__bound = true;
            var impactTimer = null;
            impact.addEventListener('input', function () {
                if (!selectedCode) return;
                if (impactTimer) clearTimeout(impactTimer);
                impactTimer = setTimeout(function () { saveContribution(); }, 800);
            });
        }
    }
    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 4) init(); });
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
})();
</script>
