@model StrategyHouse.Web.Controllers.JourneyRunViewModel
@{
    var objectives = Model.Objectives;
    var initiatives = Model.Initiatives;
    var pledges = Model.Pledges;
    var pledgedKeys = pledges.Select(p => p.ElementType + ":" + p.ElementCode).ToHashSet();
    var values = Model.Content?.Values ?? new System.Collections.Generic.List<StrategyHouse.Web.Configuration.LocalizedText>();
    var selectedValueText = Model.SelectedTeamValue;
}
<div class="gac-card">
    <h2 class="h4 h-md-2">أين ترغب إدارتك بالمساهمة؟</h2>
    <div class="alert alert-info" role="note">
        هذه المساهمات اختيارية وتساعدنا على فهم رؤيتكم بشكل أعمق. يمكنك المتابعة للمراحل القادمة دون تعبئتها.
    </div>
    <p class="text-muted">حدّد المساهمات التي تعبّر عن إدارتك بتحديد المربع «اختيار» على كل بطاقة. يمكنك إلغاء التحديد في أي وقت.</p>
    <style>
        #stage-3 .contrib-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
        #stage-3 .contrib-card {
            border: 2px solid #d5dbe4; border-radius: 12px; padding: 14px;
            background: #fff; transition: border-color .15s, box-shadow .15s;
        }
        #stage-3 .contrib-card.is-approved {
            border-color: #FAC126; box-shadow: 0 2px 10px rgba(250,193,38,.25);
        }
        #stage-3 .contrib-card .approve-row {
            display: flex; align-items: center; gap: 10px; margin-top: 12px;
            min-height: 44px;
        }
        #stage-3 .contrib-card .approve-row input[type=checkbox] {
            width: 24px; height: 24px; flex: 0 0 auto; cursor: pointer;
        }
        #stage-3 .contrib-card .approve-row label { cursor: pointer; font-weight: 700; margin: 0; }
        #stage-3 .check-badge {
            display: none; margin-inline-start: auto; background: #FAC126; color: #28334A;
            font-weight: 800; border-radius: 999px; padding: 2px 12px; font-size: .9rem;
        }
        #stage-3 .contrib-card.is-approved .check-badge { display: inline-block; }
        #stage-3 .type-badge { font-size: .78rem; border-radius: 6px; padding: 2px 8px; color: #fff; }
        #stage-3 .t-OBJ { background: #28334A; }
        #stage-3 .t-INIT { background: #5F9600; }
        #stage-3 .el-name { display: block; margin-top: 8px; font-weight: 600; color: #28334A; }
        @@media (max-width: 576px) {
            #stage-3 .contrib-grid { grid-template-columns: 1fr; }
        }
    </style>

    @{
        var cards = objectives
            .Select(o => (Type: "OBJ", Code: o.ObjectiveCode, Name: o.ObjectiveName, Label: "هدف"))
            .Concat(initiatives.Select(i => (Type: "INIT", Code: i.InitiativeCode, Name: i.InitiativeName, Label: "مبادرة")))
            .ToList();
    }
    @if (cards.Count == 0)
    {
        <div class="alert alert-info">لا توجد عناصر متاحة لهذه الإدارة.</div>
    }
    else
    {
        <div class="contrib-grid">
            @foreach (var c in cards)
            {
                var approved = pledgedKeys.Contains(c.Type + ":" + c.Code);
                <div class="contrib-card @(approved ? "is-approved" : "")" data-type="@c.Type" data-code="@c.Code">
                    <div>
                        <span class="type-badge t-@c.Type">@c.Label</span>
                        <span class="check-badge">✓ مختار</span>
                    </div>
                    <span class="el-name">@c.Name</span>
                    <div class="approve-row">
                        <input type="checkbox" id="chk-@c.Type-@c.Code" class="contrib-check" @(approved ? "checked" : "") />
                        <label for="chk-@c.Type-@c.Code">اختيار</label>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (values.Count > 0)
{
    <div class="gac-card mt-3" id="team-values">
        <h2 class="h4 h-md-2">اختر القيمة التي تعبّر عن فريقكم</h2>
        <p class="text-muted">اختياري — اختر القيمة الأقرب لروح فريقكم من قيم الهيئة الخمس.</p>
        <div class="tv-grid">
            @foreach (var v in values)
            {
                var isSel = !string.IsNullOrEmpty(selectedValueText) && selectedValueText == v.Ar;
                <label class="tv-card @(isSel ? "is-selected" : "")" data-key="@v.En" data-text="@v.Ar">
                    <input type="radio" name="teamValue" value="@v.Ar" @(isSel ? "checked" : "") />
                    <span class="tv-name">@v.Ar</span>
                </label>
            }
        </div>
        <div id="tv-status" class="small text-muted mt-2" style="min-height:1.2em;"></div>
    </div>
    <style>
        #team-values .tv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
        #team-values .tv-card {
            border: 2px solid #d5dbe4; border-radius: 12px; padding: 16px 14px; background: #fff;
            text-align: center; cursor: pointer; transition: border-color .15s, box-shadow .15s;
            display: flex; align-items: center; justify-content: center; gap: 8px; min-height: 56px; margin: 0;
        }
        #team-values .tv-card.is-selected { border-color: #067647; box-shadow: 0 2px 10px rgba(6,118,71,.2); }
        #team-values .tv-card input[type=radio] { width: 20px; height: 20px; accent-color: #067647; }
        #team-values .tv-name { font-weight: 700; color: #28334A; }
    </style>
}

<script>
(function () {
    var sessionId = '@Model.Session.Id';

    function bind() {
        document.querySelectorAll('#stage-3 .contrib-check').forEach(function (chk) {
            if (chk.__bound) return; chk.__bound = true;
            chk.addEventListener('change', function () {
                var card = chk.closest('.contrib-card');
                var type = card.dataset.type, code = card.dataset.code;
                chk.disabled = true;
                var url = chk.checked ? '@Url.Action("SavePledge")' : '@Url.Action("RemovePledge")';
                var body = chk.checked
                    ? { sessionId: sessionId, elementType: type, elementCode: code, contributionKind: 'التزام' }
                    : { sessionId: sessionId, elementType: type, elementCode: code };
                fetch(url, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                  .then(function () { card.classList.toggle('is-approved', chk.checked); })
                  .catch(function () { chk.checked = !chk.checked; })
                  .finally(function () { chk.disabled = false; });
            });
        });
    }

    function bindValues() {
        var radios = document.querySelectorAll('#team-values input[name="teamValue"]');
        var status = document.getElementById('tv-status');
        for (var i = 0; i < radios.length; i++) {
            (function (radio) {
                if (radio.__bound) return; radio.__bound = true;
                radio.addEventListener('change', function () {
                    var card = radio.closest('.tv-card');
                    var key = card ? card.getAttribute('data-key') : '';
                    var text = card ? card.getAttribute('data-text') : radio.value;
                    var cards = document.querySelectorAll('#team-values .tv-card');
                    for (var j = 0; j < cards.length; j++) cards[j].className = 'tv-card';
                    if (card) card.className = 'tv-card is-selected';
                    if (status) status.textContent = 'جارٍ الحفظ...';
                    try {
                        fetch('@Url.Action("SaveTeamValue")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sessionId: sessionId, valueKey: key, valueText: text })
                        }).then(function (r) { return r.ok ? r.json() : Promise.reject(); })
                          .then(function () { if (status) status.textContent = 'تم حفظ اختياركم: ' + text; })
                          .catch(function () { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; });
                    } catch (e) { if (status) status.textContent = 'تعذّر الحفظ، حاول مرة أخرى.'; }
                });
            })(radios[i]);
        }
    }

    document.addEventListener('stageReady', function (e) { if (e.detail && e.detail.stage === 3) { bind(); bindValues(); } });
    if (document.getElementById('stage-3') && document.getElementById('stage-3').classList.contains('is-active')) { bind(); bindValues(); }
})();
</script>
